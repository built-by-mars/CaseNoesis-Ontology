        "@value": "2024-08-25T00:00:00-04:00"
      },
      "uco-action:endTime": {
        "@type": "xsd:dateTime",
        "@value": "2024-08-26T00:00:00-04:00"
      },
      "cryptoinv:launderingTechnique": [
        "crypto-to-cash",
        "unlicensed-money-transmission"
      ]
    },
