      "uco-core:eventContext": [
        {
          "@id": "urn:uuid:5a459c41-c310-51a0-aed3-eac4e0e054fe"
        },
        {
          "@id": "urn:uuid:51a3c439-fa6f-5ed9-aa3d-7b2b2d17eb24"
        },
        {
          "@id": "urn:uuid:1a72cb33-15eb-58df-9c48-e7212b531d10"
