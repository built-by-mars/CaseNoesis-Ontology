:techniqueDFT-1012 a solveit-core:Technique ;
    rdfs:label "DFT-1012: Write protect storage media using a hardware write blocker"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/StorageMedium"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/WriteProtectedDeviceInterface"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1118,
        :weaknessDFW-1119,
        :weaknessDFW-1120 ;
    solveit-core:hasReference :citationDFCite-1089 ;
    solveit-core:techniqueDescription "A hardware write blocking device [should] prevent any change to data in the user area of a hard drive while allowing access to all data on a hard drive. (Lyle 2006)" ;
    solveit-core:techniqueDetails "Note that \"Sometimes it may be desirable to change a drive configuration to obtain access to otherwise hidden sectors, for example, such as within an HPA (host protected area).\" (Lyle 2006) " ;
    solveit-core:techniqueID "DFT-1012" ;
    solveit-core:techniqueName "Write protect storage media using a hardware write blocker" .

:techniqueDFT-1037 a solveit-core:Technique ;
    rdfs:label "DFT-1037: Obtain password from the device's owner"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/password"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1037" ;
    solveit-core:techniqueName "Obtain password from the device's owner" .

:techniqueDFT-1040 a solveit-core:Technique ;
    rdfs:label "DFT-1040: Exploit a mobile device to facilitate privileged access for data extraction"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/isPrivileged"^^xsd:anyURI ;
    solveit-core:hasExample "",
        "Checkra1n, https://checkra.in" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1157,
        :weaknessDFW-1158 ;
    solveit-core:hasReference :citationDFCite-1049 ;
    solveit-core:hasSynonym "jailbreaking",
        "mobile device exploit",
        "rooting" ;
    solveit-core:techniqueDescription "A process that typically exploits a security flaw in a specific device or operating system to enable users to perform higher privileged functions on a device (derived from Grover 2013)" ;
    solveit-core:techniqueID "DFT-1040" ;
    solveit-core:techniqueName "Exploit a mobile device to facilitate privileged access for data extraction" .

:techniqueDFT-1125 a solveit-core:Technique ;
    rdfs:label "DFT-1125: Keyword search (live)"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/KeywordSearchResult"^^xsd:anyURI ;
