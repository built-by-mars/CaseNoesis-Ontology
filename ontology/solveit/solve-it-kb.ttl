        :techniqueDFT-1182,
        :techniqueDFT-1184 ;
    solveit-core:hasSynonym "Temporal analysis",
        "Timeline analysis" ;
    solveit-core:techniqueDescription "The process of searching, filtering, sorting, highlighting, or aggregating timeline entries to determine which are relevant for event reconstruction, or to identify times of interest (adapted from Breitinger et al. 2025)" ;
    solveit-core:techniqueDetails "This can involve refinement approaches such as: filtering irrelevant entries, highlighting key entries, or aggregating entries into more meaningful events. This may result in a filtered timeline, or a set of highlighted timeline entries" ;
    solveit-core:techniqueID "DFT-1086" ;
    solveit-core:techniqueName "Analyze timeline" .

