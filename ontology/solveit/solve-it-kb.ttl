    rdfs:label "DFT-1139: Extract browser session artifacts"@en ;
    solveit-core:techniqueDescription "The examination of sessions and open tabs and their individual histories" ;
    solveit-core:techniqueID "DFT-1139" ;
    solveit-core:techniqueName "Extract browser session artifacts" .

:techniqueDFT-1140 a solveit-core:Technique ;
    rdfs:label "DFT-1140: Extract browser autofill artifacts"@en ;
    solveit-core:techniqueDescription "The examination of data that is stored to autocomplete entries in forms" ;
    solveit-core:techniqueID "DFT-1140" ;
