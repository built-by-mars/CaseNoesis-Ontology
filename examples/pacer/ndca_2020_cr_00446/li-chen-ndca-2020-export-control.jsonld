    {
      "@id": "urn:uuid:d2588b50-fe14-5fa0-8edf-4373e7c2f284",
      "@type": [
        "legalproc:ChargingInstrument",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Indictment, Doc 1 (filed under seal 2020-12-01; unsealed 2024-04-24)",
      "legalproc:instrumentType": "indictment",
      "uco-core:description": "Four counts against both defendants: conspiracy to violate IEEPA, unlawful export information activities, smuggling of goods, and willful IEEPA violations, plus a criminal forfeiture allegation. Filed under seal on 2020-12-01 (sealing order, Magistrate Judge Laurel Beeler); unsealed on government application 2024-04-24 (Magistrate Judge Alex G. Tse), the day after Chen's arrest. Source: PACER Doc docket sheet (docket), entries 1-4"
    },
    {
      "@id": "urn:uuid:b0dd6308-99e1-5c65-a0d5-d0b7cea3095e",
