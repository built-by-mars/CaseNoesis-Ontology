:techniqueDFT-1034 a solveit-core:Technique ;
    rdfs:label "DFT-1034: Attack a stored credential or device using a brute force approach"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/password"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1140,
        :weaknessDFW-1141,
        :weaknessDFW-1142 ;
    solveit-core:hasReference :citationDFCite-1077 ;
    solveit-core:hasSynonym "brute force attack",
        "exhaustive password search" ;
    solveit-core:techniqueDescription "A brute force attack, or exhaustive search is a password cracking approach where every combination of characters is tested until the correct one is found. This method is \"guaranteed to work\" given infinite time and resources which in a real-life scenario is not feasible." ;
    solveit-core:techniqueDetails "Brute force attack involves trying every possible combination in a defined search space to find the correct value. The search space could be limited to just numbers, for example in the case of a 4-digit PIN number, or alphanumerical values or even the full ASCII character set. The larger the search space, the longer it takes to complete a brute force attack." ;
    solveit-core:techniqueID "DFT-1034" ;
    solveit-core:techniqueName "Attack a stored credential or device using a brute force approach" .

:techniqueDFT-1035 a solveit-core:Technique ;
    rdfs:label "DFT-1035: Attack a stored credential or device using a dictionary-based approach"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/password"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1137,
        :weaknessDFW-1138,
        :weaknessDFW-1139 ;
    solveit-core:hasReference :citationDFCite-1075 ;
    solveit-core:hasSynonym "dictionary attack" ;
    solveit-core:techniqueDescription "A dictionary attack is a password cracking technique where an attacker uses a list of passwords, called a dictionary, to attempt to guess a password." ;
    solveit-core:techniqueDetails "Dictionary attacks use list compiled common passwords that are likely to be used by people, such as dictionary words, names, common patterns or existing lists of popular or leaked passwords.  Therefore, success depends on the quality and of dictionary list." ;
    solveit-core:techniqueID "DFT-1035" ;
    solveit-core:techniqueName "Attack a stored credential or device using a dictionary-based approach" .

:techniqueDFT-1124 a solveit-core:Technique ;
