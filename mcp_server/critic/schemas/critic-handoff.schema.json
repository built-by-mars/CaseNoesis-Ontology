{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caseontology.org/schemas/critic-handoff.schema.json",
  "title": "CASE/UCO Critic Self-Improvement Handoff Preview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "handoff_kind",
    "session_id",
    "artifact_hashes",
    "operator_id",
    "requires_operator_approval",
    "suggestion_only",
    "selected_findings",
    "handoff_type"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "handoff_kind": { "const": "critic_self_improvement_preview" },
    "session_id": { "type": "string", "minLength": 1 },
    "session_schema_version": { "type": ["string", "null"] },
    "artifact_hashes": { "type": "object" },
    "validation": { "type": ["object", "null"] },
    "operator_id": { "type": "string", "minLength": 1 },
    "operator_rationale": { "type": "string" },
    "requires_operator_approval": { "const": true },
    "suggestion_only": { "const": true },
    "unverified_generalization": { "type": "boolean" },
    "persistent_write": { "type": "boolean" },
    "handoff_type": {
      "enum": [
        "recipe_improvement",
        "routing_gap",
        "new_recipe_candidate",
        "ontology_gap",
        "extension_gap",
        "sdk_bug",
        "case_specific",
        "false_positive",
        "known_limitation",
        "generalizable"
      ]
    },
    "selected_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["finding_id", "handoff_type", "severity", "category"],
        "properties": {
          "finding_id": { "type": "string" },
          "handoff_type": {
            "enum": [
              "recipe_improvement",
              "routing_gap",
              "new_recipe_candidate",
              "ontology_gap",
              "extension_gap",
              "sdk_bug",
              "case_specific",
              "false_positive",
              "known_limitation",
              "generalizable"
            ]
          },
          "severity": { "type": "string" },
          "category": { "type": "string" },
          "rule_id": { "type": ["string", "null"] },
          "evidence_kind": { "type": ["string", "null"] },
          "confidence": { "type": ["number", "null"] },
          "status": { "type": ["string", "null"] },
          "rationale": { "type": "string" },
          "recommended_change": { "type": "string" },
          "related_recipe": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "next_tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "number" },
    "written_at": { "type": "number" },
    "package_sha256": { "type": ["string", "null"] },
    "deployment_profile": { "type": ["string", "null"] },
    "notes": { "type": "string" }
  }
}
