        "https://ontology.unifiedcyberontology.org/uco/location/Location"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1146 ;
    solveit-core:techniqueDescription "The process of assigning location properties to a reconstructed event" ;
    solveit-core:techniqueID "DFT-1087" ;
    solveit-core:techniqueName "Reconstruct the location-based properties of an event" .

:techniqueDFT-1088 a solveit-core:Technique ;
    rdfs:label "DFT-1088: Reconstruct an relations between events properties of events"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Contact"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Message"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/analysis/HypothesisedCommunication"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/analysis/HypothesisedRelationship"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1029 ;
    solveit-core:hasSynonym "Connection-based event reconstruction",
        "Relation-based event reconstruction",
        "Relational analysis" ;
    solveit-core:techniqueDescription "The process of determining the existence and nature of relationships between entities during event reconstruction" ;
    solveit-core:techniqueID "DFT-1088" ;
    solveit-core:techniqueName "Reconstruct an relations between events properties of events" .

:techniqueDFT-1089 a solveit-core:Technique ;
    rdfs:label "DFT-1089: Review source code of software"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Code"^^xsd:anyURI ;
    solveit-core:techniqueDescription "Typically to  understand it's capabilities, the artifacts it produces, or what user actions could be potentially reconstructed" ;
    solveit-core:techniqueDetails "The equivalent of `static analysis` of malware, but applied to software in general." ;
    solveit-core:techniqueID "DFT-1089" ;
    solveit-core:techniqueName "Review source code of software" .

:techniqueDFT-1091 a solveit-core:Technique ;
    rdfs:label "DFT-1091: Tag artifacts"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/ObservableObject"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/analysis/ArtifactClassification"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/core/Annotation"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1155,
        :weaknessDFW-1156 ;
    solveit-core:hasSynonym "Bookmark artifacts",
        "Bookmarking",
        "Tagging" ;
    solveit-core:techniqueDescription "Make a record of selected files or pieces of data so they can be accessed easily, or used for generating automated reports." ;
    solveit-core:techniqueID "DFT-1091" ;
    solveit-core:techniqueName "Tag artifacts" .

:techniqueDFT-1092 a solveit-core:Technique ;
    rdfs:label "DFT-1092: Generate tag-based automated report"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/analysis/ForensicToolTagBasedReport"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1152,
        :weaknessDFW-1153,
        :weaknessDFW-1154 ;
    solveit-core:hasReference :citationDFCite-1008,
        :citationDFCite-1009 ;
    solveit-core:hasSynonym "Produce bookmark-based automated report" ;
    solveit-core:techniqueDescription "Generate a report in PDF, HTML or other format that compiles tagged (or bookmarked) items from a case into a package that can be reviewed." ;
    solveit-core:techniqueID "DFT-1092" ;
    solveit-core:techniqueName "Generate tag-based automated report" .

:techniqueDFT-1093 a solveit-core:Technique ;
    rdfs:label "DFT-1093: Write expert report"@en ;
    solveit-core:hasCASEOutputClass "https://cacontology.projectvic.org/case-management#ExpertReport"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1093" ;
    solveit-core:techniqueName "Write expert report" .

:techniqueDFT-1094 a solveit-core:Technique ;
    rdfs:label "DFT-1094: Disclose investigation material to an authorized legal authority"@en ;
    solveit-core:hasReference :citationDFCite-1154,
        :citationDFCite-1155 ;
    solveit-core:techniqueID "DFT-1094" ;
    solveit-core:techniqueName "Disclose investigation material to an authorized legal authority" .

:techniqueDFT-1095 a solveit-core:Technique ;
    rdfs:label "DFT-1095: Instrument a piece of running software"@en ;
    solveit-core:hasExample "Fiddler",
        "Frida",
        "IDA Pro" ;
    solveit-core:hasReference :citationDFCite-1156 ;
    solveit-core:techniqueDescription "This can be done during experiments to help ascertain functionality, or potential forensic artifacts" ;
    solveit-core:techniqueID "DFT-1095" ;
    solveit-core:techniqueName "Instrument a piece of running software" .

:techniqueDFT-1096 a solveit-core:Technique ;
    rdfs:label "DFT-1096: Extract operating system artifacts indicating program execution"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/execProgramHashes"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/execProgramPath"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/timesExecuted"^^xsd:anyURI ;
    solveit-core:hasSynonym "Programs run identification (OS)" ;
    solveit-core:techniqueDescription "The process of examining operating system files to extract artifacts that may indicate a program has been run." ;
    solveit-core:techniqueDetails "While this technique may result in paths to executables/scripts and timestamps, to evaluate a hypothesis that a program was run requires use of T1155 to evaluate if this occurred, and optionally T1117 if the time of access is relevant." ;
    solveit-core:techniqueID "DFT-1096" ;
    solveit-core:techniqueName "Extract operating system artifacts indicating program execution" .

:techniqueDFT-1097 a solveit-core:Technique ;
    rdfs:label "DFT-1097: Extract operating system artifacts indicating installed software"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Application"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/ApplicationVersion"^^xsd:anyURI ;
    solveit-core:hasSynonym "Installed software identification (OS)" ;
    solveit-core:techniqueDescription "Extraction and analysis of information that allows programs installed on an OS to be identified." ;
    solveit-core:techniqueID "DFT-1097" ;
    solveit-core:techniqueName "Extract operating system artifacts indicating installed software" .

:techniqueDFT-1098 a solveit-core:Technique ;
    rdfs:label "DFT-1098: Enumerate operating system user accounts"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/UserAccount"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/accountType"^^xsd:anyURI ;
    solveit-core:hasExample "Windows SAM file" ;
    solveit-core:hasSynonym "User account analysis (OS)" ;
    solveit-core:techniqueDescription "Examination of operating system artifacts to determine user accounts" ;
    solveit-core:techniqueDetails "This might include which accounts exist on the system, when they were created, etc." ;
    solveit-core:techniqueID "DFT-1098" ;
    solveit-core:techniqueName "Enumerate operating system user accounts" .

:techniqueDFT-1100 a solveit-core:Technique ;
    rdfs:label "DFT-1100: Extract metadata from within images"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/RasterPicture"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/exifData"^^xsd:anyURI ;
    solveit-core:hasSynonym "EXIF extraction" ;
    solveit-core:techniqueDescription "The extraction of metadata from within images (pictures). e.g. EXIF, XMP. IPTC, iTXt etc." ;
    solveit-core:techniqueID "DFT-1100" ;
    solveit-core:techniqueName "Extract metadata from within images" .

:techniqueDFT-1101 a solveit-core:Technique ;
    rdfs:label "DFT-1101: Conduct cell site survey"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/location/Location"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1067,
        :citationDFCite-1121 ;
    solveit-core:techniqueDescription "Taking measurements to assess which cells actually provide service at a specific location (adapted from Tart et al 2012)." ;
    solveit-core:techniqueDetails "Can involve: spot sample, location survey, area survey, cell survey (Tart et al 2012)" ;
    solveit-core:techniqueID "DFT-1101" ;
    solveit-core:techniqueName "Conduct cell site survey" .

:techniqueDFT-1102 a solveit-core:Technique ;
    rdfs:label "DFT-1102: Decode data extracted from unmanaged NAND"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/ContentData"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1102" ;
    solveit-core:techniqueName "Decode data extracted from unmanaged NAND" .

:techniqueDFT-1103 a solveit-core:Technique ;
    rdfs:label "DFT-1103: Virtualize suspect system for previewing"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/PhysicalImageContainer"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/RawImage"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/VirtualizedComputer"^^xsd:anyURI ;
    solveit-core:techniqueDescription "A suspect disk image can be configured to boot as a virtual machine, which allows screenshots to be taken showing how the user's desktop looked for example." ;
    solveit-core:techniqueID "DFT-1103" ;
    solveit-core:techniqueName "Virtualize suspect system for previewing" .

:techniqueDFT-1104 a solveit-core:Technique ;
    rdfs:label "DFT-1104: Collect data using open source intelligence"@en ;
    solveit-core:techniqueID "DFT-1104" ;
    solveit-core:techniqueName "Collect data using open source intelligence" .

:techniqueDFT-1106 a solveit-core:Technique ;
    rdfs:label "DFT-1106: Classify if a video is potentially synthetically generated"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/VideoFile"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/analysis/ArtifactClassification"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/analysis/classificationConfidence"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1106" ;
    solveit-core:techniqueName "Classify if a video is potentially synthetically generated" .

:techniqueDFT-1107 a solveit-core:Technique ;
    rdfs:label "DFT-1107: Extract artifacts from health/fitness app(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/HealthAppFiles"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1107" ;
    solveit-core:techniqueName "Extract artifacts from health/fitness app(s)" .

:techniqueDFT-1108 a solveit-core:Technique ;
    rdfs:label "DFT-1108: Extract artifacts from reminders app(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/RemindersAppFiles"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1108" ;
    solveit-core:techniqueName "Extract artifacts from reminders app(s)" .

:techniqueDFT-1109 a solveit-core:Technique ;
    rdfs:label "DFT-1109: Extract artifacts from payment app(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/PaymentAppFiles"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1109" ;
    solveit-core:techniqueName "Extract artifacts from payment app(s)" .

:techniqueDFT-1112 a solveit-core:Technique ;
    rdfs:label "DFT-1112: Locate and remove physical disks from a device"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Computer"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/StorageMedium"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1174,
        :weaknessDFW-1175,
        :weaknessDFW-1176 ;
    solveit-core:techniqueDescription "Locate physical storage media within devices and removing them" ;
    solveit-core:techniqueID "DFT-1112" ;
    solveit-core:techniqueName "Locate and remove physical disks from a device" .

:techniqueDFT-1114 a solveit-core:Technique ;
    rdfs:label "DFT-1114: Preserve memory contents via Cold Boot Attack"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Memory"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1032 ;
    solveit-core:hasReference :citationDFCite-1053 ;
    solveit-core:hasSynonym "Cold Boot Attack",
        "Extracting RAM data using Cold Boot Attack" ;
    solveit-core:techniqueDescription "A precursor to extracting volatile memory (RAM) from a powered-off system by quickly rebooting or transferring the memory module to another system before residual data fades. Cooling the memory modules can significantly slow down data decay, preserving critical data such as encryption keys or passwords." ;
    solveit-core:techniqueDetails "An examiner freezes a computer’s RAM by spraying it with liquid nitrogen or even using inverted canned air, then powering off the live system without proper shutdown, and then booting into an external plugged USB, and try capturing the residual RAM content (DFT-1003) with encryption keys that might still be stored there" ;
    solveit-core:techniqueID "DFT-1114" ;
    solveit-core:techniqueName "Preserve memory contents via Cold Boot Attack" .

:techniqueDFT-1115 a solveit-core:Technique ;
    rdfs:label "DFT-1115: Visualize geolocation information"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/location/Location"^^xsd:anyURI ;
    solveit-core:hasExample "Autopsy Geolocation view (Basis Technology 2020)",
        "Magnet Axiom 'World map view' (Magnet 2020)" ;
    solveit-core:hasReference :citationDFCite-1010,
        :citationDFCite-1092,
        :citationDFCite-1093 ;
    solveit-core:techniqueDescription "Presenting points or paths visually using extracted data, typically on a map" ;
    solveit-core:techniqueID "DFT-1115" ;
    solveit-core:techniqueName "Visualize geolocation information" .

:techniqueDFT-1116 a solveit-core:Technique ;
    rdfs:label "DFT-1116: Extract references to connected devices"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasExample "ADB connected hosts",
        "Paired bluetooth devices",
        "Synronization artifacts referencing another device",
        "USB connected devices",
        "iOS backups from a computer" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1011,
        :weaknessDFW-1183,
        :weaknessDFW-1184 ;
    solveit-core:hasReference :citationDFCite-1001,
        :citationDFCite-1057 ;
    solveit-core:techniqueDescription "Examine artifacts and extract indicators of devices that have been connected to the target device." ;
    solveit-core:techniqueDetails "This technique extracts references to other devices that have potentially been connected to the device being examined. The subsequent interpretation of these artifacts (using T1088: Relational-based event reconstruction), could result in HypothesisedDevices. The separate process for inferring the connected device(s) captures the uncertainty in such an interpretation." ;
    solveit-core:techniqueID "DFT-1116" ;
    solveit-core:techniqueName "Extract references to connected devices" .

:techniqueDFT-1117 a solveit-core:Technique ;
    rdfs:label "DFT-1117: Reconstruct the time that an event may have occurred"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/analysis/hypothesisedDateTime"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1148,
        :weaknessDFW-1149,
        :weaknessDFW-1266 ;
    solveit-core:hasSynonym "Temporal-based event reconstruction" ;
    solveit-core:techniqueDescription "The process of assigning a time component to a reconstructed event" ;
    solveit-core:techniqueID "DFT-1117" ;
    solveit-core:techniqueName "Reconstruct the time that an event may have occurred" .

:techniqueDFT-1118 a solveit-core:Technique ;
    rdfs:label "DFT-1118: Locate relevant files by path"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FilteredFileSet"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI ;
    solveit-core:hasExample "Autopsy Interesting Files module",
        "Pattern matching in ALEAPP/iLEAPP to trigger specific plugins" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1186,
        :weaknessDFW-1187,
        :weaknessDFW-1188 ;
    solveit-core:hasReference :citationDFCite-1006 ;
    solveit-core:hasSynonym "Filename matching" ;
    solveit-core:techniqueDescription "Use the path of file name to determine potential relevance of the file." ;
    solveit-core:techniqueDetails "There are multiple applications of this, for example: within a tool to determine what processing should occur to a file, or flagging files with particular extensions." ;
    solveit-core:techniqueID "DFT-1118" ;
    solveit-core:techniqueName "Locate relevant files by path" .

:techniqueDFT-1120 a solveit-core:Technique ;
    rdfs:label "DFT-1120: Extract artifacts from app data automatically"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ApplicationFiles"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI ;
    solveit-core:hasExample "Axiom",
        "Hansken",
        "aLEAPP",
        "iLEAPP" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1189,
        :weaknessDFW-1190,
        :weaknessDFW-1258 ;
    solveit-core:hasSynonym "Automated trace extraction" ;
    solveit-core:techniqueDescription "The use of automation to extract pieces of data that are potentially useful for a digital forensic investigation from app data." ;
    solveit-core:techniqueDetails "Artifacts extracted may be a direct mapping to lower levels of abstraction e.g. a database field 'message content' may map to an artifact 'message content', but in many cases, automated interpretation is applied where a field such as 'flag' containing numeric values, may be mapped to more meaningful text strings in the extracted artifact." ;
    solveit-core:techniqueID "DFT-1120" ;
    solveit-core:techniqueName "Extract artifacts from app data automatically" .

:techniqueDFT-1121 a solveit-core:Technique ;
    rdfs:label "DFT-1121: Index a data source for keyword searching"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/KeywordIndexingConfiguration"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/KeywordIndex"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1054,
        :weaknessDFW-1055,
        :weaknessDFW-1056,
        :weaknessDFW-1197,
        :weaknessDFW-1198 ;
    solveit-core:hasSynonym "keyword indexing" ;
    solveit-core:techniqueDescription "Extracting strings from a data source and adding them to an index for subsequent searching." ;
    solveit-core:techniqueDetails "An index can be constructed over a set of files (including non-allocated space represented as files), a set of extracted artifacts, or both." ;
    solveit-core:techniqueID "DFT-1121" ;
    solveit-core:techniqueName "Index a data source for keyword searching" .

:techniqueDFT-1122 a solveit-core:Technique ;
    rdfs:label "DFT-1122: Keyword search (case-type wordlists)"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/KeywordSearchResult"^^xsd:anyURI ;
    solveit-core:hasExample "Example word lists https://www.dfir.training/downloads/search-terms" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1057,
        :weaknessDFW-1059 ;
    solveit-core:hasReference :citationDFCite-1074 ;
    solveit-core:techniqueDescription "Searching for case-type specific keywords" ;
    solveit-core:techniqueDetails "This complements case-specific wordlists (T1123) created for the individual case." ;
    solveit-core:techniqueID "DFT-1122" ;
    solveit-core:techniqueName "Keyword search (case-type wordlists)" .

:techniqueDFT-1123 a solveit-core:Technique ;
    rdfs:label "DFT-1123: Keyword search (case-specific wordlists)"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/KeywordSearchResult"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1192,
        :weaknessDFW-1199 ;
    solveit-core:techniqueDescription "Searching for case-specific keywords, e.g. people's names, places etc." ;
    solveit-core:techniqueDetails "This complements case-type wordlists (T1122) using words typical to specific offenses." ;
    solveit-core:techniqueID "DFT-1123" ;
    solveit-core:techniqueName "Keyword search (case-specific wordlists)" .

:techniqueDFT-1126 a solveit-core:Technique ;
    rdfs:label "DFT-1126: Keyword search (live) (physical)"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/KeywordSearchResult"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1193,
        :weaknessDFW-1194,
        :weaknessDFW-1195 ;
    solveit-core:hasReference :citationDFCite-1103,
        :citationDFCite-1134 ;
    solveit-core:hasSynonym "live search" ;
    solveit-core:techniqueDescription "Searching for keywords over the raw data on a sector by sector basis" ;
    solveit-core:techniqueID "DFT-1126" ;
    solveit-core:techniqueName "Keyword search (live) (physical)" .

:techniqueDFT-1128 a solveit-core:Technique ;
    rdfs:label "DFT-1128: Search for indicators of malware"@en ;
    solveit-core:hasSynonym "malware scan",
        "virus scan" ;
    solveit-core:techniqueDescription "Searching for the presence of current or historical malware on a system" ;
    solveit-core:techniqueDetails "This can involve searching for malware itself or other indicators e.g. persistence mechanisms, delivery method etc." ;
    solveit-core:techniqueID "DFT-1128" ;
    solveit-core:techniqueName "Search for indicators of malware" .

:techniqueDFT-1130 a solveit-core:Technique ;
    rdfs:label "DFT-1130: Search for indicators of encrypted data"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Application"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI ;
    solveit-core:techniqueDescription "Searching for the presence of current or historical encrypted data on a system" ;
    solveit-core:techniqueDetails "This can include encryption software itself, or encrypted files." ;
    solveit-core:techniqueID "DFT-1130" ;
    solveit-core:techniqueName "Search for indicators of encrypted data" .

:techniqueDFT-1131 a solveit-core:Technique ;
    rdfs:label "DFT-1131: Search for indicators of trail obfuscation"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Application"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1082 ;
    solveit-core:techniqueDescription "Searching for the presence of current or historical trail obfuscation on a system" ;
    solveit-core:techniqueID "DFT-1131" ;
    solveit-core:techniqueName "Search for indicators of trail obfuscation" .

:techniqueDFT-1132 a solveit-core:Technique ;
    rdfs:label "DFT-1132: Search for indicators of artifact wiping"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Application"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1082 ;
