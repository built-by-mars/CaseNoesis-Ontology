      "uco-core:name": "Fargo, North Dakota",
      "uco-core:description": "City from which Victim A was taken at gunpoint on the night of 2024-03-05."
    },
    {
      "@id": "urn:uuid:d070be5e-e12f-5035-9164-ddd43b57858e",
      "@type": "uco-location:Location",
      "uco-core:name": "Altenor residence, Moorhead, Minnesota",
      "uco-core:description": "Residence of co-defendant Frankwoodson Altenor where Victim A was held for ransom and from which he escaped during daytime 2024-03-06."
    },
    {
      "@id": "urn:uuid:4e9db03d-f340-585e-8c89-ddb56e1a183f",
      "@type": "uco-location:Location",
      "uco-core:name": "17th Avenue South and 25th Street South, Fargo, North Dakota",
      "uco-core:description": "Area where Maez-Schaack crashed a stolen vehicle on 2024-04-06 while attempting to evade Fargo police, fleeing on foot and leaving behind the SIG Sauer P365 pistol and a backpack containing a loaded magazine."
    },
    {
      "@id": "urn:uuid:43d20fbf-ca03-522c-a2fe-d63da89ef6a6",
      "@type": "uco-location:Location",
      "uco-core:name": "Red River Valley and Devils Lake area, North Dakota",
      "uco-core:description": "Primary distribution territory of the Lindell drug trafficking organization."
    },
    {
      "@id": "urn:uuid:5c697212-761c-5b1a-9c46-2ebff57cf47f",
      "@type": "uco-location:Location",
      "uco-core:name": "Twin Cities, Minnesota",
      "uco-core:description": "Frequent source area for the organization's methamphetamine."
    },
    {
      "@id": "urn:uuid:2478b7f6-3fe8-5967-8c51-6b49b9e1f1c9",
      "@type": "weap:Handgun",
      "uco-core:name": "SIG Sauer P365 9mm pistol (Serial Number 66F717834)",
      "uco-core:description": "Black SIG Sauer P365 pistol. Charged as possessed by Maez-Schaack on or about 2024-04-02 in furtherance of the drug conspiracy (Count 5) and as a felon in possession (Count 6); per the plea factual basis, left behind in the vicinity of a stolen vehicle Maez-Schaack crashed on 2024-04-06 while evading Fargo police (the on-or-about charge date and the narrative date are kept verbatim from each document). Source: PACER Doc 66 (indictment2), Counts 5-6; Source: PACER Doc 101 (plea), para. 6 factual basis",
      "weap:make": "SIG Sauer",
      "weap:model": "P365",
      "weap:caliber": "9mm",
      "weap:serialNumber": "66F717834"
    },
    {
      "@id": "urn:uuid:87921b5a-9769-558d-bbcd-5c035d3736c0",
      "@type": "weap:Ammunition",
      "uco-core:name": "Seventeen 9mm rounds in a black magazine",
      "uco-core:description": "Black magazine containing seventeen 9mm rounds, found in a backpack Maez-Schaack left near the crashed stolen vehicle on 2024-04-06. Source: PACER Doc 101 (plea), para. 6 factual basis",
      "weap:caliber": "9mm"
    },
    {
      "@id": "urn:uuid:b19e4f7a-511e-57f9-bdf6-5380072d053f",
      "@type": [
        "uco-core:UcoObject",
        "gufo:FunctionalComplex"
      ],
      "uco-core:name": "Ford F-250 automobile (Victim A's vehicle)",
      "uco-core:description": "Victim A's vehicle, moving in interstate commerce, taken from his person and presence by actual and threatened force during the kidnapping and kept by Maez-Schaack and his co-conspirators afterward; the property underlying the Hobbs Act robbery charge (Count 3). Source: PACER Doc 66 (indictment2), Count 3; Source: PACER Doc 101 (plea), para. 6 factual basis"
    },
    {
      "@id": "urn:uuid:5d80c942-8df6-5534-93f3-03727991b4c9",
      "@type": [
        "uco-core:UcoObject",
        "gufo:FunctionalComplex"
      ],
      "uco-core:name": "Stolen vehicle crashed in Fargo on 2024-04-06",
      "uco-core:description": "Stolen vehicle Maez-Schaack crashed in the area of 17th Avenue South and 25th Street South, Fargo, while attempting to evade Fargo police, then fled on foot. Source: PACER Doc 101 (plea), para. 6 factual basis"
    },
    {
      "@id": "urn:uuid:ae72e0c7-2113-50b0-878c-cace1d2333c6",
