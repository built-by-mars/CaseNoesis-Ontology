    solveit-core:hasReference :citationDFCite-1103,
        :citationDFCite-1133,
        :citationDFCite-1134 ;
    solveit-core:hasSynonym "live search" ;
    solveit-core:techniqueDescription "Searching for keywords over the raw data in a case without using an index of text content" ;
    solveit-core:techniqueDetails "This may be done on a physical sector basis, or on a logical (file) basis." ;
    solveit-core:techniqueID "DFT-1125" ;
    solveit-core:techniqueName "Keyword search (live)" .

