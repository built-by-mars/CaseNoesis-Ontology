          "@id": "urn:uuid:dbb4c13b-d3ae-5130-be08-4eaf488c4e67"
        }
      ],
      "uco-core:kindOfRelationship": "part_of",
      "uco-core:isDirectional": {
        "@type": "xsd:boolean",
        "@value": "true"
      }
    },
    {
      "@id": "urn:uuid:d216fac7-4f8e-5b1f-b3b6-92533d32e445",
      "@type": [
        "uco-observable:ObservableObject",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Lichtenstein cloud storage account",
      "uco-core:description": "Cloud storage account (Lichtenstein Email 2 provider) obtained by search warrant in 2021; significant portions encrypted. On 2022-01-31 law enforcement decrypted key files, including a file listing all 2,000 Wallet 1CGA4s addresses with private keys, an exchange-account spreadsheet with 'FROZEN' notations, a 'personas' folder of false identity documents, a 'passport_ideas' darknet vendor list, and financial-institution laundering reconnaissance notes. Source: PACER Doc 1-1 (statement_of_facts), paras. 51-55"
    },
    {
      "@id": "urn:uuid:5ca207fb-c5b0-528e-9aa1-da0fb6fb0aa2",
