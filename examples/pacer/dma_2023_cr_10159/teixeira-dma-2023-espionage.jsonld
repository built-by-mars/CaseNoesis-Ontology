    {
      "@id": "urn:uuid:2e0b52c3-8286-5097-b075-f624ead0a6a4",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Teixeira granted TOP SECRET//SCI clearance (July 2021)",
      "uco-core:description": "Since in or around July 2021 Teixeira held a TOP SECRET//SCI security clearance as required for his USANG position. Source: PACER Doc 48 (indictment), para. 7",
      "uco-action:performer": {
        "@id": "urn:uuid:0670870d-7a95-53c1-b215-d7357fabe240"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2021-07-01T00:00:00-04:00"
      }
    },
    {
      "@id": "urn:uuid:1aa333da-84ae-533f-a935-f78d8827b110",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Teixeira signs SCI indoctrination memoranda (July 2021)",
      "uco-core:description": "Signed acknowledgment: 'I have been advised that the unauthorized disclosure, unauthorized retention, or negligent handling of SCI by me could cause irreparable injury to the U.S. or be used to advantage by a foreign nation. I hereby agree that I will never divulge anything marked as SCI or that I know to be SCI to anyone who is not authorized to receive it.' Source: PACER Doc 144 (sentencing_memorandum), p. 6",
      "uco-action:performer": {
        "@id": "urn:uuid:b413b5a1-8666-5b5c-aca9-a86696327cc4"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2021-07-01T00:00:00-04:00"
      }
    },
    {
      "@id": "urn:uuid:bb7a0767-5ebc-5f81-b907-b650e954e879",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Unauthorized-disclosure refresher training (March 2022)",
      "uco-core:description": "Refresher course on the 'Unauthorized Disclosure of Classified Information and Controlled Unclassified Information' completed just after Teixeira began disclosing classified information on Discord (certificate: Doc 143-3; student guide: Doc 143-4). Source: PACER Doc 144 (sentencing_memorandum), p. 6",
      "uco-action:performer": {
        "@id": "urn:uuid:b413b5a1-8666-5b5c-aca9-a86696327cc4"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-03-01T00:00:00-05:00"
      }
    },
    {
      "@id": "urn:uuid:aba11235-d592-5a5d-813e-13d59eef4f52",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Superiors admonish Teixeira three times to cease viewing classified information",
      "uco-core:description": "Teixeira 'was admonished on three separate occasions by his superiors to cease and desist viewing classified information unrelated to his duties.' He was undeterred. Source: PACER Doc 144 (sentencing_memorandum), p. 12",
      "uco-action:performer": {
        "@id": "urn:uuid:f2c22909-34ea-5400-a1a9-0c06b3055bed"
      }
    },
    {
      "@id": "urn:uuid:9d22e2ff-fa79-5136-9fdf-3ec285e66a88",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Teixeira transcribes classified text from a classified workstation into Discord messages (Jan 2022 - Apr 2023)",
      "uco-core:description": "First transmission method: Teixeira accessed classified documents containing NDI from a classified workstation at Otis USANG Base, manually transcribed portions, removed the transcriptions from the SCIF without authorization, and, using the messaging function on the Social Media Platform, input and transmitted the text to users not entitled to receive it. Grounds Counts One and Two. Source: PACER Doc 48 (indictment), paras. 10-11",
      "uco-action:performer": {
        "@id": "urn:uuid:b413b5a1-8666-5b5c-aca9-a86696327cc4"
      },
      "uco-action:instrument": [
        {
          "@id": "urn:uuid:36c1a112-497c-50f0-8e0f-f00662ee9bff"
        },
        {
          "@id": "urn:uuid:43c4ca20-3a67-5f79-a1a8-807eee0810e2"
        }
      ],
