      "@id": "urn:uuid:89135312-a28e-570f-906d-8c4b350712ad",
      "@type": [
        "case-investigation:InvestigativeAction",
        "uco-action:Action"
      ],
      "uco-core:name": "Arrest Jeandiel Serrano in Los Angeles, California",
      "uco-core:description": "Serrano was arrested in Los Angeles, California on 2024-09-18 on an arrest warrant dated 2024-09-17, returned executed the same day. Source: PACER Doc docket sheet (docket), entry 7; arrest entries",
      "uco-action:performer": {
        "@id": "urn:uuid:04f62c49-3693-5552-b6c7-03ad418ce827"
      },
      "uco-action:object": [
