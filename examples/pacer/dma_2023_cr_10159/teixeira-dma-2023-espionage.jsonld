    {
      "@id": "urn:uuid:a30f7731-469c-5ea6-a53e-80162de17a3a",
      "@type": [
        "uco-observable:ObservableObject",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count Four NDI (TOP SECRET//SCI): A Government Document discussing a plot by a foreign adversa...",
      "uco-core:description": "A Government Document discussing a plot by a foreign adversary to target United States forces abroad and which discusses, in part, where and how the attack on United States forces would occur. Retained and transmitted March 2023 to April 2023. Classified Government Document printed in the SCIF, removed, photographed, and posted to Discord. Source: PACER Doc 48 (indictment), paras. 16, 18 (count charts)",
      "uco-core:objectMarking": [
        {
          "@id": "urn:uuid:86e4c715-0835-5de7-9dfa-baad4bda5482"
        }
      ]
    },
