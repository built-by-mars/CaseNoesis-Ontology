      ],
      "uco-core:name": "Superseding Indictment (Doc 44)",
      "uco-core:description": "Restructured the case to seven counts of theft of trade secrets (18 U.S.C. \u00a7 1832) and seven counts of economic espionage (18 U.S.C. \u00a7 1831), one pair per Trade Secret Category One through Seven, spanning 2022-05-21 to 2024-01-13. Source: PACER Doc 44 (superseding_indictment), caption and counts",
      "legalproc:instrumentType": "superseding-indictment",
      "uco-core:objectCreatedTime": {
        "@type": "xsd:dateTime",
