      "@id": "urn:uuid:c7e5c292-40a2-5c20-b0fc-922097b452af",
      "@type": "uco-observable:ObservableObject",
      "uco-core:name": "Sagerunex Beta version",
      "uco-core:description": "Beta variant with verbose debug strings (e.g. 'Online Fail! Wait for %d mins'); gathers hostname, MAC, and IP, queries public IP via api.ipaddress[.]com, encrypts and sends to a traditional VPS C2. Commands: host status, update config, cmd shell, read file, create file. Active ~2016-2021 (Talos timeline).",
      "uco-core:hasFacet": [
        {
          "@id": "urn:uuid:6b9bf93f-2900-5e5b-bff0-d4c401ea14f0",
