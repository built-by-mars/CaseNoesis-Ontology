sh-org:reportsTo-subjects-reportsTo-shape
	a sh:PropertyShape ;
	sh:or (
		[
			a sh:NodeShape ;
			sh:class foaf:Agent ;
		]
		[
			a sh:NodeShape ;
			sh:class org:Post ;
		]
	) ;
	sh:path org:reportsTo ;
	.

sh-org:reportsTo-subjects-shape
	a sh:NodeShape ;
	sh:or (
		[
			a sh:NodeShape ;
			sh:class foaf:Agent ;
		]
		[
			a sh:NodeShape ;
			sh:class org:Post ;
		]
	) ;
	sh:property sh-org:reportsTo-subjects-reportsTo-shape ;
	sh:targetSubjectsOf org:reportsTo ;
	.

