sh-org:originalOrganization-subjects-originalOrganization-shape
	a sh:PropertyShape ;
	sh:class org:Organization ;
	sh:path org:originalOrganization ;
	.

sh-org:originalOrganization-subjects-shape
	a sh:NodeShape ;
	rdfs:seeAlso sh-prov:used-subjects-shape ;
