      "@type": [
        "rico:EnterpriseRole",
        "uco-role:Role"
      ],
      "uco-core:name": "SE Enterprise role: target identifier",
      "uco-core:description": "Target identifiers were responsible (with organizers) for organizing and collating information across various databases to determine the most valuable targets. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), paras. 25-26, 16, 32",
      "rico:roleFunction": "target-identifier"
    },
