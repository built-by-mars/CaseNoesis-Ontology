        }
      ],
      "uco-core:kindOfRelationship": "Role_Within",
      "uco-core:isDirectional": {
        "@type": "xsd:boolean",
        "@value": "true"
      }
    },
    {
      "@id": "urn:uuid:898b046b-dc1c-55a3-bd0d-72da79568e95",
      "@type": [
        "rico:EnterpriseRole",
        "uco-role:Role"
      ],
      "uco-core:name": "SE Enterprise role: organizer",
      "uco-core:description": "Organizers were responsible (with target identifiers) for organizing and collating information across various databases to determine the most valuable targets. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), paras. 25-26, 16, 32",
      "rico:roleFunction": "organizer"
    },
