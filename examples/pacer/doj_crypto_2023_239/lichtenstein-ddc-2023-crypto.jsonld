    {
      "@id": "urn:uuid:2dd697e4-38ba-5d50-bd81-b9fd7a0c3331",
      "@type": [
        "cryptoinv:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 3: Conspiracy To Defraud the United States",
      "uco-core:description": "Morgan conspired with Lichtenstein to defraud the United States by deceiving VCEs and financial institutions to frustrate AML/KYC due diligence and prevent transmission of Bank Secrecy Act Suspicious Activity Reports to FinCEN. Source: PACER Doc 89 (information), Count Three",
      "cryptoinv:statuteCitation": "18 U.S.C. \u00a7 371",
      "cryptoinv:countNumber": {
        "@type": "xsd:nonNegativeInteger",
