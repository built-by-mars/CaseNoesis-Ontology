    {
      "@id": "urn:uuid:ce504e5a-0b8a-5531-b6b7-5fd0b66da962",
      "@type": "uco-action:Action",
      "uco-core:name": "Keep Victim A's Ford F-250 after the kidnapping",
      "uco-core:description": "Maez-Schaack and his co-conspirators kept Victim A's vehicle after the kidnapping \u2014 the taking underlying the Hobbs Act robbery charge (Count 3). Source: PACER Doc 101 (plea), para. 6 factual basis; Source: PACER Doc 66 (indictment2), Count 3",
      "uco-action:performer": {
        "@id": "urn:uuid:6820f49e-6abe-5bc2-a10c-31b9e922374b"
