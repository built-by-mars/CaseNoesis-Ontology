      ],
      "uco-core:name": "Count Ten: Economic Espionage (Trade Secret Category 3)",
      "uco-core:description": "On or about and between 2022-05-21 and 2024-01-13, in the Northern District of California and elsewhere, Ding, intending or knowing that the offense would benefit a foreign government, foreign instrumentality, or foreign agent, knowingly stole, copied, transmitted, and possessed without authorization Trade Secret Category 3: Design documents for Google's TPU software that managed the hardware and resources within a TPU, facilitated communication between TPUs, and allocated and managed collections of interconnected TPUs to different workloads. Source: PACER Doc 140 (second_superseding_indictment), counts table",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 1831(a)(1), (2), and (3)",
      "legalproc:countLabel": "Count Ten",
