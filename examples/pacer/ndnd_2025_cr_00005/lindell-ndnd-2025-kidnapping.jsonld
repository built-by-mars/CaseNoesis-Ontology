    {
      "@id": "urn:uuid:ed83f702-130e-5803-83f9-aac0f27827ed",
      "@type": "uco-identity:Person",
      "uco-core:name": "Jordan Arlo Lindell",
      "uco-core:description": "Defendant 1. Led a drug trafficking organization that primarily distributed methamphetamine in the Red River Valley and Devils Lake area of North Dakota, often obtaining it from Minnesota's Twin Cities. Ordered the kidnapping of Victim A to collect a $6,000 drug debt. The grand jury found two prior final North Dakota serious-drug-felony convictions (09-2014-CR-149, judgment 2015-01-12; 09-2019-CR-3820, judgment 2020-07-01). Source: PACER Doc 66 (indictment2), caption; prior convictions; overt acts; Source: PACER Doc 101 (plea), para. 6 factual basis"
    },
    {
      "@id": "urn:uuid:6820f49e-6abe-5bc2-a10c-31b9e922374b",
      "@type": "uco-identity:Person",
      "uco-core:name": "Kyle Kahalehili Maez-Schaack",
      "uco-core:description": "Defendant 2 (USM 70239-511). One of the drug distributors for Lindell and UC-1; often used as the muscle of the group and adept at stealing cars. Kidnapped Victim A at gunpoint at Lindell's direction, pleaded guilty to Counts 1, 2, 4, and 6, and was sentenced to 360 months. Source: PACER Doc 101 (plea), para. 6 factual basis; Source: PACER Doc 128 (judgment), Sheet 1"
    },
    {
      "@id": "urn:uuid:cdd26ed6-6c77-5e1d-b30c-d33188e74470",
      "@type": "uco-identity:Person",
      "uco-core:name": "Frankwoodson Altenor",
      "uco-core:description": "Defendant, a/k/a 'SON SON'. Obtained methamphetamine from Lindell and Maez-Schaack and often distributed smaller amounts to his associates; Victim A was held for ransom at his residence in Moorhead, Minnesota. Source: PACER Doc 66 (indictment2), caption; Source: PACER Doc 101 (plea), para. 6 factual basis"
    },
    {
      "@id": "urn:uuid:1c77f1ce-bfa2-5316-8a5e-a63f64020d1d",
      "@type": "uco-identity:Person",
      "uco-core:name": "Drew David Lauinger",
      "uco-core:description": "Defendant, charged in Count 1 (kidnapping) of the Second Superseding Indictment. Source: PACER Doc 66 (indictment2), caption; Count 1"
    },
    {
      "@id": "urn:uuid:92e71de5-24e2-5f4b-bb92-c6d89014cd23",
      "@type": "uco-identity:Person",
      "uco-core:name": "UC-1 (unindicted co-conspirator)",
      "uco-core:description": "As-yet unindicted co-conspirator who, with Lindell, was owed the $6,000 methamphetamine debt and ordered the kidnapping of Victim A. Source: PACER Doc 101 (plea), para. 6 factual basis"
    },
    {
      "@id": "urn:uuid:57f315e6-8aae-5d13-b370-46aecc23eeb0",
      "@type": "uco-identity:Person",
      "uco-core:name": "Victim A",
      "uco-core:description": "Kidnapping victim, identified only as Victim A. Owed Lindell and UC-1 $6,000 for 500 grams or more of methamphetamine; taken at gunpoint from Fargo, beaten, held for ransom in Moorhead, Minnesota, and escaped during daytime March 6, 2024 after being left unattended. Source: PACER Doc 66 (indictment2), Count 1; overt acts 3-5; Source: PACER Doc 101 (plea), para. 6 factual basis"
    },
    {
      "@id": "urn:uuid:4a974837-6823-5877-a065-3769f2551924",
      "@type": "uco-identity:Person",
      "uco-core:name": "Brandon Mattern",
      "uco-core:description": "Person the defendant must not communicate or interact with under special condition 1 of supervised release; role in the offense not stated in the reviewed documents. Source: PACER Doc 128 (judgment), Sheet 3D special condition 1"
    },
    {
      "@id": "urn:uuid:d5113cc7-2406-55b4-9087-9980ace2ef8c",
      "@type": "uco-identity:Person",
      "uco-core:name": "Peter D. Welte",
      "uco-core:description": "Chief District Judge, District of North Dakota; imposed judgment on 2026-06-01. Source: PACER Doc 128 (judgment), Sheet 1"
    },
    {
      "@id": "urn:uuid:5dcbb73f-e523-5eb8-8480-10f86454c3b7",
      "@type": "uco-identity:Person",
      "uco-core:name": "Brian P. Toay",
      "uco-core:description": "Defense counsel for Maez-Schaack. Source: PACER Doc 101 (plea), preamble; Source: PACER Doc 128 (judgment), Sheet 1"
    },
    {
      "@id": "urn:uuid:7e73cca3-ea2d-5893-83d3-6752bd71a042",
      "@type": "uco-identity:Organization",
      "uco-core:name": "U.S. Attorney's Office, District of North Dakota",
      "uco-core:description": "Prosecuting office. Second Superseding Indictment signed by Acting U.S. Attorney Jennifer Klemetsrud Puhl; Plea Agreement executed by U.S. Attorney Nicholas W. Chase and AUSA Jacob T. Rodenbiker. Source: PACER Doc 66 (indictment2), signature block; Source: PACER Doc 101 (plea), preamble and signature block"
    },
    {
      "@id": "urn:uuid:c1fc0ea3-6a55-553f-be87-71421985e79f",
      "@type": "uco-identity:Organization",
      "uco-core:name": "DOJ Violent Crime and Racketeering Section",
      "uco-core:description": "Department of Justice section joining the prosecution: Chief David L. Jaffe and Trial Attorney Shriram Harid. Source: PACER Doc 101 (plea), preamble and signature block"
    },
    {
      "@id": "urn:uuid:77d35432-7a79-5f8e-abc9-93c52ad2a3c2",
      "@type": "uco-identity:Organization",
      "uco-core:name": "Fargo Police Department",
      "uco-core:description": "Police department Maez-Schaack attempted to evade on 2024-04-06 before crashing a stolen vehicle and abandoning the SIG Sauer P365. Source: PACER Doc 101 (plea), para. 6 factual basis"
    },
    {
      "@id": "urn:uuid:76b415a0-05e5-5240-bb0e-9033b92dd063",
      "@type": "uco-identity:Organization",
      "uco-core:name": "Lindell drug trafficking organization",
      "uco-core:description": "Organization led by Lindell that primarily distributed methamphetamine in the Red River Valley and Devils Lake area of North Dakota, often obtaining it from Minnesota's Twin Cities; used U.S. currency, mobile payment apps, social media, and cellular telephones in its transactions. Source: PACER Doc 101 (plea), para. 6 factual basis; Source: PACER Doc 66 (indictment2), overt acts 9-11",
      "uco-core:tag": [
        "drug-trafficking-organization"
      ]
    },
