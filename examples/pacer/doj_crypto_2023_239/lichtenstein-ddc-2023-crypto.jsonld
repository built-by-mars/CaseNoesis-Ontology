    {
      "@id": "urn:uuid:22865525-70ca-5602-bdd0-2d2a4d4e274a",
      "@type": [
        "cryptoinv:AssetSeizureAction",
        "case-investigation:InvestigativeAction",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Seizure of ~94,636 BTC from Wallet 1CGA4s",
      "uco-core:description": "Between 2022-01-31 and 2022-02-01, law enforcement obtained approval for a lawful seizure supported by probable cause under exigent circumstances and used the recovered private keys to seize Wallet 1CGA4s's remaining balance of approximately 94,636 BTC, worth $3.629 billion. A seizure warrant issued 2022-02-04. Source: PACER Doc 1-1 (statement_of_facts), para. 6",
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-01-31T00:00:00-05:00"
      },
      "uco-action:endTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-02-01T00:00:00-05:00"
      },
      "uco-action:object": [
        {
          "@id": "urn:uuid:056a069c-4f2c-590b-b48c-dc70d19f9708"
        }
      ]
