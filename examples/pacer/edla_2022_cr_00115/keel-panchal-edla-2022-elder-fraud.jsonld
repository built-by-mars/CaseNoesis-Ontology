        }
      ],
      "uco-core:kindOfRelationship": "Rented_By",
      "uco-core:isDirectional": {
        "@type": "xsd:boolean",
        "@value": "true"
      }
    },
    {
      "@id": "urn:uuid:5a7a3175-f854-5899-9cb6-6f907f56ef7e",
      "@type": [
        "uco-location:Location",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Hammond Square Mall, 2000 Southwest Railroad Avenue, Hammond, LA",
      "uco-core:description": "Drop site for both Victim A handoffs: the Santa Fe Cattle Company restaurant parking lot (2022-04-03) and the controlled-delivery sting near Best Buy (2022-04-04). Tangipahoa Parish, Eastern District of Louisiana. Source: PACER Doc 61 (factual_basis), pp. 2-3"
    },
    {
      "@id": "urn:uuid:de41ed43-a812-5ff2-bd4d-5deae58b50ae",
      "@type": [
        "uco-location:Location",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "South Center / Tukwila, Washington",
      "uco-core:description": "Victim B handoff sites: the Target parking lot at 300 Andover Park W, Tukwila, WA (2022-02-24, $60,000) and a Barnes and Noble bookstore in South Center, WA (2022-03-11, $100,000). Source: PACER Doc 61 (factual_basis), pp. 6-7"
    },
    {
      "@id": "urn:uuid:fc888836-87f6-56e2-a3e6-98ad5be05b39",
      "@type": [
        "uco-location:Location",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "La Quinta Inn, 5900 Veterans Blvd., Metairie, LA",
      "uco-core:description": "Keel's hotel (reserved on Panchal's card ending 5885 for two guests, 2022-04-03 to 2022-04-05); searched under a JPSO warrant, recovering flight tickets showing the Tampa-Seattle-New Orleans courier route. Source: PACER Doc 61 (factual_basis), pp. 4-5"
    },
    {
      "@id": "urn:uuid:06bfb9ec-6eea-5223-b6cc-cb3273be4b48",
      "@type": [
        "uco-action:Action",
