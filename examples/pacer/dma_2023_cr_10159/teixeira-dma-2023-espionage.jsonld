    {
      "@id": "urn:uuid:5bf8fbe7-df30-5647-993e-c9998cc72cdc",
      "@type": [
        "uco-observable:ObservableObject",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count Six NDI (TOP SECRET//SCI): A Government Document that describes a shift in foreign and...",
      "uco-core:description": "A Government Document that describes a shift in foreign and economic policy of a particular foreign government and actions that country took in an effort to repair its relationship with the United States, to the perceived detriment of a separate foreign country. Retained and transmitted Jan. 2023 to April 2023. Classified Government Document printed in the SCIF, removed, photographed, and posted to Discord. Source: PACER Doc 48 (indictment), paras. 16, 18 (count charts)",
      "uco-core:objectMarking": [
        {
          "@id": "urn:uuid:86e4c715-0835-5de7-9dfa-baad4bda5482"
        }
      ]
    },
