    {
      "@id": "urn:uuid:7256e498-9885-5ca6-b01a-97e0d280651e",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Malone Lam \u2014 Count 1ss: RICO Conspiracy",
      "uco-core:description": "Knowingly and intentionally conspiring to violate 18 U.S.C. \u00a7 1962(c) \u2014 to conduct and participate in the conduct of the affairs of the SE Enterprise through a pattern of racketeering activity (18 U.S.C. \u00a7\u00a7 1961(1), (5)) consisting of multiple acts indictable under the eight enumerated statutory categories, each defendant agreeing that a conspirator would commit at least two acts of racketeering activity. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), Count One, paras. 34-36 Pending as of the docket printout.",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 1962(d)",
      "legalproc:countNumber": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "1"
      },
      "legalproc:countLabel": "Count 1ss",
      "legalproc:offenseForm": "conspiracy",
      "legalproc:chargeDisposition": "pending",
      "legalproc:assertedIn": {
        "@id": "urn:uuid:6b1124e5-c0b8-5478-8de9-b596aa69676e"
      },
      "rico:predicateStatute": [
        "18 U.S.C. \u00a7 1028 (fraud and related activity in connection with identification documents)",
        "18 U.S.C. \u00a7 1029 (fraud and related activity in connection with access devices)",
        "18 U.S.C. \u00a7 1343 (wire fraud)",
        "18 U.S.C. \u00a7 1512 (tampering with a witness, victim, or an informant)",
        "18 U.S.C. \u00a7 1956 (laundering of monetary instruments)",
        "18 U.S.C. \u00a7 1957 (engaging in monetary transactions in property derived from specified unlawful activity)",
        "18 U.S.C. \u00a7 1960 (illegal money transmitters)",
        "18 U.S.C. \u00a7 2314 (interstate transportation of stolen property)"
      ]
    },
