@prefix solveit-observable: <https://ontology.solveit-df.org/solveit/observable/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/> .
@base <https://ontology.solveit-df.org/solveit/observable/> .

#################################################################
#    SOLVE-IT Observable Search Module
#    Classes for keyword search and indexing
#################################################################

<https://ontology.solveit-df.org/solveit/observable/search> rdf:type owl:Ontology ;
    owl:versionIRI <https://ontology.solveit-df.org/solveit/observable/search/0.1.9> ;
    owl:imports <https://ontology.unifiedcyberontology.org/uco/observable/1.4.0> ;
    dcterms:title "SOLVE-IT Observable Search Module"@en ;
    dcterms:description "Classes for keyword search, indexing, and file system analysis."@en ;
    dcterms:creator "SOLVE-IT Project" ;
    owl:versionInfo "0.1.9" ;
    rdfs:label "SOLVE-IT Observable Search Module"@en .

#################################################################
#    Classes
#################################################################

###  KeywordSearchResult Observable Object
solveit-observable:KeywordSearchResult rdf:type owl:Class ;
    rdfs:subClassOf uco-observable:ObservableObject ;
    rdfs:label "Keyword Search Result"@en ;
    rdfs:comment "A result from a keyword search operation during forensic analysis."@en .

###  KeywordSearchResultSet Observable Object
solveit-observable:KeywordSearchResultSet rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:ArtifactSet ;
    rdfs:label "Keyword Search Result Set"@en ;
    rdfs:comment "A collection of keyword search results from a search operation. Subsequent techniques may filter or reduce this set, for example by reviewing hits, discarding false positives, or redacting privileged content. Follows the same set-based pattern as FileSet and its subclasses."@en .

###  KeywordIndex Observable Object
solveit-observable:KeywordIndex rdf:type owl:Class ;
    rdfs:subClassOf uco-observable:ObservableObject ;
    rdfs:label "Keyword Index"@en ;
    rdfs:comment "An index of keywords created during forensic analysis."@en .

###  KeywordIndexingConfiguration Observable Object
solveit-observable:KeywordIndexingConfiguration rdf:type owl:Class ;
    rdfs:subClassOf uco-observable:ObservableObject ;
    rdfs:label "Keyword Indexing Configuration"@en ;
    rdfs:comment "Configuration settings used for keyword indexing during forensic analysis."@en .

#################################################################
#    Object Properties
#################################################################

solveit-observable:hasSearchResult rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:KeywordSearchResultSet ;
    rdfs:range solveit-observable:KeywordSearchResult ;
    rdfs:label "has search result"@en ;
    rdfs:comment "Links a KeywordSearchResultSet to an individual KeywordSearchResult."@en .

solveit-observable:hasConfiguration rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:KeywordIndex ;
    rdfs:range solveit-observable:KeywordIndexingConfiguration ;
    rdfs:label "has configuration"@en ;
    rdfs:comment "Links a KeywordIndex to its KeywordIndexingConfiguration."@en .
