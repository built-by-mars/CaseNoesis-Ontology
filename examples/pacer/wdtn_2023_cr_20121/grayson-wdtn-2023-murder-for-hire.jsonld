    {
      "@id": "urn:uuid:2fac0009-083e-5351-9d62-26c68c97e4bb",
      "@type": [
        "uco-core:UcoObject"
      ],
      "uco-core:name": "$10,000 payment for the staged 'attempt'",
      "uco-core:description": "US$10,000 \u2014 half of the promised $20,000 price \u2014 demanded by the Memphis couple for the purported failed attempt and received from Ashley and Joshua Grayson at a meeting in Dallas. Consideration for the murder-for-hire under 18 U.S.C. \u00a7 1958. Source: USAO press release, para. 5",
      "uco-core:tag": [
        "evidence",
        "payment"
      ]
    },
    {
      "@id": "urn:uuid:7e74eac8-f243-58a3-8bd6-3270bf2cced6",
      "@type": [
        "legalproc:ChargingInstrument",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Indictment (D.E. 1, filed 2023-06-29)",
      "uco-core:description": "One-count grand jury indictment returned in the Western District of Tennessee charging Ashley Grayson and Joshua Grayson with Use of Interstate Facility in Commission of Murder-for-Hire, 18 U.S.C. \u00a7 1958. Source: PACER docket, D.E. 1; Source: USAO press release, para. 6",
      "legalproc:instrumentType": "indictment",
      "uco-core:objectCreatedTime": {
        "@type": "xsd:dateTime",
        "@value": "2023-06-29T00:00:00-05:00"
      }
    },
