@prefix : <https://ontology.solveit-df.org/solveit/analysis/> .
@prefix solveit-analysis: <https://ontology.solveit-df.org/solveit/analysis/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix uco-core: <https://ontology.unifiedcyberontology.org/uco/core/> .
@prefix uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/> .
@prefix uco-analysis: <https://ontology.unifiedcyberontology.org/uco/analysis/> .
@prefix solveit-observable: <https://ontology.solveit-df.org/solveit/observable/> .
@base <https://ontology.solveit-df.org/solveit/analysis/> .

#################################################################
#    SOLVE-IT Analysis Module
#    Analytic results and analysis classes for digital forensics
#################################################################

<https://ontology.solveit-df.org/solveit/analysis> rdf:type owl:Ontology ;
    owl:versionIRI <https://ontology.solveit-df.org/solveit/analysis/0.1.9> ;
    owl:imports <https://ontology.unifiedcyberontology.org/uco/core/1.4.0> ,
                <https://ontology.unifiedcyberontology.org/uco/observable/1.4.0> ,
                <https://ontology.unifiedcyberontology.org/uco/analysis/1.4.0> ;
    dcterms:title "SOLVE-IT Analysis Module"@en ;
    dcterms:description "Analytic results for SOLVE-IT digital forensics, including hypothesised events and forensic tool reports."@en ;
    dcterms:creator "SOLVE-IT Project" ;
    owl:versionInfo "0.1.9" ;
    rdfs:label "SOLVE-IT Analysis Module"@en .

#################################################################
#    Classes
#################################################################

###  Hypothesis Analytic Result
solveit-analysis:Hypothesis rdf:type owl:Class ;
    rdfs:subClassOf uco-analysis:AnalyticResult ;
    rdfs:label "Hypothesis"@en ;
    rdfs:comment "A proposition or explanation put forward for consideration during forensic analysis, which may be supported or contradicted by observable artifacts."@en .

###  HypothesisedEvent
solveit-analysis:HypothesisedEvent rdf:type owl:Class ;
    rdfs:subClassOf solveit-analysis:Hypothesis ;
    rdfs:label "Hypothesised Event"@en ;
    rdfs:comment "An event that is hypothesised to have occurred."@en .

###  HypothesisedWebSearch
solveit-analysis:HypothesisedWebSearch rdf:type owl:Class ;
    rdfs:subClassOf solveit-analysis:HypothesisedEvent ;
    rdfs:label "Hypothesised Web Search"@en ;
    rdfs:comment "A web search that is hypothesised to have been performed, potentially inferred from browser history fragments, cached results, or suggested search terms. Use uco-observable:keywordSearchTerm for the search query."@en .

###  HypothesisedCommunication
solveit-analysis:HypothesisedCommunication rdf:type owl:Class ;
    rdfs:subClassOf solveit-analysis:HypothesisedEvent ;
    rdfs:label "Hypothesised Communication"@en ;
    rdfs:comment "A communication that is hypothesised to have occurred between parties, potentially inferred from partial message records, contact patterns, or metadata fragments. Use uco-observable:from and uco-observable:to for the parties involved."@en .

###  HypothesisedRelationship
solveit-analysis:HypothesisedRelationship rdf:type owl:Class ;
    rdfs:subClassOf solveit-analysis:Hypothesis ;
    rdfs:label "Hypothesised Relationship"@en ;
    rdfs:comment "A relationship between entities that is hypothesised to exist, such as an inferred association between persons, accounts, devices, or locations based on co-occurrence patterns, shared identifiers, or behavioural analysis."@en .

###  HypothesisedDevice
solveit-analysis:HypothesisedDevice rdf:type owl:Class ;
    rdfs:subClassOf solveit-analysis:Hypothesis ;
    rdfs:label "Hypothesised Device"@en ;
    rdfs:comment "A device that is hypothesised to have been involved, such as a device inferred from artifacts but not yet physically identified or examined."@en .

###  HypothesisedUserAccount
solveit-analysis:HypothesisedUserAccount rdf:type owl:Class ;
    rdfs:subClassOf solveit-analysis:Hypothesis ;
    rdfs:label "Hypothesised User Account"@en ;
    rdfs:comment "A user account that is hypothesised to have existed, for example inferred from recovered deleted account records, carved registry artifacts, or references to the account in other artifacts. Supporting artifacts can be linked with solveit-analysis:supportedBy."@en .

###  HypothesisSet Analytic Result
solveit-analysis:HypothesisSet rdf:type owl:Class ;
    rdfs:subClassOf uco-analysis:AnalyticResult ;
    rdfs:label "Hypothesis Set"@en ;
    rdfs:comment "A collection of competing alternative hypotheses considered together, for example the mutually exclusive explanations proposed for a single observation. Members are linked with solveit-analysis:hasHypothesis."@en .

###  ForensicToolTagBasedReport Analytic Result
solveit-analysis:ForensicToolTagBasedReport rdf:type owl:Class ;
    rdfs:subClassOf uco-analysis:AnalyticResult ;
    rdfs:label "Forensic Tool Tag-Based Report"@en ;
    rdfs:comment "A report generated by a forensic tool based on tags added during analysis."@en .

#################################################################
#    Object Properties
#################################################################

solveit-analysis:supportedBy rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-analysis:Hypothesis ;
    rdfs:range uco-observable:ObservableObject ;
    rdfs:label "supported by"@en ;
    rdfs:comment "Links a Hypothesis to artifacts that support the hypothesis."@en .

solveit-analysis:contradictedBy rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-analysis:Hypothesis ;
    rdfs:range uco-observable:ObservableObject ;
    rdfs:label "contradicted by"@en ;
    rdfs:comment "Links a Hypothesis to artifacts that contradict the hypothesis."@en .

solveit-analysis:hasHypothesis rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-analysis:HypothesisSet ;
    rdfs:range solveit-analysis:Hypothesis ;
    rdfs:label "has hypothesis"@en ;
    rdfs:comment "Links a HypothesisSet to a member Hypothesis it groups as a competing alternative."@en .

solveit-analysis:hypothesisedDateTime rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-analysis:HypothesisedEvent ;
    rdfs:range [ a owl:Class ;
                 owl:unionOf ( solveit-observable:DateTimeStamp
                               solveit-observable:DateTimeRange ) ] ;
    rdfs:label "hypothesised date time"@en ;
    rdfs:comment "The date and time at which the hypothesised event is believed to have occurred - either an absolute timestamp (DateTimeStamp) or a time interval (DateTimeRange)."@en .

solveit-analysis:hypothesisedServiceName rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-analysis:HypothesisedEvent ;
    rdfs:range xsd:string ;
    rdfs:label "hypothesised service name"@en ;
    rdfs:comment "The name of the service or platform hypothesised to have been used (e.g. Google, WhatsApp, iMessage)."@en .

solveit-analysis:hasArtifact rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-analysis:ForensicToolTagBasedReport ;
    rdfs:range uco-observable:ObservableObject ;
    rdfs:label "has artifact"@en ;
    rdfs:comment "Links a ForensicToolTagBasedReport to tagged artifacts."@en .

solveit-analysis:hasFile rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-analysis:ForensicToolTagBasedReport ;
    rdfs:range uco-observable:File ;
    rdfs:label "has file"@en ;
    rdfs:comment "Links a ForensicToolTagBasedReport to tagged files."@en .
