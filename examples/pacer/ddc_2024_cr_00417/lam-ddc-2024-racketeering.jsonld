    {
      "@id": "urn:uuid:4cd8e7a9-affc-5e06-918b-43629ddd3c6e",
      "@type": "uco-action:Action",
      "uco-core:name": "Exchange $196,880 through a 'cash guy' Monero address for a rental deposit",
      "uco-core:description": "In July 2024, arranging another rental home for Lam, Tangeman requested $196,880 in USDT; when Lam said he didn't have USDT and asked for an XMR (Monero) address, Tangeman shared his 'cash guy's' XMR address and Lam sent the $196,880. Tangeman replied 'Waiting for cash atm ... Then going to give it to her.' Source: PACER Doc 318 (sentmemo), Statement of Facts quotes",
      "uco-action:performer": {
        "@id": "urn:uuid:ee9929a5-4779-5303-9c4f-7c0d7802af40"
      },
      "uco-action:startTime": {
