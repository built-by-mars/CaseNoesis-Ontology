    {
      "@id": "urn:uuid:18fe8e88-2b33-57ba-9b00-11d6c7f11d5c",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Teixeira instructs Discord associates to delete evidence",
      "uco-core:description": "Instructed associates on Discord to delete electronic evidence and not cooperate with law enforcement. Basis (with the other obstruction acts) of the USSG \u00a7 3C1.1 obstruction enhancement. Source: PACER Doc 144 (sentencing_memorandum), pp. 8-9",
      "uco-action:performer": {
        "@id": "urn:uuid:b413b5a1-8666-5b5c-aca9-a86696327cc4"
