      "@id": "urn:uuid:bd0541f5-1a14-5c91-bc8f-e8bf0a5e7c72",
      "@type": [
        "uco-action:Action",
        "https://attack.mitre.org/techniques/T1016"
      ],
      "uco-core:name": "Host and network discovery",
      "uco-core:description": "Actor ran net, tasklist, quser, ipconfig, netstat, and dir to enumerate user accounts, directories, processes, and network configuration; assessed internet reachability and, when restricted, used the target proxy or the Venom tool. Tools were frequently staged in the world-readable public\\pictures folder.",
      "uco-action:performer": {
        "@id": "urn:uuid:302f9be5-f6d7-57c4-ad18-22d120790017"
      },
      "uco-action:instrument": [
