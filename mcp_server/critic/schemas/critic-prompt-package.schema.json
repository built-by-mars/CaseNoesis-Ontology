{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caseontology.org/schemas/critic-prompt-package.schema.json",
  "title": "CASE/UCO Critic Prompt Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "system_role",
    "trust_boundary",
    "artifact_hashes",
    "validation_summary",
    "response_schema",
    "response_schema_version",
    "response_schema_sha256",
    "prompt_package_hash",
    "byte_size",
    "truncated"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1, "maxLength": 32 },
    "system_role": { "type": "string", "minLength": 1 },
    "session_id": { "type": ["string", "null"], "maxLength": 128 },
    "pass_number": { "type": "integer", "minimum": 1, "maximum": 32 },
    "trust_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_trust", "forbidden_actions"],
      "properties": {
        "content_trust": { "type": "string" },
        "forbidden_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "artifact_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graph_sha256"],
      "properties": {
        "graph_sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
        "serializer_sha256": { "type": ["string", "null"] },
        "source_sha256": { "type": "object" },
        "coverage_contract_sha256": { "type": ["string", "null"] },
        "provenance_manifest_sha256": { "type": ["string", "null"] }
      }
    },
    "validation_summary": { "type": "object" },
    "extensions": { "type": "array", "items": { "type": "string" } },
    "profiles": { "type": "array", "items": { "type": "string" } },
    "deterministic_findings": { "type": "array" },
    "source_findings": { "type": "array" },
    "critic_findings": { "type": "array" },
    "prior_pass_findings": { "type": "array" },
    "graph_neighborhoods": { "type": "array" },
    "serializer_excerpts": { "type": "array" },
    "serializer_overview": { "type": "object" },
    "source_excerpts": { "type": "array" },
    "structural_stats": { "type": "object" },
    "omissions": { "type": "array", "items": { "type": "string" } },
    "response_schema": { "type": "object" },
    "response_schema_version": { "type": "string", "minLength": 1, "maxLength": 32 },
    "response_schema_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "review_request_sha256": {
      "type": ["string", "null"],
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "review_config_sha256": {
      "type": ["string", "null"],
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "review_config": { "type": "object" },
    "prompt_package_hash": { "type": "string", "minLength": 64, "maxLength": 64 },
    "prompt_content_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "serialization_integrity_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "byte_size": { "type": "integer", "minimum": 1 },
    "token_estimate": { "type": "integer", "minimum": 1 },
    "truncated": { "type": "boolean" },
    "sampling_disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_source_excerpts",
        "contains_serializer_excerpts",
        "contains_graph_literals",
        "marking_ids",
        "marking_names",
        "restricted_content_detected",
        "excerpt_bytes",
        "estimated_tokens",
        "egress_decision"
      ],
      "properties": {
        "contains_source_excerpts": { "type": "boolean" },
        "contains_serializer_excerpts": { "type": "boolean" },
        "contains_graph_literals": { "type": "boolean" },
        "marking_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "marking_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "restricted_content_detected": { "type": "boolean" },
        "excerpt_bytes": { "type": "integer", "minimum": 0 },
        "estimated_tokens": { "type": "integer", "minimum": 0 },
        "egress_decision": {
          "type": "string",
          "enum": ["allow", "manual_required", "deny"]
        }
      }
    }
  }
}
