      "uco-core:name": "Sagerunex Zimbra version",
      "uco-core:description": "Variant that uses the Zimbra open-source webmail API as its C2 channel: logs in for an auth token, saves encrypted host info as mail_report.rar attached to a Drafts-folder message (beacon/exfil), reads operator commands from mailbox content, and writes command results as mail_report.rar into the Trash folder. Active since 2019.",
      "uco-core:hasFacet": [
        {
          "@id": "urn:uuid:96cc9671-185b-514c-8e3a-9a019bc94029",
          "@type": "uco-observable:FileFacet",
          "uco-observable:fileName": "Sagerunex Zimbra version (Sagerunex variant)",
          "uco-observable:extension": "dll",
          "uco-observable:observableCreatedTime": {
            "@type": "xsd:dateTime",
            "@value": "2019-01-01T00:00:00Z"
          }
        }
      ]
    },
