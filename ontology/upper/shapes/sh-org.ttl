# imports: http://example.org/shapes/sh-foaf
# imports: http://example.org/shapes/sh-prov-o
# imports: http://example.org/shapes/sh-skos
# imports: http://www.w3.org/ns/org#

@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix gr: <http://purl.org/goodrelations/v1#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sh-org: <http://example.org/shapes/org/> .
@prefix sh-prov: <http://example.org/shapes/prov/> .
@prefix sh-skos: <http://example.org/shapes/skos/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/shapes/sh-org>
	a owl:Ontology ;
	owl:imports
		<http://example.org/shapes/sh-foaf> ,
		<http://example.org/shapes/sh-prov-o> ,
		<http://example.org/shapes/sh-skos> ,
		<http://www.w3.org/ns/org#>
		;
	.

sh-org:BusinessEntity-shape
	a sh:NodeShape ;
	sh:targetClass gr:BusinessEntity ;
	.

sh-org:ChangeEvent-disjointWith-Membership-shape
	a sh:NodeShape ;
	sh:message "org:ChangeEvent and org:Membership are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Membership ;
	] ;
	sh:targetClass org:ChangeEvent ;
	.

sh-org:ChangeEvent-disjointWith-Organization-shape
	a sh:NodeShape ;
	sh:message "org:ChangeEvent and org:Organization are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Organization ;
	] ;
	sh:targetClass org:ChangeEvent ;
	.

sh-org:ChangeEvent-disjointWith-Role-shape
	a sh:NodeShape ;
	sh:message "org:ChangeEvent and org:Role are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Role ;
	] ;
	sh:targetClass org:ChangeEvent ;
	.

sh-org:ChangeEvent-disjointWith-Site-shape
	a sh:NodeShape ;
	sh:message "org:ChangeEvent and org:Site are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Site ;
	] ;
	sh:targetClass org:ChangeEvent ;
	.

sh-org:ChangeEvent-shape
	a sh:NodeShape ;
	rdfs:seeAlso sh-prov:Activity-shape ;
	sh:targetClass org:ChangeEvent ;
	.

sh-org:FormalOrganization-shape
	a sh:NodeShape ;
	sh:targetClass org:FormalOrganization ;
	.

sh-org:Membership-disjointWith-Organization-shape
	a sh:NodeShape ;
	sh:message "org:Membership and org:Organization are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Organization ;
	] ;
	sh:targetClass org:Membership ;
	.

sh-org:Membership-disjointWith-Role-shape
	a sh:NodeShape ;
	sh:message "org:Membership and org:Role are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Role ;
	] ;
	sh:targetClass org:Membership ;
	.

sh-org:Membership-disjointWith-Site-shape
	a sh:NodeShape ;
	sh:message "org:Membership and org:Site are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Site ;
	] ;
	sh:targetClass org:Membership ;
	.

sh-org:Membership-shape
	a sh:NodeShape ;
	sh:targetClass org:Membership ;
	.

sh-org:Organization-disjointWith-Role-shape
	a sh:NodeShape ;
	sh:message "org:Organization and org:Role are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Role ;
	] ;
	sh:targetClass org:Organization ;
	.

sh-org:Organization-disjointWith-Site-shape
	a sh:NodeShape ;
	sh:message "org:Organization and org:Site are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Site ;
	] ;
	sh:targetClass org:Organization ;
	.

sh-org:Organization-equivalentClass-shape
	a sh:NodeShape ;
	rdfs:comment
		"Shape deactivated to account for some ontology authorship metadata spelling patterns requiring OWL or RDFS inferencing to satisfy this shape."@en ,
		"org:Organization declares itself an equivalent class with foaf:Organization."@en
		;
	sh:class foaf:Organization ;
	sh:deactivated "true"^^xsd:boolean ;
	sh:targetClass org:Organization ;
	.

sh-org:Organization-shape
	a sh:NodeShape ;
	sh:targetClass org:Organization ;
	.

sh-org:OrganizationalCollaboration-hasMember-shape
	a sh:PropertyShape ;
	sh:class org:Organization ;
	sh:path org:hasMember ;
	.

sh-org:OrganizationalCollaboration-shape
	a sh:NodeShape ;
	sh:property sh-org:OrganizationalCollaboration-hasMember-shape ;
	sh:targetClass org:OrganizationalCollaboration ;
	.

sh-org:OrganizationalUnit-shape
	a sh:NodeShape ;
	sh:targetClass org:OrganizationalUnit ;
	.

sh-org:Post-shape
	a sh:NodeShape ;
	sh:targetClasss org:Post ;
	.

sh-org:Role-disjointWith-Site-shape
	a sh:NodeShape ;
	sh:message "org:Role and org:Site are disjoint classes."@en ;
	sh:not [
		a sh:NodeShape ;
		sh:class org:Site ;
	] ;
	sh:targetClass org:Role ;
	.

sh-org:Role-shape
	a sh:NodeShape ;
	rdfs:seeAlso sh-skos:Concept-shape ;
	sh:targetClass org:Role ;
	.

sh-org:Site-shape
	a sh:NodeShape ;
	sh:targetClass org:Site ;
	.

sh-org:basedAt-subjects-basedAt-shape
	a sh:PropertyShape ;
	sh:class org:Site ;
	sh:path org:basedAt ;
	.

sh-org:basedAt-subjects-shape
	a sh:NodeShape ;
	sh:class foaf:Person ;
	sh:property sh-org:basedAt-subjects-basedAt-shape ;
	sh:targetSubjectsOf org:basedAt ;
	.

sh-org:changedBy-subjects-changedBy-shape
	a sh:PropertyShape ;
	sh:class org:ChangeEvent ;
