      ],
      "uco-core:name": "Count 45: Escape from Custody (O'Dell)",
      "uco-core:description": "Between 2023-09-29 and 2023-10-01 O'Dell escaped from, and failed to return to, custody of the Phelps County Jail where he was confined under a federal detention order. Pleaded guilty 2024-10-28. Source: PACER Doc 48 (indictment3), Count 45, para. 80",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 751(a)",
      "legalproc:countLabel": "Count 45",
      "legalproc:countNumber": [
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "45"
        }
      ],
      "legalproc:offenseForm": "substantive",
