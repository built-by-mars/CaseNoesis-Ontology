    {
      "@id": "urn:uuid:89caa1ab-1e63-5ca9-a1d7-714e973dbdbd",
      "@type": [
        "cryptoinv:ForfeitureOrder",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Forfeiture allegation and consent order (Lichtenstein)",
      "uco-core:description": "The Information's forfeiture allegation lists specific property including approximately 94,643.29837084 BTC, 117,376.52651940 BCH, 117,376.58178024 BSV, 118,102.03258447 BTG, 29,016.98 XMR, Ethereum wallets and DeFi positions (USDC, aUSDC, aUSDT, USDT, yvUSDT, WETH, Curve DAO tokens), gold coins recovered from a buried location, funds from JPMorgan Chase, Wells Fargo, and Flagstar/Signature bank accounts, and BTC/ETH from an external hard drive recovered at the defendants' New York residence. In the plea agreement Lichtenstein consented to a forfeiture money judgment of $72,618,825.60 and to forfeiture of the specific listed property. Source: PACER Doc 89 (information), forfeiture allegation paras. 10-13; Source: PACER Doc 96 (plea_agreement), forfeiture section",
      "cryptoinv:forfeits": [
        {
          "@id": "urn:uuid:056a069c-4f2c-590b-b48c-dc70d19f9708"
