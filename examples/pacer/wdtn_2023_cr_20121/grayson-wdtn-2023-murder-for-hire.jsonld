      "uco-core:isDirectional": {
        "@type": "xsd:boolean",
        "@value": "true"
      }
    },
    {
      "@id": "urn:uuid:c2c54bb7-dfae-517f-a403-d48a4c3c7139",
      "@type": "uco-action:Action",
      "uco-core:name": "Offer the Memphis couple money to kill three people (Dallas meeting)",
      "uco-core:description": "In early September 2022, the Memphis woman and her husband met with Ashley Grayson and her husband in Dallas, where Ashley Grayson offered to pay the couple to kill three different people \u2014 the Southaven woman, Grayson's former boyfriend, and a Texas woman who had recently made negative social media posts about Grayson \u2014 each killing valued at $20,000 or more. Joshua Grayson's presence at the meeting is recorded here; the jury acquitted him of the \u00a7 1958 charge. Source: USAO press release, para. 3",
      "uco-action:performer": {
        "@id": "urn:uuid:f343525b-ac3b-5796-8466-167e4308ef07"
      },
      "uco-action:object": [
        {
          "@id": "urn:uuid:4a77fc19-e38f-5826-914d-88a5ecefa828"
        },
        {
          "@id": "urn:uuid:2f552c80-9bae-55fa-97eb-f0de81f77e3f"
        },
        {
          "@id": "urn:uuid:c5945a50-63a3-5180-a395-a4cc3d546634"
        }
      ],
      "uco-action:location": {
        "@id": "urn:uuid:30ee77d1-0c86-5d72-86ab-8d058f2168bf"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-09-01T00:00:00-05:00"
      },
      "uco-action:endTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-09-09T00:00:00-05:00"
      }
    },
    {
      "@id": "urn:uuid:95fa08ad-7783-5cf5-876b-9842cdba6bc7",
      "@type": "uco-action:Action",
      "uco-core:name": "Confirm the hit on the Southaven woman in a video-recorded call",
      "uco-core:description": "On 2022-09-10, the Memphis woman video-recorded a call to Ashley Grayson in which Grayson confirmed that she wanted the Southaven woman killed as soon as possible and offered an extra $5,000 for the murder to be carried out in the next week. Source: USAO press release, para. 4",
      "uco-action:performer": {
        "@id": "urn:uuid:f343525b-ac3b-5796-8466-167e4308ef07"
      },
      "uco-action:object": [
        {
          "@id": "urn:uuid:4a77fc19-e38f-5826-914d-88a5ecefa828"
        }
      ],
      "uco-action:instrument": [
        {
          "@id": "urn:uuid:e05e1663-8087-5322-bff5-9b656b536154"
        }
      ],
      "uco-action:startTime": {
