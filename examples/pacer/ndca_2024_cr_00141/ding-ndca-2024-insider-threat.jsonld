      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Ding founds Zhisuan and applies to MiraclePlus (by 2023-05-30)",
      "uco-core:description": "Ding founded Shanghai Zhisuan Technology, acted as CEO, and applied on Zhisuan's behalf to the MiraclePlus startup incubation program, proposing a CMS to accelerate ML workloads on supercomputing chips. Source: PACER Doc 140 (second_superseding_indictment), paras. 21-22",
      "uco-action:performer": {
        "@id": "urn:uuid:aeeaf703-8a4a-554b-9882-0228790fb782"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2023-05-30T00:00:00-07:00"
      }
    },
