    solveit-core:hasPotentialWeakness :weaknessDFW-1247 ;
    solveit-core:techniqueDescription "The examination of the links saved within a browser to facilitate quick access" ;
    solveit-core:techniqueID "DFT-1141" ;
    solveit-core:techniqueName "Extract browser bookmark artifacts" .

:techniqueDFT-1142 a solveit-core:Technique ;
    rdfs:label "DFT-1142: Extract browser download artifacts"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI,
