:weaknessDFW-1004 a solveit-core:Weakness ;
    rdfs:label "DFW-1004: Data copied does not include all sectors from LBA0 to LBA max due to the data copying process stopping prematurely"@en ;
    solveit-core:hasPotentialMitigation :mitigationDFM-1003,
        :mitigationDFM-1004 ;
    solveit-core:hasWeaknessClass solveit-core:ASTM_INCOMP ;
    solveit-core:weaknessID "DFW-1004" ;
    solveit-core:weaknessName "Data copied does not include all sectors from LBA0 to LBA max due to the data copying process stopping prematurely" .

:weaknessDFW-1005 a solveit-core:Weakness ;
    rdfs:label "DFW-1005: Dogs fail to find a digital device"@en ;
    solveit-core:hasWeaknessClass solveit-core:ASTM_INCOMP ;
    solveit-core:weaknessID "DFW-1005" ;
    solveit-core:weaknessName "Dogs fail to find a digital device" .

:weaknessDFW-1006 a solveit-core:Weakness ;
    rdfs:label "DFW-1006: Acquisition tool does not copy data from HPA"@en ;
    solveit-core:hasPotentialMitigation :mitigationDFM-1003,
        :mitigationDFM-1005 ;
    solveit-core:hasReference :citationDFCite-1052 ;
    solveit-core:hasWeaknessClass solveit-core:ASTM_INCOMP ;
    solveit-core:weaknessDescription "Some forensic acquisition tools do not detect or acquire data stored within the HPA (Host Protected Area), resulting in an incomplete forensic image that omits potentially evidential data. This weakness arises because accessing the HPA typically requires issuing specific ATA commands (such as SET MAX ADDRESS) to temporarily remove the protection before imaging, a capability not universally implemented across acquisition tools (Gupta, Hoeschele and Rogers, 2006)." ;
    solveit-core:weaknessID "DFW-1006" ;
    solveit-core:weaknessName "Acquisition tool does not copy data from HPA" .

:weaknessDFW-1007 a solveit-core:Weakness ;
    rdfs:label "DFW-1007: Acquisition tool does not copy data from DCO"@en ;
    solveit-core:hasPotentialMitigation :mitigationDFM-1003,
        :mitigationDFM-1006 ;
    solveit-core:hasReference :citationDFCite-1052 ;
    solveit-core:hasWeaknessClass solveit-core:ASTM_INCOMP ;
    solveit-core:weaknessDescription "The Device Configuration Overlay (DCO) is a feature of the ATA standard that allows hardware vendors or system manufacturers to permanently hide a portion of a hard disk drive's capacity from the host system, including the operating system and forensic acquisition tools. Unlike the HPA, the DCO operates at a lower level and persists across power cycles, meaning that without issuing specific ATA commands (such as DEVICE CONFIGURATION RESTORE) the hidden area remains inaccessible. Acquisition tools that do not detect or interact with the DCO will produce an incomplete forensic image, potentially missing evidential data stored in this region (Gupta, Hoeschele and Rogers, 2006)." ;
    solveit-core:weaknessID "DFW-1007" ;
    solveit-core:weaknessName "Acquisition tool does not copy data from DCO" .

