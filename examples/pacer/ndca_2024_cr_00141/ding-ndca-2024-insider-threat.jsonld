      ],
      "uco-core:name": "Ding's residence (N.D. Cal.)",
      "uco-core:description": "Site of Google's 2024-01-04 device retrieval and the FBI's 2024-01-06 search warrant execution. Source: PACER Doc 140 (second_superseding_indictment), paras. 32-33"
    },
    {
      "@id": "urn:uuid:e8f519df-d26e-5f13-b993-c45a99d8a4bc",
      "@type": [
        "uco-location:Location",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Beijing, People's Republic of China",
      "uco-core:description": "Site of the 2023-11-24 MiraclePlus venture capital investor conference where Ding pitched Zhisuan, and destination of his 2024-01-07 one-way ticket. Source: PACER Doc 140 (second_superseding_indictment), paras. 22, 28"
    },
