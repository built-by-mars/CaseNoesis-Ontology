      ],
      "uco-core:name": "Counts 36-37: Felon in Possession of a Firearm (Perry)",
      "uco-core:description": "Perry, a convicted felon, knowingly possessed the Voodoo Innovations rifle (Count 36) and the Ruger Security-9 pistol with an obliterated serial number (Count 37). The government recommended merging Count 37 into Count 36 at sentencing as multiplicitous. Source: PACER Doc 48 (indictment3), Counts 36-37, paras. 71-72; Source: PACER Doc 214 (sentencing_memo), p. 2 n.1",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7\u00a7 922(g)(1) & 924(a)(8)",
