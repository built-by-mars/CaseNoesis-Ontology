    {
      "@id": "urn:uuid:2d30ae09-1422-5f1b-abc4-a126af3d5837",
      "@type": [
        "rico:RacketeeringEnterprise",
        "uco-identity:Organization"
      ],
      "uco-core:name": "The Social Engineering Enterprise (SE Enterprise)",
      "uco-core:description": "Group of individuals based in California, Connecticut, New York, Florida, and abroad, associated in fact although not a legal entity (18 U.S.C. \u00a7 1961(4)), engaged in and affecting interstate and foreign commerce. Grew from friendships developed on online gaming platforms that evolved into agreements to commit cyber-enabled offenses. Operated from no later than October 2023 through at least May 2025. Charged purposes: (a) stealing virtual currency from victims throughout the United States through fraudulent pretenses; (b) disguising, concealing, and obfuscating the source and ownership of the stolen funds through virtual-currency laundering techniques; and (c) converting laundered virtual currency into fiat currency and wire transfers for nightclubs, exotic cars, jewelry, luxury handbags, clothing, private jet rentals, and rental mansions in Los Angeles, the Hamptons, Miami, and elsewhere. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), paras. 23-27; Source: PACER Doc 257 (soo), Statement of Facts",
      "rico:enterpriseType": "association-in-fact",
      "uco-core:tag": [
        "criminal-enterprise"
      ]
    },
    {
      "@id": "urn:uuid:31a080c4-8acb-5d89-a6e9-708cdd2a4271",
      "@type": [
        "rico:EnterpriseRole",
        "uco-role:Role"
      ],
      "uco-core:name": "SE Enterprise role: database hacker",
      "uco-core:description": "Database hackers were responsible for hacking websites and servers to obtain cryptocurrency-related databases or purchasing databases on the dark web. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), paras. 25-26, 16, 32",
      "rico:roleFunction": "database-hacker"
    },
    {
      "@id": "urn:uuid:92f9611f-265b-55b4-bba0-4d0a9a509f5f",
      "@type": "uco-core:Relationship",
      "uco-core:source": [
