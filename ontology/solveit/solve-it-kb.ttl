    solveit-core:techniqueID "DFT-1066" ;
    solveit-core:techniqueName "Extract artifacts from operating system log files" .

:techniqueDFT-1067 a solveit-core:Technique ;
    rdfs:label "DFT-1067: Extract artifacts from operating system cloud synchronization features"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
