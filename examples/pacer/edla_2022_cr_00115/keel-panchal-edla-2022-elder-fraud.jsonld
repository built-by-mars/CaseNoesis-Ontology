  "@graph": [
    {
      "@id": "urn:uuid:433e4bb8-6960-5cba-9803-4f7f566f8ef7",
      "@type": "case-investigation:Investigation",
      "uco-core:name": "United States v. Keel & Panchal, 2:22-cr-00115-ILRL-KWR (E.D. La.)",
      "legalproc:caseIdentifier": "2:22-cr-00115-ILRL-KWR",
      "uco-core:description": "Elder-fraud prosecution of two money couriers for a transnational government-impersonation call-center scheme. Co-conspirators phoned elderly victims (Victim A, 77, Hammond, LA; Victim B, 76, Washington State; Victim C, 80, Bossier Parish, LA), posed as U.S. Treasury / DOJ agents, claimed the victims' bank accounts were implicated in crime, and collected cash 'for safekeeping' via Green Dot cards, mailed packages, and in-person pickups. Keel was arrested 2022-04-04 in a Tangipahoa Parish Sheriff's Office controlled-delivery sting; HSI's follow-on federal investigation attributed $4,498,327 in actual and attempted losses to 31 U.S. victims since 2021-10-22. Docket filed 2022-06-02 (magistrate case 2:22-mj-00062-DM); terminated 2023-10-25. Judge Ivan L.R. Lemelle; Magistrate Judge Karen Wells Roby. Source: PACER Doc criminal docket sheet (docket), caption; Source: PACER Doc 61 (factual_basis), pp. 1-8"
    },
    {
