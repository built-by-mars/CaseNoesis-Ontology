{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caseontology.org/schemas/critic-finding.schema.json",
  "title": "CASE/UCO CriticFinding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "severity",
    "category",
    "confidence",
    "status",
    "target",
    "evidence_kind",
    "evidence",
    "rationale",
    "recommended_change",
    "verification_method"
  ],
  "properties": {
    "finding_id": { "type": "string", "minLength": 1 },
    "identity_key": { "type": "string" },
    "severity": {
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "category": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": {
      "enum": [
        "new",
        "persisting",
        "resolved",
        "regression",
        "disputed",
        "unevaluated"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "path": { "type": ["string", "null"] },
        "line": { "type": ["integer", "null"] },
        "node_id": { "type": ["string", "null"] },
        "predicate": { "type": ["string", "null"] },
        "counterpart_id": { "type": ["string", "null"] },
        "json_pointer": { "type": ["string", "null"] },
        "qualified_name": { "type": ["string", "null"] }
      }
    },
    "evidence_kind": {
      "enum": ["deterministic", "source", "critic_inference"]
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rationale": { "type": "string" },
    "recommended_change": { "type": "string" },
    "verification_method": { "type": "string" },
    "rule_id": { "type": ["string", "null"] },
    "verifier_rule_id": { "type": ["string", "null"] },
    "rule_version": { "type": ["string", "null"] },
    "claim_type": { "type": ["string", "null"] },
    "assesses_finding_id": { "type": ["string", "null"] },
    "related_recipe": { "type": ["string", "null"] },
    "related_validation_result": { "type": ["string", "null"] },
    "suppressible": { "type": "boolean" },
    "disputed_rationale": { "type": ["string", "null"] },
    "display_index": { "type": ["integer", "null"] },
    "occurrence": { "type": "object" }
  }
}
