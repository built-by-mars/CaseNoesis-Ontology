    {
      "@id": "urn:uuid:57f9a6f5-41fd-549a-9ff3-7f51ab1a8cff",
      "@type": "uco-action:Action",
      "uco-core:name": "Stage a failed murder attempt with a police-lights photo and demand $10,000",
      "uco-core:description": "The Memphis couple sent Ashley Grayson a picture of police lights from an unrelated incident in Memphis under the guise that they had attempted to carry out the murder-for-hire but were unsuccessful, and demanded $10,000 \u2014 half of the promised price \u2014 for the attempt. Source: USAO press release, para. 5",
      "uco-action:performer": {
        "@id": "urn:uuid:92774010-3d0e-59ae-bb35-42093de3aa6f"
      },
      "uco-action:object": [
