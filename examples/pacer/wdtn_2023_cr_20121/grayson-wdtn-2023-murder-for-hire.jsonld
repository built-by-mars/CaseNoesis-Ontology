    {
      "@id": "urn:uuid:2c020a11-1cff-5858-933a-9869b10cafb7",
      "@type": "uco-action:Action",
      "uco-core:name": "Pay the Memphis couple $10,000 for the staged 'attempt' (Dallas meeting)",
      "uco-core:description": "The Memphis couple went to Dallas, met with Ashley Grayson and her husband, and received $10,000 from them for the 'attempt'. Source: USAO press release, para. 5",
      "uco-action:performer": {
        "@id": "urn:uuid:f343525b-ac3b-5796-8466-167e4308ef07"
      },
