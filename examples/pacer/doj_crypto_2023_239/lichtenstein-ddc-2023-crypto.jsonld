    {
      "@id": "urn:uuid:91c55da8-ad04-5bcb-95ed-53f96f149f74",
      "@type": [
        "cryptoinv:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 1: Money Laundering Conspiracy",
      "uco-core:description": "Lichtenstein conspired (August 2016 - February 2022) to conduct financial transactions involving proceeds of wire fraud (18 U.S.C. \u00a7 1343) and computer fraud and abuse (18 U.S.C. \u00a7 1030(a)(2)(C), (a)(4)), designed to conceal the nature, location, source, ownership, and control of the proceeds. Source: PACER Doc 89 (information), Count One",
      "cryptoinv:statuteCitation": "18 U.S.C. \u00a7 1956(h)",
      "cryptoinv:countNumber": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "1"
      },
      "cryptoinv:chargeDescription": "Money Laundering Conspiracy"
    },
    {
      "@id": "urn:uuid:5ae708a2-baa6-5cc8-9777-e680ed714b36",
