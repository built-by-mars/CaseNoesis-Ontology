    {
      "@id": "urn:uuid:3ba2ffc6-236f-588d-b883-c8b11af2b09f",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 3 (Chen): Smuggling of Goods (18 U.S.C. \u00a7\u00a7 554 and 2)",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7\u00a7 554 and 2",
      "legalproc:countNumber": {
