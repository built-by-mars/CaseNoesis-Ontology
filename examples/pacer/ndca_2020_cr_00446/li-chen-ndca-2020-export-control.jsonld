    {
      "@id": "urn:uuid:921db28e-6b44-54f7-bc96-ccc0dcc98194",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 1 (Chen): Conspiracy to Violate IEEPA (50 U.S.C. \u00a7 1705 and 15 C.F.R. \u00a7 764.2(d))",
      "legalproc:statuteCitation": "50 U.S.C. \u00a7 1705 and 15 C.F.R. \u00a7 764.2(d)",
      "legalproc:countNumber": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "1"
      },
      "legalproc:countLabel": "Count 1",
      "legalproc:offenseForm": "conspiracy",
      "legalproc:chargeDisposition": "dismissed",
      "legalproc:assertedIn": [
        {
          "@id": "urn:uuid:d2588b50-fe14-5fa0-8edf-4373e7c2f284"
        }
      ],
      "uco-core:description": "Beginning no later than May 13, 2015, and continuing through at least August 13, 2018, Li, Chen, and others conspired to export, re-export, and supply goods and services from the United States to Chengdu GaStone Technology Co. and other end users in the PRC without a license and in violation of the DOC Entity List. Objects: purchase items from the United States and ship them to Entity List entities through intermediary companies such as JHI to conceal the nature of the exports and the true end users. Dismissed as to Chen by government oral motion at sentencing on 2025-01-28. Source: PACER Doc 1 (indictment), counts; Source: PACER Doc docket sheet (docket), count chart"
    },
    {
      "@id": "urn:uuid:c1d2698b-3f6d-5445-a2c8-18c505701710",
      "@type": "uco-core:Relationship",
      "uco-core:source": [
        {
          "@id": "urn:uuid:2b2e1372-64e4-5055-9939-abc65bb71348"
        }
      ],
      "uco-core:target": [
        {
          "@id": "urn:uuid:921db28e-6b44-54f7-bc96-ccc0dcc98194"
        }
      ],
      "uco-core:kindOfRelationship": "Charged_With",
      "uco-core:isDirectional": {
        "@type": "xsd:boolean",
        "@value": "true"
      }
    },
    {
      "@id": "urn:uuid:91560151-25b7-5b4d-aca7-3e74dc02a092",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 1 (Li): Conspiracy to Violate IEEPA (50 U.S.C. \u00a7 1705 and 15 C.F.R. \u00a7 764.2(d))",
      "legalproc:statuteCitation": "50 U.S.C. \u00a7 1705 and 15 C.F.R. \u00a7 764.2(d)",
      "legalproc:countNumber": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "1"
      },
      "legalproc:countLabel": "Count 1",
      "legalproc:offenseForm": "conspiracy",
      "legalproc:chargeDisposition": "pending",
      "legalproc:assertedIn": [
        {
          "@id": "urn:uuid:d2588b50-fe14-5fa0-8edf-4373e7c2f284"
        }
      ],
      "uco-core:description": "Beginning no later than May 13, 2015, and continuing through at least August 13, 2018, Li, Chen, and others conspired to export, re-export, and supply goods and services from the United States to Chengdu GaStone Technology Co. and other end users in the PRC without a license and in violation of the DOC Entity List. Objects: purchase items from the United States and ship them to Entity List entities through intermediary companies such as JHI to conceal the nature of the exports and the true end users. Pending as to Han Li; no disposition on the docket. Source: PACER Doc 1 (indictment), counts; Source: PACER Doc docket sheet (docket), count chart"
    },
    {
      "@id": "urn:uuid:412c25c1-be48-5931-9a3e-f943282fc6a3",
      "@type": "uco-core:Relationship",
      "uco-core:source": [
        {
          "@id": "urn:uuid:9d4a0671-06f6-51a9-aa52-85e2f5d9efad"
        }
      ],
      "uco-core:target": [
        {
          "@id": "urn:uuid:91560151-25b7-5b4d-aca7-3e74dc02a092"
        }
      ],
      "uco-core:kindOfRelationship": "Charged_With",
      "uco-core:isDirectional": {
        "@type": "xsd:boolean",
        "@value": "true"
      }
    },
    {
      "@id": "urn:uuid:bcc268d8-d76d-5b1b-8f32-451679193b48",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 2 (Chen): Unlawful Export Information Activities (13 U.S.C. \u00a7 305 and 18 U.S.C. \u00a7 2)",
      "legalproc:statuteCitation": "13 U.S.C. \u00a7 305 and 18 U.S.C. \u00a7 2",
      "legalproc:countNumber": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "2"
      },
      "legalproc:countLabel": "Count 2",
      "legalproc:offenseForm": "substantive",
      "legalproc:chargeDisposition": "dismissed",
      "legalproc:assertedIn": [
        {
          "@id": "urn:uuid:d2588b50-fe14-5fa0-8edf-4373e7c2f284"
        }
      ],
      "uco-core:description": "On or about December 4, 2015, Li and Chen knowingly submitted and caused submission of false and misleading electronic export information (EEI) through the Automated Export System (AES), stating no license was required and that the ultimate consignee for the export of a DTX-150 Automatic Diamond Scriber Breaker was Jiangsu Hantang International Trade Group Corp. Ltd. in Nanjing, when the true ultimate end user and consignee was Chengdu GaStone Technology Co. Dismissed as to Chen by government oral motion at sentencing on 2025-01-28. Source: PACER Doc 1 (indictment), counts; Source: PACER Doc docket sheet (docket), count chart"
    },
    {
      "@id": "urn:uuid:98f92a91-db7a-5833-a8e9-678d6ef8e91f",
