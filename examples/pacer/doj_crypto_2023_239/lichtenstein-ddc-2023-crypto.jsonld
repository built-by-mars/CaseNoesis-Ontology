    {
      "@id": "urn:uuid:1cbda294-8f3c-5a9e-9c24-4a6085a07014",
      "@type": [
        "cryptoinv:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 2: Conspiracy To Commit Money Laundering",
      "uco-core:description": "Morgan conspired (August 2016 - February 2022) with Lichtenstein to violate 18 U.S.C. \u00a7 1956(a)(1)(B)(i) by laundering proceeds of the Bitfinex hack. Source: PACER Doc 89 (information), Count Two",
      "cryptoinv:statuteCitation": "18 U.S.C. \u00a7 371",
      "cryptoinv:countNumber": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "2"
      },
      "cryptoinv:chargeDescription": "Conspiracy To Commit Money Laundering"
    },
