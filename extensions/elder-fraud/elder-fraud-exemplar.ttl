	a time:ProperInterval ;
	time:hasBeginning cg:instant-2022-01-01 ;
	time:hasEnd cg:instant-2023-05-31 .
cg:instant-2022-01-01 a time:Instant ; time:inXSDDateTimeStamp "2022-01-01T00:00:00Z"^^xsd:dateTimeStamp .
cg:instant-2023-05-31 a time:Instant ; time:inXSDDateTimeStamp "2023-05-31T23:59:00Z"^^xsd:dateTimeStamp .

cg:phase-agawam-1
	a traj:PhaseAssertion ;
	uco-core:name "Occupancy assertion 0 (Agawam trajectory)" ;
	uco-core:description "Opener cold-call: grandchild-in-trouble persona via VoIP, fixed opener script, and isolation line 'keep this between us until i get out.' Fed by exogenous victim-list purchase (pre-s0). Source: Aff." ;
	traj:assertsState ef:InitialContact ;
	traj:atInterval cg:interval-2023-02 ;
	traj:sequenceIndex "0"^^xsd:nonNegativeInteger ;
	prov:wasDerivedFrom
		cg:evidence-call-center-scripts ,
		cg:evidence-victim-list-purchase ;
	uco-core:hasFacet cg:confidence-agawam-1 .

cg:phase-agawam-2
	a traj:PhaseAssertion ;
	uco-core:name "Occupancy assertion 1 (Agawam trajectory)" ;
	uco-core:description "Closer follow-up: Aff. states closers impersonated attorneys for the grandchildren (bail/fee demand / emotional conditioning). Secrecy language is NOT attributed here — Aff. places 'keep this between us' in the opener script. Payment-mechanism logistics are the next phase (a_direct). Source: Aff." ;
	traj:assertsState ef:Conditioning ;
	traj:atInterval cg:interval-2023-02 ;
	traj:sequenceIndex "1"^^xsd:nonNegativeInteger ;
	prov:wasDerivedFrom cg:evidence-call-center-scripts ;
	uco-core:hasFacet cg:confidence-agawam-2 .

cg:phase-agawam-3
	a traj:PhaseAssertion ;
	uco-core:name "Occupancy assertion 2 (Agawam trajectory)" ;
	uco-core:description "Closer payment-mechanism direction: Aff. closers 'directed the victims to send or deliver cash'; for the Agawam victim that meant handing a cash package (framed as 'documents') to a rideshare driver at the home — the pivot from conditioning into logistics. Source: Aff." ;
	traj:assertsState ef:ExtractionInstruction ;
	traj:atInterval cg:interval-2023-02 ;
	traj:sequenceIndex "2"^^xsd:nonNegativeInteger ;
	prov:wasDerivedFrom
		cg:evidence-payment-direction ,
		cg:evidence-agawam-victim-instruction ;
	uco-core:hasFacet cg:confidence-agawam-3 .

cg:phase-agawam-4
	a traj:PhaseAssertion ;
	uco-core:name "Occupancy assertion 3 (Agawam trajectory)" ;
	uco-core:description "Runner (Baez Santana / Silverio Balbuena) co-opts an unwitting Lyft driver to collect the victim's cash package at the Agawam address and deliver it to the runners' location. Source: Aff." ;
	traj:assertsState ef:ProceedsCollection ;
	traj:atInterval cg:interval-2023-02 ;
	traj:sequenceIndex "3"^^xsd:nonNegativeInteger ;
	prov:wasDerivedFrom cg:evidence-agawam-coopt ;
	uco-core:hasFacet cg:confidence-agawam-4 .

cg:phase-agawam-5
	a traj:PhaseAssertion ;
	uco-core:name "Occupancy assertion 4 (Agawam trajectory)" ;
	uco-core:description "Collected proceeds enter structured deposit into a purported-business Bank of America account (general laundering pipeline; not a per-pickup-traced deposit record). Source: Aff." ;
	traj:assertsState ef:Laundering ;
	traj:atInterval cg:interval-laundering-window ;
	traj:sequenceIndex "4"^^xsd:nonNegativeInteger ;
	prov:wasDerivedFrom cg:evidence-laundering-pipeline ;
	uco-core:hasFacet cg:confidence-agawam-5 .

cg:phase-agawam-6
	a traj:PhaseAssertion ;
	uco-core:name "Occupancy assertion 5 (Agawam trajectory)" ;
	uco-core:description "Cross-border transmission of deposited/hand-delivered proceeds to the Dominican Republic via NUÑEZ NUÑEZ's eight-percent transmitter network — modeled offense endpoint. Source: Aff." ;
	traj:assertsState ef:Completed ;
	traj:atInterval cg:interval-laundering-window ;
	traj:sequenceIndex "5"^^xsd:nonNegativeInteger ;
	traj:isTerminal true ;
	traj:terminalPolarity "completed" ;
	prov:wasDerivedFrom cg:evidence-laundering-pipeline ;
	uco-core:hasFacet cg:confidence-agawam-6 .

cg:trajectory-agawam-2023
	a traj:Trajectory ;
	uco-core:name "Elder-fraud trajectory: Agawam, MA rideshare cash pickup (Feb. 2023)" ;
	uco-core:description "United States v. Castanos Garcia et al., 1:24-cr-10138-LTS (D. Mass.) — full occupancy through Completed (laundering + cross-border transmit); no mid-chain interception for this pickup." ;
	traj:hasPhaseAssertion
		cg:phase-agawam-1 ,
		cg:phase-agawam-2 ,
		cg:phase-agawam-3 ,
		cg:phase-agawam-4 ,
		cg:phase-agawam-5 ,
		cg:phase-agawam-6 .

