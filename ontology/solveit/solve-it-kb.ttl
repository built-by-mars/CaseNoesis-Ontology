:techniqueDFT-1145 a solveit-core:Technique ;
    rdfs:label "DFT-1145: Extract browser extensions artifacts"@en ;
    solveit-core:techniqueDescription "The examination of the extensions installed within a browser" ;
    solveit-core:techniqueID "DFT-1145" ;
