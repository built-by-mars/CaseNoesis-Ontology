    solveit-core:hasPotentialWeakness :weaknessDFW-1052 ;
    solveit-core:hasReference :citationDFCite-1103 ;
    solveit-core:hasSynonym "indexed search" ;
    solveit-core:techniqueDescription "Searching for keywords within a generated index of data in a case" ;
    solveit-core:techniqueID "DFT-1124" ;
    solveit-core:techniqueName "Keyword search (indexed)" .

