      ],
      "uco-core:name": "Thorswap",
      "uco-core:description": "Virtual currency exchange named in the indictment as one the money launderers used to change stolen cryptocurrency into privacy coins such as Monero (XMR) to disguise and conceal the location, ownership, and control of the stolen funds. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), para. 19; Count 3 manner and means",
      "uco-core:tag": [
        "no-kyc-exchange"
