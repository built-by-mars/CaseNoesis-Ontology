    {
      "@id": "urn:uuid:37e3e539-6582-5632-8331-eb0ba9733c3b",
      "@type": "uco-action:Action",
      "uco-core:name": "Invite the Memphis woman to Dallas for a 'business opportunity'",
      "uco-core:description": "In August 2022, Ashley Grayson asked a Memphis woman with whom she had worked in the past to fly to Dallas to discuss a 'business opportunity'. Source: USAO press release, para. 3",
      "uco-action:performer": {
        "@id": "urn:uuid:f343525b-ac3b-5796-8466-167e4308ef07"
      },
      "uco-action:object": [
        {
          "@id": "urn:uuid:92774010-3d0e-59ae-bb35-42093de3aa6f"
        }
      ],
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-08-01T00:00:00-05:00"
      },
      "uco-action:endTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-08-31T00:00:00-05:00"
      }
    },
    {
      "@id": "urn:uuid:dc4b6c87-2aaf-5555-9186-a59183b6d8a8",
      "@type": "uco-core:Relationship",
      "uco-core:source": [
