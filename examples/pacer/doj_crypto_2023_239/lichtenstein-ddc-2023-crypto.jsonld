    {
      "@id": "urn:uuid:c8e2715d-81d7-52f1-9229-cf22c5d376ae",
      "@type": [
        "cryptoinv:SentencingOutcome",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Government sentencing recommendation for Lichtenstein",
      "uco-core:description": "Citing substantial assistance, the government moved under U.S.S.G. \u00a7 5K1.1 for a downward departure and recommended 60 months at offense level 25. The pre-departure Guidelines range at offense level 32, Criminal History Category I, would be 121-151 months. The government also proposed in-kind restitution to Bitfinex of forfeited cryptocurrency collectively valued at more than $6 billion at current prices. Source: PACER Doc 146 (sentencing_memorandum), pp. 1-2 and restitution section",
      "cryptoinv:sentenceStatus": "recommended-government",
      "cryptoinv:sentenceDurationMonths": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "60"
      },
      "cryptoinv:offenseLevel": {
        "@type": "xsd:integer",
        "@value": "25"
      },
      "cryptoinv:guidelineRangeLowMonths": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "121"
      },
      "cryptoinv:guidelineRangeHighMonths": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "151"
      },
      "cryptoinv:sentencingDate": {
        "@type": "xsd:dateTime",
        "@value": "2024-10-15T00:00:00-04:00"
      }
    },
