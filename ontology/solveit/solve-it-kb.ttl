:techniqueDFT-1001 a solveit-core:Technique ;
    rdfs:label "DFT-1001: Triage devices or media"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/DeviceSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/PrioritizedDeviceSet"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1001,
        :weaknessDFW-1002,
        :weaknessDFW-1003 ;
    solveit-core:hasReference :citationDFCite-1115,
        :citationDFCite-1131 ;
    solveit-core:techniqueDescription "Digital forensic triage is a partial forensic examination conducted under (significant) time and resource constraints [DFCite-1115]." ;
    solveit-core:techniqueDetails "Involves the ranking of apprehended digital items in terms of their importance to a case and likelihood that they contain the data required [DFCite-1131]. It can involve multiple techniques to identify devices of most interest such as keyword searching, hash matching, media review etc." ;
    solveit-core:techniqueID "DFT-1001" ;
    solveit-core:techniqueName "Triage devices or media" .

:techniqueDFT-1002 a solveit-core:Technique ;
    rdfs:label "DFT-1002: Copy sectors from storage media"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ReadWriteDeviceInterface"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/WriteProtectedDeviceInterface"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/Bitstream"^^xsd:anyURI ;
    solveit-core:hasExample "FTK Imager",
        "Magnet ACQUIRE",
        "dcfldd" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1004,
        :weaknessDFW-1006,
        :weaknessDFW-1007,
        :weaknessDFW-1013,
        :weaknessDFW-1014,
        :weaknessDFW-1015,
        :weaknessDFW-1016,
        :weaknessDFW-1136,
        :weaknessDFW-1143,
        :weaknessDFW-1278 ;
    solveit-core:hasReference :citationDFCite-1107 ;
    solveit-core:hasSynonym "disk imaging" ;
    solveit-core:techniqueDescription "Copying of sectors from a storage media, typically LBA~0~ to LBA~max~ to a bitstream that can be stored in a image format (DFT-1025)." ;
    solveit-core:techniqueDetails "The process could be applied to a traditional hard disk, SSD, USB stick, or data from an eMMC chip that has been desoldered and placed in a reader. This data needs to be stored as a container file (DFT-1025). Logs would also usually be created recording the details of the imaging process and any errors that occured." ;
    solveit-core:techniqueID "DFT-1002" ;
    solveit-core:techniqueName "Copy sectors from storage media" .

:techniqueDFT-1003 a solveit-core:Technique ;
    rdfs:label "DFT-1003: Copy pages from physical memory"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Memory"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/Bitstream"^^xsd:anyURI ;
    solveit-core:hasExample "FTK Imager" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1029,
        :weaknessDFW-1030,
        :weaknessDFW-1031,
        :weaknessDFW-1032,
        :weaknessDFW-1033 ;
    solveit-core:hasReference :citationDFCite-1025,
        :citationDFCite-1084,
        :citationDFCite-1085 ;
    solveit-core:hasSynonym "Memory imaging",
        "RAM dump",
        "RAM imaging",
        "memory dump" ;
    solveit-core:techniqueDescription "Involves creating a copy of the live memory data of a running system" ;
    solveit-core:techniqueDetails "Collection of Pagefile may also be useful (Kornblum 2007)." ;
    solveit-core:techniqueID "DFT-1003" ;
    solveit-core:techniqueName "Copy pages from physical memory" .

:techniqueDFT-1004 a solveit-core:Technique ;
    rdfs:label "DFT-1004: Collect logical files selectively"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FilteredFileSet"^^xsd:anyURI ;
    solveit-core:hasExample "FTK Imager - allows an AD1 logical container to be created of a selected subset of files within a previewed data source." ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1017,
        :weaknessDFW-1018,
        :weaknessDFW-1019,
        :weaknessDFW-1020,
        :weaknessDFW-1021,
        :weaknessDFW-1022,
        :weaknessDFW-1023,
        :weaknessDFW-1024 ;
    solveit-core:hasSubtechnique :techniqueDFT-1015 ;
    solveit-core:hasSynonym "Logical acquisition",
        "Logical imaging" ;
    solveit-core:techniqueDescription "Views a set of files (typically via direct access from previewing) and acquires a subset of them." ;
    solveit-core:techniqueDetails "This selection of files would subsequently be stored into a container such as a tar/zip file or a forensic image format." ;
    solveit-core:techniqueID "DFT-1004" ;
    solveit-core:techniqueName "Collect logical files selectively" .

:techniqueDFT-1005 a solveit-core:Technique ;
    rdfs:label "DFT-1005: Search a crime scene for relevant physical evidence"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/DeviceSet"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Device"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/location"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1114 ;
    solveit-core:hasReference :citationDFCite-1018,
        :citationDFCite-1044 ;
    solveit-core:hasSynonym "Crime scene examination",
        "Crime scene investigation",
        "Crime scene processing",
        "Incident scene examination",
        "Scene search" ;
    solveit-core:techniqueDescription "The process of 'carefully documenting the conditions at a crime scene and identifying all relevant physical evidence.' (Birzer 2018)." ;
    solveit-core:techniqueDetails """The UK's Forensic Science Regulator (FSR) guidance refers to "Incident scene examination" which takes a holistic approach and considers an incident scene in conjunction with the requirements of an investigation and the criminal justice system. The aim of incident scene examination is to identify and locate, or note the absence of, physical material which has relevance and significance to inform the investigation including, where relevant, the reconstruction of past events.
The techqniue does not restrict to searching for digital devices as other physical objects may be relevant e.g. contain passwords.""" ;
    solveit-core:techniqueID "DFT-1005" ;
    solveit-core:techniqueName "Search a crime scene for relevant physical evidence" .

:techniqueDFT-1008 a solveit-core:Technique ;
    rdfs:label "DFT-1008: Detect the potential existence of digital devices by profiling network traffic"@en ;
    solveit-core:techniqueID "DFT-1008" ;
    solveit-core:techniqueName "Detect the potential existence of digital devices by profiling network traffic" .

:techniqueDFT-1009 a solveit-core:Technique ;
    rdfs:label "DFT-1009: Locate potential digital evidence sources via cloud account identifiers"@en ;
    solveit-core:techniqueID "DFT-1009" ;
    solveit-core:techniqueName "Locate potential digital evidence sources via cloud account identifiers" .

:techniqueDFT-1011 a solveit-core:Technique ;
    rdfs:label "DFT-1011: Store seized devices or media in evidence bags"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Device"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.caseontology.org/case/investigation/exhibitNumber"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Device"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1011" ;
    solveit-core:techniqueName "Store seized devices or media in evidence bags" .

:techniqueDFT-1014 a solveit-core:Technique ;
    rdfs:label "DFT-1014: Document the chain of custody"@en ;
    solveit-core:hasCASEInputClass "https://ontology.caseontology.org/case/investigation/ProvenanceRecord"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.caseontology.org/case/investigation/ProvenanceRecord"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1147 ;
    solveit-core:hasSynonym "CoC",
        "Continuity of evidence" ;
    solveit-core:techniqueDescription "A process that tracks the movement of evidence through its collection, safeguarding, and analysis lifecycle by documenting each person who handled the evidence, the date/time it was collected or transferred, and the purpose for the transfer [DFCite-1147]." ;
    solveit-core:techniqueID "DFT-1014" ;
    solveit-core:techniqueName "Document the chain of custody" .

:techniqueDFT-1015 a solveit-core:Technique ;
    rdfs:label "DFT-1015: Collect logical files selectively based on privacy preserving criteria"@en ;
    solveit-core:hasExample "Cellebrite - Allows filtering by app, data category, and/or by timestamp as to what data is collected.",
        "Odyssey - Allows selective storing of data from mobile devices - https://www.bluelightsdigital.com/odyssey",
        "XRY - Allows filtering by app, data category, and/or by timestamp as to what data is collected." ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1025,
        :weaknessDFW-1026,
        :weaknessDFW-1027,
        :weaknessDFW-1028 ;
    solveit-core:techniqueDescription "Previewing a data source and selecting a subset of the data for collection into a container such as a tar/zip file or a forensic image format for the purposes of protecting the privacy of the complainant or witness." ;
    solveit-core:techniqueID "DFT-1015" ;
    solveit-core:techniqueName "Collect logical files selectively based on privacy preserving criteria" .

:techniqueDFT-1016 a solveit-core:Technique ;
    rdfs:label "DFT-1016: Collect specific pieces of information from a live running device"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Device"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/IPAddress"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/MACAddress"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/NetworkConnection"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Process"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/UserAccount"^^xsd:anyURI ;
    solveit-core:hasExample "ipconfig",
        "netstat",
        "procdump",
        "pslist",
        "psloggedon" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1034,
        :weaknessDFW-1035,
        :weaknessDFW-1036 ;
    solveit-core:hasReference :citationDFCite-1080,
        :citationDFCite-1129 ;
    solveit-core:hasSynonym "Live response data collection",
        "Volatile data collection" ;
    solveit-core:techniqueDescription "Running commands on a live system to collect specific pieces of information e.g. running processes or open ports" ;
    solveit-core:techniqueDetails """Prior to collecting data from the system, pre-stages are described in (Waits et al 2008) as:
- Establish trusted command shell
- Establish method for transmitting and storing the information
""" ;
    solveit-core:techniqueID "DFT-1016" ;
    solveit-core:techniqueName "Collect specific pieces of information from a live running device" .

:techniqueDFT-1017 a solveit-core:Technique ;
    rdfs:label "DFT-1017: Capture network packets"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/NetworkInterface"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/NetworkPacketCapture"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1017" ;
    solveit-core:techniqueName "Capture network packets" .

:techniqueDFT-1018 a solveit-core:Technique ;
    rdfs:label "DFT-1018: Collect data from a remote networked device"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/NetworkConnection"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/ForensicImageContainer"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1018" ;
    solveit-core:techniqueName "Collect data from a remote networked device" .

:techniqueDFT-1019 a solveit-core:Technique ;
    rdfs:label "DFT-1019: Extract a backup from a mobile device"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/MobileDevice"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/DeviceGeneratedBackup"^^xsd:anyURI ;
    solveit-core:hasExample "Extraction of an iOS backup",
        "Use of ADB to generate an Android backup" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1037,
        :weaknessDFW-1038,
        :weaknessDFW-1039,
        :weaknessDFW-1040,
        :weaknessDFW-1041,
        :weaknessDFW-1270 ;
    solveit-core:techniqueDescription "Using the in-built backup capability of a device to extract a subset of its contents" ;
    solveit-core:techniqueID "DFT-1019" ;
    solveit-core:techniqueName "Extract a backup from a mobile device" .

:techniqueDFT-1021 a solveit-core:Technique ;
    rdfs:label "DFT-1021: Extract artifacts from a configuration file"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/configuration/Configuration"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/configuration/ConfigurationEntry"^^xsd:anyURI ;
    solveit-core:hasExample "prefs.js from Firefox" ;
    solveit-core:techniqueDescription "Examination of a file that was designed for storing configuration information for a piece of software (e.g. an application or operating system feature)" ;
    solveit-core:techniqueID "DFT-1021" ;
    solveit-core:techniqueName "Extract artifacts from a configuration file" .

:techniqueDFT-1022 a solveit-core:Technique ;
    rdfs:label "DFT-1022: Capture mobile device screenshots (manually)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/MobileDevice"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/DeviceScreenshotCapture"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1045 ;
    solveit-core:techniqueDescription "An examiner directly manipulates the target mobile device using the device's input interface (i.e., keypads and buttons), and records the content shown on the display of the device. (Fukami et al 2021)" ;
    solveit-core:techniqueDetails "This is the manual version of DFT-1163. The device is controlled manually, and screenshots are captured manually." ;
    solveit-core:techniqueID "DFT-1022" ;
    solveit-core:techniqueName "Capture mobile device screenshots (manually)" .

:techniqueDFT-1023 a solveit-core:Technique ;
    rdfs:label "DFT-1023: Collect data from cloud service via a live web page using credentials"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Credential"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/OnlineService"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/ArchiveFile"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1023" ;
    solveit-core:techniqueName "Collect data from cloud service via a live web page using credentials" .

:techniqueDFT-1024 a solveit-core:Technique ;
    rdfs:label "DFT-1024: Collect data from cloud service via submission of request to service provider"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/OnlineService"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/accountIdentifier"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/ArchiveFile"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1024" ;
    solveit-core:techniqueName "Collect data from cloud service via submission of request to service provider" .

:techniqueDFT-1025 a solveit-core:Technique ;
    rdfs:label "DFT-1025: Store bitstream data in a forensic image format"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/Bitstream"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/PhysicalImageContainer"^^xsd:anyURI ;
    solveit-core:hasExample "2009 M57-Jean - Data is supplied as a ‘multi-volume Expert Witness file’ - i.e. split EnCase E01 & E02 image files (https://digitalcorpora.org/corpora/scenarios/m57-jean/)",
        "FTK Imager: This tool can be used to acquire data from block devices in various image formats including RAW, EWF, and AFF",
        "Magnet Acquire: This tool can be used to acquire data from block devices in various image formats including RAW and EWF.",
        "libewf: This open source library allows access to the EWF format. The accompanying ewftools proves tools to verify, inspect and create EWF images. " ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1043 ;
    solveit-core:hasSynonym "store disk image container",
        "store image file",
        "write data to a disk image container",
        "write data to a forensic image format" ;
    solveit-core:techniqueDescription "Storage of bitstream data recovered from a digital device" ;
    solveit-core:techniqueDetails "The storage of bitstream data resulting from disk imaging, in formats such as: EWF, AFF4. The imaged data may be split into several linked container formats. e.g. e01, e02 e03 etc. This technique represents storage of data in container formats, whereas DFT-1178 represents data stored in raw files. " ;
    solveit-core:techniqueID "DFT-1025" ;
    solveit-core:techniqueName "Store bitstream data in a forensic image format" .

:techniqueDFT-1026 a solveit-core:Technique ;
    rdfs:label "DFT-1026: Store data in standard archive format"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/DeviceGeneratedBackup"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/FileSystemExtraction"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/ArchiveFile"^^xsd:anyURI ;
    solveit-core:hasExample "RAR",
        "TAR",
        "ZIP" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1165,
        :weaknessDFW-1275 ;
    solveit-core:techniqueDescription "Storing acquired data in a standard archive format such as rar, tar or zip" ;
    solveit-core:techniqueDetails "This is commonly used with mobile file system extractions, but mobile backups can also sometimes be compressed into an archive." ;
    solveit-core:techniqueID "DFT-1026" ;
    solveit-core:techniqueName "Store data in standard archive format" .

:techniqueDFT-1027 a solveit-core:Technique ;
    rdfs:label "DFT-1027: Read data from a device using JTAG"@en ;
    solveit-core:techniqueID "DFT-1027" ;
    solveit-core:techniqueName "Read data from a device using JTAG" .

:techniqueDFT-1028 a solveit-core:Technique ;
    rdfs:label "DFT-1028: Physically remove a storage chip from a device (chip-off)"@en ;
    solveit-core:hasSynonym "chip-off" ;
    solveit-core:techniqueID "DFT-1028" ;
    solveit-core:techniqueName "Physically remove a storage chip from a device (chip-off)" .

:techniqueDFT-1029 a solveit-core:Technique ;
    rdfs:label "DFT-1029: Read data from a desoldered eMMC via a chip reader"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/Bitstream"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1029" ;
    solveit-core:techniqueName "Read data from a desoldered eMMC via a chip reader" .

:techniqueDFT-1030 a solveit-core:Technique ;
    rdfs:label "DFT-1030: Read data from unmanaged NAND"@en ;
    solveit-core:techniqueDetails "Data read in this way will need decoding to be made accessible, e.g. via DFT-1029" ;
    solveit-core:techniqueID "DFT-1030" ;
    solveit-core:techniqueName "Read data from unmanaged NAND" .

:techniqueDFT-1031 a solveit-core:Technique ;
    rdfs:label "DFT-1031: Recover encryption/decryption key from memory"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/DecryptionKey"^^xsd:anyURI ;
    solveit-core:hasExample "Bulk Extractor - of the many scanners within bulk extractor, one of which attempts to locate AES keys.",
        "Volatility - the plug in ‘trucryptmaster’ attempts to recover Truecrypt 7.1a master keys." ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1044,
        :weaknessDFW-1045 ;
    solveit-core:hasReference :citationDFCite-1053,
        :citationDFCite-1054,
        :citationDFCite-1056 ;
    solveit-core:techniqueDescription "This describes the technique whereby an attempt is made to extract key material from memory, or a memory acquisition of a running system to fascinate the decryption of some data " ;
    solveit-core:techniqueID "DFT-1031" ;
    solveit-core:techniqueName "Recover encryption/decryption key from memory" .

:techniqueDFT-1032 a solveit-core:Technique ;
    rdfs:label "DFT-1032: Recover encryption/decryption key information using side channel attacks"@en ;
    solveit-core:techniqueID "DFT-1032" ;
    solveit-core:techniqueName "Recover encryption/decryption key information using side channel attacks" .

:techniqueDFT-1036 a solveit-core:Technique ;
    rdfs:label "DFT-1036: Recover information about a potential device PIN or pattern lock using a smudge attack"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/UnlockPattern"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1036" ;
    solveit-core:techniqueName "Recover information about a potential device PIN or pattern lock using a smudge attack" .

:techniqueDFT-1038 a solveit-core:Technique ;
    rdfs:label "DFT-1038: Attack a stored credential or device using a rainbow table-based approach"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/password"^^xsd:anyURI ;
    solveit-core:hasSynonym "rainbow table attack" ;
    solveit-core:techniqueID "DFT-1038" ;
    solveit-core:techniqueName "Attack a stored credential or device using a rainbow table-based approach" .

:techniqueDFT-1039 a solveit-core:Technique ;
    rdfs:label "DFT-1039: Downgrade apps to facilitate data extraction"@en ;
    solveit-core:hasReference :citationDFCite-1139,
        :citationDFCite-1142 ;
    solveit-core:techniqueDescription "Downgrading an app to a version in which data is available e.g. via a backup method" ;
    solveit-core:techniqueID "DFT-1039" ;
    solveit-core:techniqueName "Downgrade apps to facilitate data extraction" .

:techniqueDFT-1041 a solveit-core:Technique ;
    rdfs:label "DFT-1041: Gain access to a device via a Pin2Pwn approach"@en ;
    solveit-core:techniqueID "DFT-1041" ;
    solveit-core:techniqueName "Gain access to a device via a Pin2Pwn approach" .

:techniqueDFT-1043 a solveit-core:Technique ;
    rdfs:label "DFT-1043: Read bitstream from forensic image container file(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/PhysicalImageContainer"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/BitstreamRandomAccessed"^^xsd:anyURI ;
    solveit-core:hasExample "Advanced Forensic Format (AFF)",
        "Expert Witness Format (EWF)" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1121,
        :weaknessDFW-1122,
        :weaknessDFW-1123,
        :weaknessDFW-1259 ;
    solveit-core:hasSynonym "Access forensic image",
        "Access forensic image content",
        "Decode forensic image bitstream",
        "Read forensic format",
        "Read forensic image" ;
    solveit-core:techniqueDescription "The decoding of a forensic format such as EWF such that the raw sectors can be accessed by a forensic tool (typically performed on-the-fly internally in a tool.)" ;
    solveit-core:techniqueDetails "For example a EWF (Expert Witness Format) needs to be processed to expose the equivalent RAW image sectors." ;
    solveit-core:techniqueID "DFT-1043" ;
    solveit-core:techniqueName "Read bitstream from forensic image container file(s)" .

:techniqueDFT-1044 a solveit-core:Technique ;
    rdfs:label "DFT-1044: Decode data stored in a mobile backup format"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/DeviceGeneratedBackup"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasExample "adb backup decoding",
        "iOS backup decoding" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1046,
        :weaknessDFW-1047,
        :weaknessDFW-1048,
        :weaknessDFW-1049,
        :weaknessDFW-1050,
        :weaknessDFW-1051 ;
    solveit-core:techniqueDescription "Processing an extracted mobile device backup to access the files contained within." ;
    solveit-core:techniqueID "DFT-1044" ;
    solveit-core:techniqueName "Decode data stored in a mobile backup format" .

:techniqueDFT-1045 a solveit-core:Technique ;
    rdfs:label "DFT-1045: Read contents from standard archive file(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/ArchiveFile"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1185 ;
    solveit-core:techniqueDescription "Extract files from a common archive format e.g. TAR, RAR, ZIP" ;
    solveit-core:techniqueID "DFT-1045" ;
    solveit-core:techniqueName "Read contents from standard archive file(s)" .

:techniqueDFT-1046 a solveit-core:Technique ;
    rdfs:label "DFT-1046: Redact digital forensic tool results to protect privileged material"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/RedactedArtifactSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/RedactedFileSet"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1046" ;
    solveit-core:techniqueName "Redact digital forensic tool results to protect privileged material" .

:techniqueDFT-1047 a solveit-core:Technique ;
    rdfs:label "DFT-1047: Filter files using a hashset to reduce files examined"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/HashSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/RedactedFileSet"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1132 ;
    solveit-core:hasSynonym "hash matching (reduce)" ;
    solveit-core:techniqueDescription "After hashing a set of files, compare the hashes against a known hashset to identify and remove known files from further examination." ;
    solveit-core:techniqueID "DFT-1047" ;
    solveit-core:techniqueName "Filter files using a hashset to reduce files examined" .

:techniqueDFT-1048 a solveit-core:Technique ;
    rdfs:label "DFT-1048: Protect privacy by only partially processing data from a source"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/RedactedArtifactSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/RedactedFileSet"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1037 ;
    solveit-core:techniqueDescription "Limiting the scope of file processing based on type, date or other criteria to protect privacy." ;
    solveit-core:techniqueDetails "The files may still be present in the data set or removed, or made inaccessible, but the core of the technique is to provide a limited set of artifacts, compared with full processing." ;
    solveit-core:techniqueID "DFT-1048" ;
    solveit-core:techniqueName "Protect privacy by only partially processing data from a source" .

:techniqueDFT-1049 a solveit-core:Technique ;
    rdfs:label "DFT-1049: Keyword search"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/KeywordSearchResult"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1053,
        :weaknessDFW-1058,
        :weaknessDFW-1059,
        :weaknessDFW-1196 ;
    solveit-core:hasReference :citationDFCite-1013,
        :citationDFCite-1014,
        :citationDFCite-1103 ;
    solveit-core:hasSubtechnique :techniqueDFT-1122,
        :techniqueDFT-1123,
        :techniqueDFT-1124,
        :techniqueDFT-1125,
        :techniqueDFT-1126,
        :techniqueDFT-1127,
        :techniqueDFT-1151 ;
    solveit-core:hasSynonym "string search" ;
    solveit-core:techniqueDescription "This technique involves searching data in the case for specific strings" ;
    solveit-core:techniqueDetails "This search may be conducted live, directly over the data, or from a generated index of strings extracted from the data. The words searched for may be either case-specific, or sometimes case-type specific." ;
    solveit-core:techniqueID "DFT-1049" ;
    solveit-core:techniqueName "Keyword search" .

:techniqueDFT-1050 a solveit-core:Technique ;
    rdfs:label "DFT-1050: Locate relevant files using a hashset to identify files of interest"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/HashSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FilteredFileSet"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1132 ;
    solveit-core:hasSynonym "Hash matching (locate)" ;
    solveit-core:techniqueID "DFT-1050" ;
    solveit-core:techniqueName "Locate relevant files using a hashset to identify files of interest" .

:techniqueDFT-1051 a solveit-core:Technique ;
    rdfs:label "DFT-1051: Locate potentially relevant files using fuzzy hash matching"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FilteredFileSet"^^xsd:anyURI ;
    solveit-core:techniqueID "DFT-1051" ;
    solveit-core:techniqueName "Locate potentially relevant files using fuzzy hash matching" .

:techniqueDFT-1052 a solveit-core:Technique ;
    rdfs:label "DFT-1052: Generate timeline"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/Timeline"^^xsd:anyURI ;
    solveit-core:hasExample "plaso" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1144,
        :weaknessDFW-1145,
        :weaknessDFW-1146,
        :weaknessDFW-1147,
        :weaknessDFW-1151,
        :weaknessDFW-1269 ;
    solveit-core:hasReference :citationDFCite-1039,
        :citationDFCite-1058 ;
    solveit-core:hasSubtechnique :techniqueDFT-1153 ;
    solveit-core:hasSynonym "timeline generation",
        "timelining" ;
    solveit-core:techniqueDescription "The extraction and normalisation of timestamps from a data source into a set of timeline entries" ;
    solveit-core:techniqueID "DFT-1052" ;
    solveit-core:techniqueName "Generate timeline" .

:techniqueDFT-1053 a solveit-core:Technique ;
    rdfs:label "DFT-1053: Extract 'entities' from a data source"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/BitstreamRandomAccessed"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI ;
    solveit-core:hasExample "bulk extractor" ;
    solveit-core:hasSynonym "entity extraction" ;
    solveit-core:techniqueDescription "Extracting common types of entity in a data source e.g. email addresses, IP addresses, domain names, URLs, credit card numbers, etc." ;
    solveit-core:techniqueID "DFT-1053" ;
    solveit-core:techniqueName "Extract 'entities' from a data source" .

:techniqueDFT-1054 a solveit-core:Technique ;
    rdfs:label "DFT-1054: Review artifacts or content manually for relevant material"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/analysis/ArtifactClassification"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1060,
        :weaknessDFW-1061,
        :weaknessDFW-1062 ;
    solveit-core:techniqueDescription "Manual examination of files or artifacts to determine their relevance to the investigation." ;
    solveit-core:techniqueDetails "The result of this process is a classification, which may be 'relevant', or could be more specific, e.g. 'contains reference to x'. This technique is likely paired with T1091 (Bookmark artifacts) but they could be recorded in other ways. This manual review could be of the content of files (DFT-1058), or of content extracted from within files e.g. images (DFT-1081), video (DFT-1080), or audio (DFT-1079)." ;
    solveit-core:techniqueID "DFT-1054" ;
    solveit-core:techniqueName "Review artifacts or content manually for relevant material" .

:techniqueDFT-1055 a solveit-core:Technique ;
    rdfs:label "DFT-1055: Examine file and folder structure"@en ;
    solveit-core:hasSynonym "Directory structure review" ;
    solveit-core:techniqueDescription "The process of examining the directory hierarchy, file and folder names (rather than file contents) to identify potentially relevant material." ;
    solveit-core:techniqueID "DFT-1055" ;
    solveit-core:techniqueName "Examine file and folder structure" .

:techniqueDFT-1056 a solveit-core:Technique ;
    rdfs:label "DFT-1056: Enumerate connections between artifacts"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/ObservableObject"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/ObservableRelationship"^^xsd:anyURI ;
    solveit-core:hasExample "AXIOM Connections feature" ;
    solveit-core:techniqueDescription "Finds references between artifacts, such as operating system artifacts that refer to a specific file" ;
    solveit-core:techniqueID "DFT-1056" ;
    solveit-core:techniqueName "Enumerate connections between artifacts" .

:techniqueDFT-1057 a solveit-core:Technique ;
    rdfs:label "DFT-1057: Search for indicators of steganography"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/AcquiredData"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1082 ;
    solveit-core:techniqueDescription "Searching for the presence of current or historical steganography software on a system" ;
    solveit-core:techniqueID "DFT-1057" ;
    solveit-core:techniqueName "Search for indicators of steganography" .

:techniqueDFT-1058 a solveit-core:Technique ;
    rdfs:label "DFT-1058: Search for mismatched file extensions"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FilteredFileSet"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1007 ;
    solveit-core:techniqueDescription "Checking the content of a file against its file extension to identify mismatches." ;
    solveit-core:techniqueDetails "This results in a file path of an identified file, but also highlights the extension that the file has, and the file extension(s) that are expected" ;
    solveit-core:techniqueID "DFT-1058" ;
    solveit-core:techniqueName "Search for mismatched file extensions" .

:techniqueDFT-1059 a solveit-core:Technique ;
    rdfs:label "DFT-1059: Identify partitions"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/BitstreamRandomAccessed"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/DiskPartition"^^xsd:anyURI ;
    solveit-core:hasExample "Hargreaves, Nelson and Casey (2024) provides a dataset with a deleted but recoverable partition that can be used for tool evaluation." ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1063,
        :weaknessDFW-1064,
        :weaknessDFW-1065,
        :weaknessDFW-1066,
        :weaknessDFW-1067 ;
    solveit-core:hasReference :citationDFCite-1024,
        :citationDFCite-1106 ;
    solveit-core:hasSynonym "media management analysis" ;
    solveit-core:techniqueDescription "Partitions are defined as ‘allocated contiguous sets of sectors from storage media’. This involves recovering the list of partitions that exist on a storage media." ;
    solveit-core:techniqueDetails """Partitions schemes include: MBR, GPT, APM. Some schemes such as GPT have records of the partitions in a single area (plus a backup partition table), others such as MBR make use of Extended Partition Tables (EPTs) that are scattered throughout the disk.

Partitions can also be deleted but may be recoverable if the start sectors of the volumes contained within them can be identified. """ ;
    solveit-core:techniqueID "DFT-1059" ;
    solveit-core:techniqueName "Identify partitions" .

:techniqueDFT-1060 a solveit-core:Technique ;
    rdfs:label "DFT-1060: Enumerate allocated files and folders"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/FileSystem"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasExample "The Sleuth Kit - allows parsing of file system structures",
        "X-Ways Forensics - allows parsing of file system structures" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1068,
        :weaknessDFW-1069,
        :weaknessDFW-1070,
        :weaknessDFW-1071,
        :weaknessDFW-1072,
        :weaknessDFW-1073,
        :weaknessDFW-1074,
        :weaknessDFW-1075,
        :weaknessDFW-1076,
        :weaknessDFW-1077,
        :weaknessDFW-1078,
        :weaknessDFW-1079,
        :weaknessDFW-1080,
        :weaknessDFW-1081,
        :weaknessDFW-1082,
        :weaknessDFW-1083,
        :weaknessDFW-1084 ;
    solveit-core:hasReference :citationDFCite-1024,
        :citationDFCite-1030 ;
    solveit-core:hasSynonym "file system parsing" ;
    solveit-core:techniqueDescription "This involves parsing the allocated file system data structures and reconstructing the file system of the target media or device." ;
    solveit-core:techniqueID "DFT-1060" ;
    solveit-core:techniqueName "Enumerate allocated files and folders" .

:techniqueDFT-1061 a solveit-core:Technique ;
    rdfs:label "DFT-1061: Recover non-allocated files"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/ContentData"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/FileSystem"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/core/confidence"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Directory"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1133 ;
    solveit-core:hasReference :citationDFCite-1030 ;
    solveit-core:hasSubtechnique :techniqueDFT-1064,
        :techniqueDFT-1150 ;
    solveit-core:hasSynonym "Deleted data recovery",
        "Deleted file recovery" ;
    solveit-core:techniqueDescription "The recovery of files from non-allocated space" ;
    solveit-core:techniqueDetails "An attempt to recover non-allocated files from either a current file system or non-allocated space from within a file system, partition, or storage media." ;
    solveit-core:techniqueID "DFT-1061" ;
    solveit-core:techniqueName "Recover non-allocated files" .

:techniqueDFT-1062 a solveit-core:Technique ;
    rdfs:label "DFT-1062: Decrypt encrypted file systems/volumes"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Image"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Volume"^^xsd:anyURI ;
    solveit-core:techniqueDescription "The process of decrypting an encrypted file system/volume to make its contents accessible for analysis." ;
    solveit-core:techniqueDetails "The output of this process will vary depending on the encryption implementation in place. If encryption is at the sector level then it would result in a decrypted forensic image, but if it uses file-based encryption then the process would result in an equivalent volume but with the file content/metadata decrypted." ;
    solveit-core:techniqueID "DFT-1062" ;
    solveit-core:techniqueName "Decrypt encrypted file systems/volumes" .

:techniqueDFT-1063 a solveit-core:Technique ;
    rdfs:label "DFT-1063: Identify file types"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/analysis/ArtifactClassification"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/mimeType"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1129,
        :weaknessDFW-1130,
        :weaknessDFW-1131 ;
    solveit-core:hasReference :citationDFCite-1040,
        :citationDFCite-1060 ;
    solveit-core:techniqueDescription "Applying a process that identifies the types of files." ;
    solveit-core:techniqueDetails "This could be via extension, although files may have been renamed, and so this is unreliable, so other means such as examining a file signature or other techniques are used (Dubettier et al 2023)" ;
    solveit-core:techniqueID "DFT-1063" ;
    solveit-core:techniqueName "Identify file types" .

:techniqueDFT-1064 a solveit-core:Technique ;
    rdfs:label "DFT-1064: Carve non-allocated files"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/core/confidence"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/rangeOffset"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/rangeOffsetType"^^xsd:anyURI ;
    solveit-core:hasExample "Photorec (Grenier 2023)",
        "foremost",
        "scalpel" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1103,
        :weaknessDFW-1104,
        :weaknessDFW-1105,
        :weaknessDFW-1106,
        :weaknessDFW-1107 ;
    solveit-core:hasReference :citationDFCite-1011,
        :citationDFCite-1048 ;
    solveit-core:hasSynonym "file carving" ;
    solveit-core:techniqueDescription "The process of recovering files from non-allocated space using only the structural properties of files." ;
    solveit-core:techniqueDetails "File carving should result in not just the file content, but the offset in which it was found and the offset base (i.e. the disk, volume, or offset within another file). This approach uses internal files structural information only - if residual file system metadata is used then the complementary technique T1150 is more applicable." ;
    solveit-core:techniqueID "DFT-1064" ;
    solveit-core:techniqueName "Carve non-allocated files" .

:techniqueDFT-1065 a solveit-core:Technique ;
    rdfs:label "DFT-1065: Extract artifacts from operating system-level content indexer(s)"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/fileName"^^xsd:anyURI,
