    {
      "@id": "urn:uuid:9a9f6738-023d-5f12-b528-e89a8777bf41",
      "@type": [
        "uco-identity:Person",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Ilya Lichtenstein",
      "uco-core:description": "Also known as 'Dutch'; citizen of Russia and the United States, resident of New York and/or California. Admitted to hacking the victim exchange and to the money laundering conspiracy. Source: PACER Doc 95 (statement_of_offense), paras. 1, 12-17",
      "cryptoinv:chargedWith": [
        {
          "@id": "urn:uuid:91c55da8-ad04-5bcb-95ed-53f96f149f74"
        }
      ]
    },
    {
      "@id": "urn:uuid:f14eecaf-4771-5399-858e-46521c0cfab0",
      "@type": [
        "uco-identity:Person",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Heather Rhiannon Morgan",
      "uco-core:description": "Citizen of the United States; married Lichtenstein in or around January 2019. Assisted the laundering while initially unaware of the specific origin of the funds; told no later than early 2020 that Lichtenstein was responsible for the 2016 hack. Source: PACER Doc 95 (statement_of_offense), paras. 2-3, 20",
      "cryptoinv:chargedWith": [
        {
          "@id": "urn:uuid:1cbda294-8f3c-5a9e-9c24-4a6085a07014"
        },
        {
          "@id": "urn:uuid:2dd697e4-38ba-5d50-bd81-b9fd7a0c3331"
        }
      ]
    },
    {
      "@id": "urn:uuid:460347c1-cea7-5f92-838a-a8715089364c",
      "@type": [
        "cryptoinv:VirtualAssetServiceProvider",
        "uco-identity:Organization",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Bitfinex",
      "uco-core:description": "The victim virtual currency exchange ('VICTIM VCE'), one of the world's largest virtual currency exchanges, doing business globally. Hacked in August 2016. Source: PACER Doc 95 (statement_of_offense), para. 4"
    },
    {
      "@id": "urn:uuid:e5649fce-5faa-531e-81f2-25f1051163c4",
      "@type": [
        "cryptoinv:DarknetMarket",
        "uco-identity:Organization",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "AlphaBay",
      "uco-core:description": "Darknet market (operated December 2014 - July 2017) used as a pass-through to break up the stolen-BTC trail on the blockchain. Source: PACER Doc 1-1 (statement_of_facts), paras. 11-12 and n.12"
    },
    {
      "@id": "urn:uuid:2fdcfd02-f1e7-5313-8fb1-5ccc3b696a4d",
      "@type": [
        "cryptoinv:DarknetMarket",
        "uco-identity:Organization",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Hydra",
      "uco-core:description": "Darknet marketplace through which stolen funds were moved using multiple segregated input and withdrawal addresses. Source: PACER Doc 95 (statement_of_offense), para. 19"
    },
    {
      "@id": "urn:uuid:173757bc-662d-5f38-8488-aeb09c58cf13",
      "@type": [
        "uco-identity:Organization",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Financial Crimes Enforcement Network (FinCEN)",
      "uco-core:description": "Division of the U.S. Department of the Treasury responsible for implementation, administration, and enforcement of the Bank Secrecy Act; headquartered in Washington, D.C. Object of the Count Three conspiracy to defraud the United States. Source: PACER Doc 1-1 (statement_of_facts), paras. 56-59"
    },
    {
      "@id": "urn:uuid:8ac453b3-8837-56a5-8b1b-1e5cfb21e77e",
      "@type": [
        "uco-identity:Organization",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "IRS Criminal Investigation (IRS-CI)",
      "uco-core:description": "Lead tracing agency; affiant Special Agent Christopher Janczewski. Investigated jointly with FBI and HSI. Source: PACER Doc 1-1 (statement_of_facts), paras. 1-3"
    },
    {
      "@id": "urn:uuid:79396170-fead-56be-826a-51c8939b60dd",
      "@type": [
        "cryptoinv:CryptocurrencyMixingService",
        "uco-identity:Organization",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Bitcoin Fog",
      "uco-core:description": "Cryptocurrency mixing service used to launder a portion of the stolen funds. Source: PACER Doc 95 (statement_of_offense), para. 19"
    },
    {
      "@id": "urn:uuid:3f151420-b11b-59cd-8218-013a744277d4",
      "@type": [
        "cryptoinv:CryptocurrencyMixingService",
        "uco-identity:Organization",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Helix",
      "uco-core:description": "Cryptocurrency mixing service used to launder a portion of the stolen funds. Source: PACER Doc 95 (statement_of_offense), para. 19"
    },
    {
      "@id": "urn:uuid:dc38e7e7-c4ab-5931-88a1-d35ecba22d22",
      "@type": [
        "cryptoinv:CryptocurrencyMixingService",
        "uco-identity:Organization",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "ChipMixer",
      "uco-core:description": "Cryptocurrency mixing service used to launder a portion of the stolen funds. Source: PACER Doc 95 (statement_of_offense), para. 19"
    },
    {
      "@id": "urn:uuid:92e2e443-fc67-55e6-8a57-4ca2a850f5cf",
      "@type": "uco-core:Relationship",
