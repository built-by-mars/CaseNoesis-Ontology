    {
      "@id": "urn:uuid:fb34cdfd-c6e1-5cf4-a67f-0310e4ddbeef",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 1: Conspiracy to Murder a Federal Officer and Employee",
      "uco-core:description": "Beginning at least as early as 2022-08-20 and continuing through 2022-10-07, Perry and O'Dell conspired to kill officers and employees of the United States \u2014 specifically U.S. Border Patrol agents who would attempt to stop them from shooting at immigrants at the United States - Mexico border \u2014 and to acquire supplies from murdered agents. Overt acts are detailed in paragraphs 12-42. Source: PACER Doc 48 (indictment3), Count 1, paras. 43-49",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7\u00a7 1117 & 1114",
      "legalproc:countLabel": "Count 1",
      "legalproc:countNumber": [
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "1"
        }
      ],
      "legalproc:offenseForm": "conspiracy",
      "legalproc:chargeClassification": "Class A Felony",
      "legalproc:chargeDisposition": [
        "convicted-by-verdict"
      ],
      "legalproc:assertedIn": [
        {
          "@id": "urn:uuid:4f417072-1ae7-5cad-996e-feec2286f2d5"
        }
      ]
    },
    {
      "@id": "urn:uuid:10a6f019-bdf5-576e-b5df-93a495c97c4d",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 2: Conspiracy to Assault a Federal Officer and Employee",
      "uco-core:description": "Conspiracy to forcibly assault, resist, oppose, impede, intimidate, or interfere with U.S. Border Patrol officers and employees engaged in official duties. Source: PACER Doc 48 (indictment3), Count 2, paras. 50-56",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7\u00a7 371 & 111(a)(1)",
      "legalproc:countLabel": "Count 2",
      "legalproc:countNumber": [
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "2"
        }
      ],
      "legalproc:offenseForm": "conspiracy",
      "legalproc:chargeClassification": "Class D Felony",
      "legalproc:chargeDisposition": [
        "convicted-by-verdict"
      ],
      "legalproc:assertedIn": [
        {
          "@id": "urn:uuid:4f417072-1ae7-5cad-996e-feec2286f2d5"
        }
      ]
    },
    {
      "@id": "urn:uuid:21ce5d41-27ec-50d0-b0dd-1e9f6b4d1d60",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 3: Conspiracy to Injure Officer",
      "uco-core:description": "Conspiracy to injure officers and employees of the United States on account of, or during, the lawful discharge of their duties; manner and means included preparing for travel to Texas, recruiting participants, staging firearms and paramilitary gear in Warsaw, Missouri, and using force against FBI Special Agents. Source: PACER Doc 48 (indictment3), Count 3, paras. 57-60",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 372",
      "legalproc:countLabel": "Count 3",
      "legalproc:countNumber": [
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "3"
        }
      ],
      "legalproc:offenseForm": "conspiracy",
      "legalproc:chargeClassification": "Class D Felony",
      "legalproc:chargeDisposition": [
        "convicted-by-verdict"
      ],
      "legalproc:assertedIn": [
        {
          "@id": "urn:uuid:4f417072-1ae7-5cad-996e-feec2286f2d5"
        }
      ]
    },
    {
      "@id": "urn:uuid:2185d2b6-076f-528c-8271-3580bd55dd4a",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Counts 4-10: Attempted Murder of a Federal Officer and Employee",
      "uco-core:description": "On 2022-10-07 in Benton County, Missouri, the defendants attempted to kill seven FBI Special Agents (victims J.R., J.C., R.G., D.H., C.H., T.R., T.M.), one victim per count, while each agent was engaged in the performance of his duties. Source: PACER Doc 48 (indictment3), Counts 4-10, paras. 61-62",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7\u00a7 1114(a)(3), 1113 & 2",
      "legalproc:countLabel": "Counts 4-10",
      "legalproc:countNumber": [
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "4"
        },
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "5"
        },
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "6"
        },
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "7"
        },
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "8"
        },
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "9"
        },
        {
          "@type": "xsd:nonNegativeInteger",
          "@value": "10"
        }
      ],
      "legalproc:offenseForm": "attempt",
      "legalproc:chargeClassification": "Class C Felony",
      "legalproc:chargeDisposition": [
        "convicted-by-verdict"
      ],
      "legalproc:assertedIn": [
