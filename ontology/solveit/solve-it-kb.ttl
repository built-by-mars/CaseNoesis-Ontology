    solveit-core:hasExample "Spotlight",
        "Windows Search",
        "Zeitgeist" ;
    solveit-core:hasReference :citationDFCite-1100,
        :citationDFCite-1122 ;
    solveit-core:hasSynonym "OS search database examination",
        "operating system search database examination" ;
    solveit-core:techniqueDescription "Examine information from operating system artifacts relating to content indexing and search capabilities e.g. Windows Desktop Search" ;
    solveit-core:techniqueDetails "For example the Windows Search database '...contains vast amount of values about various of artifacts found on a Windows system, e.g. files and directories, emails, appointments, attachments, images, audio and video' (Metz 2011)" ;
    solveit-core:techniqueID "DFT-1065" ;
    solveit-core:techniqueName "Extract artifacts from operating system-level content indexer(s)" .

:techniqueDFT-1066 a solveit-core:Technique ;
