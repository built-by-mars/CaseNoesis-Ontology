      ],
      "uco-core:name": "Nicolas Dellecave \u2014 Count 2: Conspiracy to Commit Wire Fraud",
      "uco-core:description": "Conspiring to commit wire fraud by devising a scheme to defraud and obtain money, property, and cryptocurrency from Victim-1 through Victim-9 and others by materially false and fraudulent pretenses, causing interstate wire transmissions in execution of the scheme. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), Count Two, paras. 38-39 Pending as of the docket printout.",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 1349",
