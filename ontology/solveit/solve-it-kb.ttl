    solveit-core:techniqueDetails "An AI companion is defined as \"a type of generative AI-based conversational agent (CA) explicitly designed for companionship and friendship with a human user (Strohmann et al. 2022; Pentina et al. 2023)\" (Bayor et al 2025)." ;
    solveit-core:techniqueID "DFT-1133" ;
    solveit-core:techniqueName "Extract artifacts from AI companion app(s)" .

:techniqueDFT-1137 a solveit-core:Technique ;
    rdfs:label "DFT-1137: Extract browser history artifacts"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/BrowserAppFiles"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/URLHistory"^^xsd:anyURI ;
    solveit-core:hasExample "History for Chrome",
        "places.sqlite for Firefox" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1108,
        :weaknessDFW-1109,
        :weaknessDFW-1110,
        :weaknessDFW-1111,
        :weaknessDFW-1112,
        :weaknessDFW-1243,
        :weaknessDFW-1244,
        :weaknessDFW-1245,
        :weaknessDFW-1246 ;
    solveit-core:hasSynonym "internet history examination",
        "web history examination" ;
    solveit-core:techniqueDescription "The examination of the history component of a web browser." ;
    solveit-core:techniqueDetails "Typically this would involve the examination of data in one or more SQLite tables." ;
    solveit-core:techniqueID "DFT-1137" ;
    solveit-core:techniqueName "Extract browser history artifacts" .

