    {
      "@id": "urn:uuid:6ad7a0fe-e9bb-5a27-bd54-3e936aee8dd1",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Nicolas Dellecave \u2014 Count 3: Conspiracy to Launder Monetary Instruments",
      "uco-core:description": "Conspiring to violate 18 U.S.C. \u00a7\u00a7 1956(a)(1)(B)(i) and 1957 \u2014 moving $245,093,239.00 in stolen cryptocurrency, along with other stolen cryptocurrency, through numerous financial transactions designed to conceal the nature, location, source, ownership, and control of the proceeds of the Count Two wire fraud conspiracy. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), Count Three, paras. 40-41 Pending as of the docket printout.",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 1956(h)",
      "legalproc:countNumber": {
