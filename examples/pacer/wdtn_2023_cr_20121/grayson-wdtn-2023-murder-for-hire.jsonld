    {
      "@id": "urn:uuid:f343525b-ac3b-5796-8466-167e4308ef07",
      "@type": "uco-identity:Person",
      "uco-core:name": "Ashley Grayson",
      "uco-core:description": "Defendant 1 (USM 67352-510), 35, of Dallas, Texas. Ran an internet-based business and gained notoriety from her online presence. Offered to pay a Memphis couple to kill three people, each killing valued at $20,000 or more; confirmed the Southaven target in a video-recorded call and paid $10,000 for a staged failed attempt. Convicted by a jury on 2024-03-29 and sentenced to 120 months, the statutory maximum for 18 U.S.C. \u00a7 1958. Source: USAO press release, paras. 1-6; Source: PACER docket, Defendant (1); minute entries 127, 211"
    },
    {
      "@id": "urn:uuid:5212870d-7010-521d-98e2-51fdc2151e8a",
      "@type": "uco-identity:Person",
      "uco-core:name": "Joshua Grayson",
      "uco-core:description": "Defendant 2, husband of Ashley Grayson. Present at the September 2022 Dallas meeting where the killings were solicited and at the later Dallas meeting where the $10,000 was paid. Acquitted by the jury on 2024-03-29 and discharged by judgment of acquittal on 2024-04-04. Source: USAO press release, paras. 3-5; Source: PACER docket, Defendant (2); D.E. 134"
    },
    {
      "@id": "urn:uuid:92774010-3d0e-59ae-bb35-42093de3aa6f",
      "@type": "uco-identity:Person",
      "uco-core:name": "Memphis woman (cooperating witness)",
      "uco-core:description": "Memphis woman who had worked with Ashley Grayson in the past. Asked in August 2022 to fly to Dallas for a 'business opportunity'; solicited with her husband to commit three killings. Video-recorded a 2022-09-10 call in which Grayson confirmed she wanted the Southaven woman killed as soon as possible. With her husband, staged a failed attempt and collected $10,000. Identity not stated in the reviewed documents. Source: USAO press release, paras. 3-5"
    },
    {
      "@id": "urn:uuid:b4744b9f-59b4-5c84-a1a7-9a5019eb9fb8",
      "@type": "uco-identity:Person",
      "uco-core:name": "Memphis woman's husband (cooperating witness)",
      "uco-core:description": "Husband of the Memphis woman; traveled with her to the Dallas meetings, participated in the staged failed attempt, and shared in the $10,000 payment. Identity not stated in the reviewed documents. Source: USAO press release, paras. 3-5"
    },
    {
      "@id": "urn:uuid:4a77fc19-e38f-5826-914d-88a5ecefa828",
      "@type": "uco-identity:Person",
      "uco-core:name": "Southaven, Mississippi woman (intended victim)",
      "uco-core:description": "Operated an online business similar to Ashley Grayson's. After a 2021 falling out, Grayson suspected her of creating fake online profiles that criticized Grayson and her business; the pair never met in person. Primary target of the murder-for-hire plot \u2014 Grayson wanted her killed as soon as possible and offered an extra $5,000 for the murder to be carried out within a week. Source: USAO press release, paras. 2-4"
    },
    {
      "@id": "urn:uuid:2f552c80-9bae-55fa-97eb-f0de81f77e3f",
      "@type": "uco-identity:Person",
      "uco-core:name": "Ashley Grayson's former boyfriend (intended victim)",
      "uco-core:description": "Second person Ashley Grayson offered to pay the Memphis couple to kill, at a value of at least $20,000. Identity not stated in the reviewed documents. Source: USAO press release, para. 3"
    },
    {
      "@id": "urn:uuid:c5945a50-63a3-5180-a395-a4cc3d546634",
      "@type": "uco-identity:Person",
      "uco-core:name": "Texas woman (intended victim)",
      "uco-core:description": "Third person Ashley Grayson offered to pay the Memphis couple to kill; she had recently made negative social media posts about Grayson. Identity not stated in the reviewed documents. Source: USAO press release, para. 3"
    },
    {
      "@id": "urn:uuid:8097f17a-c2b9-5fd2-bb11-76721e996542",
      "@type": "uco-identity:Person",
      "uco-core:name": "Jon Phipps McCalla",
      "uco-core:description": "U.S. District Judge who presided over pretrial proceedings and the March 2024 jury trial, and entered Joshua Grayson's judgment of acquittal. Source: PACER docket, minute entries 114-127; D.E. 134"
    },
    {
      "@id": "urn:uuid:c92e21c3-e7fc-5395-b5f6-8deb506a5919",
      "@type": "uco-identity:Person",
      "uco-core:name": "Thomas L. Parker",
      "uco-core:description": "U.S. District Judge assigned 2024-07-31; imposed Ashley Grayson's sentence on 2024-10-31 and entered judgment. Source: PACER docket, judge update 2024-07-31; D.E. 211, 213"
    },
    {
      "@id": "urn:uuid:227a6b72-439f-5821-a865-174281b2af43",
      "@type": "uco-identity:Person",
      "uco-core:name": "Tu M. Pham",
      "uco-core:description": "Chief Magistrate Judge who conducted the 2023-07-07 initial appearance, set $10,000 unsecured bonds, and arraigned the defendants. Source: PACER docket, minute entries 7, 28"
    },
    {
      "@id": "urn:uuid:fa9fc6ec-dc5e-5582-acad-e089548bbd09",
      "@type": "uco-identity:Person",
      "uco-core:name": "Janelle Hosafros",
      "uco-core:description": "FBI case agent who sat with the government at trial and testified in its case-in-chief. Source: PACER docket, minute entries 114, 121, 126"
    },
    {
      "@id": "urn:uuid:0f8f63c8-09c5-5a2d-b708-59ff8f254a33",
      "@type": "uco-identity:Organization",
      "uco-core:name": "U.S. Attorney's Office, Western District of Tennessee",
      "uco-core:description": "Prosecuting office. Acting U.S. Attorney Reagan Fondren announced the sentence; AUSAs Neal Oldham and Bryce Phillips prosecuted the case. Source: USAO press release, paras. 1, 8-9"
    },
    {
      "@id": "urn:uuid:65b23ff9-f619-5a17-858d-26282e150607",
      "@type": "uco-identity:Organization",
      "uco-core:name": "Federal Bureau of Investigation",
      "uco-core:description": "Investigating agency (Nashville Field Office, Memphis Resident Agency; Special Agent in Charge Joe Carrico). Source: USAO press release, paras. 7-8"
    },
    {
      "@id": "urn:uuid:3069da35-7ffd-5ead-86dd-8121df6546ba",
      "@type": "uco-identity:Organization",
      "uco-core:name": "Bureau of Alcohol, Tobacco, Firearms and Explosives",
      "uco-core:description": "Co-investigating agency. Source: USAO press release, para. 8"
    },
    {
      "@id": "urn:uuid:577265df-6b08-5be4-aed9-c04c93ebc647",
      "@type": "uco-identity:Organization",
      "uco-core:name": "Ashley Grayson's internet-based business",
      "uco-core:description": "Internet-based business run by Ashley Grayson, from which she gained notoriety online; name not stated in the reviewed documents. Source: USAO press release, para. 2"
    },
    {
      "@id": "urn:uuid:09b8ebda-6c63-5ea5-a6ac-2aa08fa26ec1",
      "@type": "uco-identity:Organization",
      "uco-core:name": "Southaven woman's online business",
      "uco-core:description": "Online business similar to Ashley Grayson's, operated by the Southaven, Mississippi woman; name not stated in the reviewed documents. Source: USAO press release, para. 2"
    },
