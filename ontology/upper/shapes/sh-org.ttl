			sh:class org:Post ;
		]
	) ;
	sh:property sh-org:role-subjects-role-shape ;
	sh:targetSubjectsOf org:role ;
	.

sh-org:roleProperty-subjects-roleProperty-shape
	a sh:PropertyShape ;
