      "@id": "urn:uuid:c3ae2a3c-a62c-5f81-b384-6a8f865fb209",
      "@type": [
        "rico:EnterpriseRole",
        "uco-role:Role"
      ],
      "uco-core:name": "SE Enterprise role: caller",
      "uco-core:description": "Callers ('se'ers') were responsible for cold-calling victims and convincing them their accounts were the subject of a cyber-attack and that the caller was attempting to help secure their accounts. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), paras. 25-26, 16, 32",
      "rico:roleFunction": "caller"
    },
    {
      "@id": "urn:uuid:2f848a82-538d-55d3-b2d2-9a3c8e35b3b7",
