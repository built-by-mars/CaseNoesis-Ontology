    {
      "@id": "urn:uuid:a8228cea-a94f-5899-b418-e826e3762363",
      "@type": "uco-action:Action",
      "uco-core:name": "Investigate the murder-for-hire plot",
      "uco-core:description": "The case was investigated by the Federal Bureau of Investigation and the Bureau of Alcohol, Tobacco, Firearms and Explosives; FBI case agent Janelle Hosafros testified at trial. The proactive response from the investigating agencies prevented a more serious crime from occurring. Source: USAO press release, paras. 7-8; Source: PACER docket, minute entries 114-126",
      "uco-action:performer": {
        "@id": "urn:uuid:65b23ff9-f619-5a17-858d-26282e150607"
      },
      "uco-action:object": [
