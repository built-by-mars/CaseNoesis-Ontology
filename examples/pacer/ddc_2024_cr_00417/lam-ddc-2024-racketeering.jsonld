    {
      "@id": "urn:uuid:fc7a4b68-6e3c-592c-84fa-05f63a0a402a",
      "@type": "uco-action:Action",
      "uco-core:name": "Break into Victim-4's New Mexico home in search of hardware wallets",
      "uco-core:description": "On 2024-07-08, COCONSPIRATOR M.F., in coordination with Lam and others, broke into Victim-4's home in search of hardware virtual currency devices, having flown to New Mexico and set up a telephone with a video camera across from the home to livestream the break-in so other enterprise members could alert him if the victim returned. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), overt acts kk-mm",
      "uco-action:performer": {
        "@id": "urn:uuid:04fd1056-9078-5f59-9969-fc066c494e55"
      },
      "uco-action:object": [
        {
