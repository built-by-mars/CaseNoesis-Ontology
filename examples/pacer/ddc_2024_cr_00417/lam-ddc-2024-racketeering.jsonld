      ],
      "uco-core:name": "Cash in brown Louis Vuitton bag totaling $169,700 (forfeiture item C1, currency list)",
      "uco-core:description": "Bulk cash listed as specific property subject to forfeiture. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), forfeiture currency list",
      "uco-core:tag": [
        "forfeiture",
        "bulk-cash"
