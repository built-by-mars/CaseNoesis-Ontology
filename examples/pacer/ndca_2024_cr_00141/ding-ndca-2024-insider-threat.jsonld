      ],
      "uco-core:name": "Rongshu CEO emails Ding a CTO offer (from 2022-06-13)",
      "uco-core:description": "Emails offering the Rongshu CTO position at 100,000 RMB monthly plus bonus and stock, beginning less than one month after Ding's uploads started. Source: PACER Doc 140 (second_superseding_indictment), para. 18",
      "uco-action:performer": {
        "@id": "urn:uuid:fc6776f9-23bf-52ce-8588-e390ad42b15f"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-06-13T00:00:00-07:00"
      }
    },
