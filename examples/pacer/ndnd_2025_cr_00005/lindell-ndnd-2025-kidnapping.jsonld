      }
    },
    {
      "@id": "urn:uuid:f58eff2d-ae25-5817-b4c4-79872f96102a",
      "@type": "uco-action:Action",
      "uco-core:name": "Hold Victim A for ransom and force calls to family and friends",
      "uco-core:description": "Victim A was held for ransom in the amount of the $6,000 debt at the Moorhead residence while one or more individuals ordered him to call his friends and family to ask for money; despite several calls he was unable to raise any funds. Source: PACER Doc 101 (plea), para. 6 factual basis",
      "uco-action:performer": {
        "@id": "urn:uuid:6820f49e-6abe-5bc2-a10c-31b9e922374b"
      },
      "uco-action:object": [
        {
          "@id": "urn:uuid:57f315e6-8aae-5d13-b370-46aecc23eeb0"
        }
      ],
      "uco-action:instrument": [
        {
          "@id": "urn:uuid:22a6f6c1-c4e9-593f-bf1c-3cb9d7903ec7"
        }
      ],
      "uco-action:location": {
        "@id": "urn:uuid:d070be5e-e12f-5035-9164-ddd43b57858e"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2024-03-05T00:00:00-06:00"
      },
      "uco-action:endTime": {
        "@type": "xsd:dateTime",
        "@value": "2024-03-06T00:00:00-06:00"
      }
    },
    {
      "@id": "urn:uuid:2e29c4e8-1761-5de7-a7bc-26cccff92615",
      "@type": "uco-action:Action",
      "uco-core:name": "Victim A escapes the Moorhead residence",
      "uco-core:description": "Maez-Schaack, Altenor, and others eventually left Victim A unattended at the Moorhead residence during daytime March 6, 2024, whereupon Victim A escaped. Source: PACER Doc 101 (plea), para. 6 factual basis",
      "uco-action:performer": {
        "@id": "urn:uuid:57f315e6-8aae-5d13-b370-46aecc23eeb0"
      },
      "uco-action:location": {
