#################################################################
# Machine layer — Transitions + inferred StateMachineModel
#
# traj:enactsAction: arriving-state convention; multi-valued when an edge
# is gated by co-occurring techniques (trajectories SHACL: no maxCount).
#
#   transition-1 InitialContact -> Conditioning:
#     a_spoof, a_script, a_secrecy  (FACT: secrecy is opener-script language)
#   transition-2 Conditioning -> ExtractionInstruction: a_direct
#   transition-3 ExtractionInstruction -> ProceedsCollection: a_coopt
#   transition-4 ProceedsCollection -> Laundering: a_fakeid, a_deposit
#   transition-5 Laundering -> Completed: a_transmit
#################################################################

cg:trigger-opener-call a uco-core:UcoObject ; uco-core:name "Trigger: Opener call placed" .
cg:trigger-closer-directs-cash a uco-core:UcoObject ; uco-core:name "Trigger: Closer directs victim into payment logistics" .
cg:trigger-cash-instruction a uco-core:UcoObject ; uco-core:name "Trigger: victim agrees to send cash" .
cg:trigger-proceeds-routed a uco-core:UcoObject ; uco-core:name "Trigger: collected cash routed to deposit channel" .
cg:trigger-transmit a uco-core:UcoObject ; uco-core:name "Trigger: proceeds handed to transmitter/courier network" .

cg:transition-1
	a traj:Transition ;
	uco-core:name "InitialContact -> Conditioning" ;
	traj:fromState ef:InitialContact ;
	traj:toState ef:Conditioning ;
	traj:trigger cg:trigger-opener-call ;
	traj:enactsAction
		cg:action-spoofed-opener-call ,
		cg:action-deploy-opener-script ,
		cg:action-opener-secrecy .

cg:transition-2
	a traj:Transition ;
	uco-core:name "Conditioning -> ExtractionInstruction" ;
	traj:fromState ef:Conditioning ;
	traj:toState ef:ExtractionInstruction ;
	traj:trigger cg:trigger-closer-directs-cash ;
	traj:enactsAction cg:action-direct-payment-mechanism .

cg:transition-3
	a traj:Transition ;
	uco-core:name "ExtractionInstruction -> ProceedsCollection" ;
	traj:fromState ef:ExtractionInstruction ;
	traj:toState ef:ProceedsCollection ;
	traj:trigger cg:trigger-cash-instruction ;
	traj:enactsAction cg:action-coopt-rideshare-driver .

cg:transition-4
	a traj:Transition ;
	uco-core:name "ProceedsCollection -> Laundering" ;
	traj:fromState ef:ProceedsCollection ;
	traj:toState ef:Laundering ;
	traj:trigger cg:trigger-proceeds-routed ;
	traj:enactsAction
		cg:action-purported-business-account ,
		cg:action-structure-deposits .

cg:transition-5
	a traj:Transition ;
	uco-core:name "Laundering -> Completed" ;
	traj:fromState ef:Laundering ;
	traj:toState ef:Completed ;
	traj:trigger cg:trigger-transmit ;
	traj:enactsAction cg:action-transmit-proceeds .

cg:tool-esm-estimator
	a uco-tool:Tool ;
	uco-core:name "ESM trajectory estimator (illustrative)" ;
	uco-core:description "version 0.1.0-dev" .

cg:action-estimate-transitions
	a uco-action:Action ;
	uco-core:name "Estimate elder-fraud transition probabilities (illustrative)" ;
	uco-action:instrument cg:tool-esm-estimator ;
	prov:wasAssociatedWith cg:tool-esm-estimator .

cg:estimate-1
	a traj:TransitionEstimate ;
	uco-core:name "P(InitialContact -> Conditioning)" ;
	traj:ofTransition cg:transition-1 ;
	traj:transitionProbability "0.93"^^xsd:decimal ;
	traj:sampleBasis "Illustrative estimate for ESM demonstration; not derived from case-specific frequency data."^^xsd:string ;
	prov:wasGeneratedBy cg:action-estimate-transitions .

cg:estimate-2
	a traj:TransitionEstimate ;
	uco-core:name "P(Conditioning -> ExtractionInstruction)" ;
	traj:ofTransition cg:transition-2 ;
	traj:transitionProbability "0.88"^^xsd:decimal ;
	traj:sampleBasis "Illustrative estimate for ESM demonstration; not derived from case-specific frequency data."^^xsd:string ;
	prov:wasGeneratedBy cg:action-estimate-transitions .

cg:estimate-3
	a traj:TransitionEstimate ;
	uco-core:name "P(ExtractionInstruction -> ProceedsCollection)" ;
	traj:ofTransition cg:transition-3 ;
	traj:transitionProbability "0.71"^^xsd:decimal ;
	traj:sampleBasis "Illustrative estimate for ESM demonstration; not derived from case-specific frequency data — this is also the transition disrupted in the Attleboro trajectory."^^xsd:string ;
	prov:wasGeneratedBy cg:action-estimate-transitions .

cg:estimate-4
	a traj:TransitionEstimate ;
	uco-core:name "P(ProceedsCollection -> Laundering)" ;
	traj:ofTransition cg:transition-4 ;
	traj:transitionProbability "0.90"^^xsd:decimal ;
	traj:sampleBasis "Illustrative estimate for ESM demonstration; not derived from case-specific frequency data."^^xsd:string ;
	prov:wasGeneratedBy cg:action-estimate-transitions .

cg:estimate-5
	a traj:TransitionEstimate ;
	uco-core:name "P(Laundering -> Completed)" ;
	traj:ofTransition cg:transition-5 ;
	traj:transitionProbability "0.85"^^xsd:decimal ;
	traj:sampleBasis "Illustrative estimate for ESM demonstration; not derived from case-specific frequency data."^^xsd:string ;
	prov:wasGeneratedBy cg:action-estimate-transitions .

cg:model
	a traj:StateMachineModel ;
	uco-core:name "Elder-fraud (Castanos Garcia) state-machine estimate (v0)" ;
	traj:initialState ef:InitialContact ;
	traj:learnedFrom
		cg:trajectory-agawam-2023 ,
		cg:trajectory-attleboro-2022 ;
	traj:hasTransition
		cg:transition-1 ,
		cg:transition-2 ,
		cg:transition-3 ,
		cg:transition-4 ,
		cg:transition-5 ;
	traj:hasTransitionEstimate
		cg:estimate-1 ,
		cg:estimate-2 ,
		cg:estimate-3 ,
		cg:estimate-4 ,
		cg:estimate-5 ;
	prov:wasGeneratedBy cg:action-estimate-transitions .
