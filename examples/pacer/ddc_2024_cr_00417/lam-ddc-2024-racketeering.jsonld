    {
      "@id": "urn:uuid:d1905388-5249-5aa0-96f1-e8442e00c7be",
      "@type": "uco-action:Action",
      "uco-core:name": "Spend over $4,000,000 in stolen virtual currency at Los Angeles nightclubs",
      "uco-core:description": "Between 2024-08-19 and 2024-09-10, Lam and his associates spent over $4,000,000 in stolen virtual currency at Los Angeles nightclubs. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), overt act yy",
      "uco-action:performer": {
        "@id": "urn:uuid:e54ecd62-9da3-59fb-8d04-f9029e7e8898"
