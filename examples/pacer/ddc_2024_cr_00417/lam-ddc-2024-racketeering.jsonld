    {
      "@id": "urn:uuid:46c14c1d-d75b-557c-9b7e-d8baf71a9a64",
      "@type": "uco-action:Action",
      "uco-core:name": "Toss mobile telephone into Biscayne Bay ahead of arrest",
      "uco-core:description": "On or about 2024-09-18, after obtaining information from an off-duty law enforcement officer that agents were on their way to arrest him, Lam walked to the rear of his Miami rental home and tossed his mobile telephone off the boat dock into Biscayne Bay to destroy incriminating evidence. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), overt acts pppp-qqqq",
      "uco-action:performer": {
        "@id": "urn:uuid:e54ecd62-9da3-59fb-8d04-f9029e7e8898"
      },
      "uco-action:object": [
