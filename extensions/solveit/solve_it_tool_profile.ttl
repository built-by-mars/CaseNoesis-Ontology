@prefix : <https://ontology.solveit-df.org/solveit/tool-profile/> .
@prefix solveit-tool-profile: <https://ontology.solveit-df.org/solveit/tool-profile/> .
@prefix solveit-core: <https://ontology.solveit-df.org/solveit/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix uco-core: <https://ontology.unifiedcyberontology.org/uco/core/> .
@prefix uco-tool: <https://ontology.unifiedcyberontology.org/uco/tool/> .
@prefix uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@base <https://ontology.solveit-df.org/solveit/tool-profile/> .

#################################################################
#    SOLVE-IT Tool Profile Module
#    Capability profiles for forensic tools with conditional
#    mitigation declarations
#################################################################

<https://ontology.solveit-df.org/solveit/tool-profile> rdf:type owl:Ontology ;
    owl:versionIRI <https://ontology.solveit-df.org/solveit/tool-profile/0.1.9> ;
    owl:imports <https://ontology.unifiedcyberontology.org/uco/core/1.4.0> ,
                <https://ontology.unifiedcyberontology.org/uco/tool/1.4.0> ,
                <https://ontology.unifiedcyberontology.org/uco/observable/1.4.0> ,
                <https://ontology.solveit-df.org/solveit/core> ;
    dcterms:title "SOLVE-IT Tool Profile Module"@en ;
    dcterms:description "Capability profiles for forensic tools, enabling conditional mitigation declarations that are version-specific and attributable."@en ;
    dcterms:creator "SOLVE-IT Project" ;
    owl:versionInfo "0.1.9" ;
    rdfs:label "SOLVE-IT Tool Profile Module"@en .

#################################################################
#    Classes
#################################################################

### ToolCapabilityProfile
solveit-tool-profile:ToolCapabilityProfile rdf:type owl:Class ;
    rdfs:subClassOf uco-core:UcoObject ;
    rdfs:label "Tool Capability Profile"@en ;
    rdfs:comment "A declaration of what techniques a specific version of a tool can perform and what mitigations it implements, published by a named party. Distributed as a TTL file per tool version per publisher."@en .

### SolveitAwareInstrument
solveit-tool-profile:SolveitAwareInstrument rdf:type owl:Class ;
    rdfs:subClassOf uco-tool:Tool ;
    rdfs:label "SOLVE-IT Aware Instrument"@en ;
    rdfs:comment "A specialised tool that has been evaluated against SOLVE-IT tool capability profiles. Adds the consultedProfile property to link an instrument to the profiles used during mitigation assessment."@en .

### MitigationCapability
solveit-tool-profile:MitigationCapability rdf:type owl:Class ;
    rdfs:subClassOf uco-core:UcoObject ;
    rdfs:label "Mitigation Capability"@en ;
    rdfs:comment "A declared capability that a specific mitigation is provided by a tool, optionally subject to conditions expressed as SHACL shapes."@en .

### ConditionTargetType
solveit-tool-profile:ConditionTargetType rdf:type owl:Class ;
    rdfs:label "Condition Target Type"@en ;
    rdfs:comment "Enumeration of action components that conditions can evaluate against."@en .

#################################################################
#    Individuals (Condition Target Types)
#################################################################

solveit-tool-profile:ObjectTarget rdf:type solveit-tool-profile:ConditionTargetType ;
    rdfs:label "Object Target"@en ;
    rdfs:comment "Resolves to the uco-action:object (input) value of the performed technique."@en .

solveit-tool-profile:InstrumentTarget rdf:type solveit-tool-profile:ConditionTargetType ;
    rdfs:label "Instrument Target"@en ;
    rdfs:comment "Resolves to the uco-action:instrument value (the Tool / SolveitAwareInstrument instance)."@en .

solveit-tool-profile:ResultsTarget rdf:type solveit-tool-profile:ConditionTargetType ;
    rdfs:label "Results Target"@en ;
    rdfs:comment "Resolves to the uco-action:result (output) value of the performed technique."@en .

solveit-tool-profile:PerformerTarget rdf:type solveit-tool-profile:ConditionTargetType ;
    rdfs:label "Performer Target"@en ;
    rdfs:comment "Resolves to the uco-action:performer value of the performed technique. Reserved for future use."@en .

#################################################################
#    Object Properties
#################################################################

solveit-tool-profile:profileFor rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-tool-profile:ToolCapabilityProfile ;
    rdfs:range uco-tool:Tool ;
    rdfs:label "profile for"@en ;
    rdfs:comment "Links to the tool that this profile describes. That tool object also potentially contains the tool version that this applies to."@en .

solveit-tool-profile:supportsTechnique rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-tool-profile:ToolCapabilityProfile ;
    rdfs:range solveit-core:Technique ;
    rdfs:label "supports technique"@en ;
    rdfs:comment "Declares that the profiled tool supports a given technique."@en .

solveit-tool-profile:hasMitigationCapability rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-tool-profile:ToolCapabilityProfile ;
    rdfs:range solveit-tool-profile:MitigationCapability ;
    rdfs:label "has mitigation capability"@en ;
    rdfs:comment "Links a profile to a mitigation capability declaration."@en .

solveit-tool-profile:consultedProfile rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-tool-profile:SolveitAwareInstrument ;
    rdfs:range solveit-tool-profile:ToolCapabilityProfile ;
    rdfs:label "consulted profile"@en ;
    rdfs:comment "Links an instrument to the capability profiles consulted during mitigation assessment."@en .

solveit-tool-profile:implementsMitigation rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-tool-profile:MitigationCapability ;
    rdfs:range solveit-core:Mitigation ;
    rdfs:label "implements mitigation"@en ;
    rdfs:comment "The SOLVE-IT mitigation that this capability implements."@en .

solveit-tool-profile:appliesWhen rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-tool-profile:MitigationCapability ;
    rdfs:range sh:NodeShape ;
    rdfs:label "applies when"@en ;
    rdfs:comment "A SHACL NodeShape defining the conditions for this mitigation to be active. Optional; if absent, the mitigation is unconditional."@en .

solveit-tool-profile:conditionTarget rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-tool-profile:MitigationCapability ;
    rdfs:range solveit-tool-profile:ConditionTargetType ;
    rdfs:label "condition target"@en ;
    rdfs:comment "Specifies which component of the action the condition evaluates against. Required if appliesWhen is set."@en .

#################################################################
#    Data Properties
#################################################################

solveit-tool-profile:publishedBy rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-tool-profile:ToolCapabilityProfile ;
    rdfs:range xsd:string ;
    rdfs:label "published by"@en ;
    rdfs:comment "The name of the party that published this profile."@en .

solveit-tool-profile:publishedDate rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-tool-profile:ToolCapabilityProfile ;
    rdfs:range xsd:dateTime ;
    rdfs:label "published date"@en ;
    rdfs:comment "When this profile was published."@en .

