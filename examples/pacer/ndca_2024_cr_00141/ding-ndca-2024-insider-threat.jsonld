    {
      "@id": "urn:uuid:494a8040-0b69-5744-9ac8-94af64d2b115",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Ding travels to the PRC and raises capital for Rongshu (2022-10-29 to 2023-03-25)",
      "uco-core:description": "Ding remained in the PRC for roughly five months, participating in Rongshu investor meetings from December 2022; Rongshu's CEO identified him to investors as CTO on 2023-04-17. Google was never informed. Source: PACER Doc 140 (second_superseding_indictment), paras. 19-20",
      "uco-action:performer": {
        "@id": "urn:uuid:aeeaf703-8a4a-554b-9882-0228790fb782"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
