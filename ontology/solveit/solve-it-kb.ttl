        :weaknessDFW-1355 ;
    solveit-core:techniqueDescription "The processes of reading the metadata values stored within forensic container formats" ;
    solveit-core:techniqueDetails "This has been differentiated from reading data from text files that accompany raw disk images, but includes metadata stored within logical formats. " ;
    solveit-core:techniqueID "DFT-1193" ;
    solveit-core:techniqueName "Read metadata from within a forensic image container" .

:weaknessDFW-1001 a solveit-core:Weakness ;
