    },
    {
      "@id": "urn:uuid:651aaeec-2604-5fe9-b5f2-6ca0b74c9b31",
      "@type": [
        "uco-observable:ObservableObject",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count Two NDI (SECRET): Information regarding the provision of equipment to Ukraine,...",
      "uco-core:description": "Information regarding the provision of equipment to Ukraine, how the equipment would be transferred, and how the equipment would be used upon receipt. Retained and transmitted Jan. 2023 to April 2023. Classified information transcribed from a classified workstation into Discord messages. Source: PACER Doc 48 (indictment), paras. 16, 18 (count charts)",
      "uco-core:objectMarking": [
        {
          "@id": "urn:uuid:55d480ce-b220-5d84-aa70-5bdc9c92d391"
        }
      ]
    },
