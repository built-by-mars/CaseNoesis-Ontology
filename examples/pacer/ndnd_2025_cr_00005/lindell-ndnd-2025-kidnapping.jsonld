    {
      "@id": "urn:uuid:3fef9c97-e618-5b20-b11a-4493ac784bea",
      "@type": "uco-action:Action",
      "uco-core:name": "Distribute methamphetamine in North Dakota and Minnesota",
      "uco-core:description": "From late February 2024 through early April 2024, the conspirators distributed and possessed with intent to distribute methamphetamine in North Dakota, Minnesota, and elsewhere, arranging transfers into North Dakota from out of state and using currency, mobile payment apps, social media, and cellular telephones. Source: PACER Doc 66 (indictment2), overt acts 1-2, 9-11",
      "uco-action:performer": {
        "@id": "urn:uuid:ed83f702-130e-5803-83f9-aac0f27827ed"
      },
      "uco-action:object": [
        {
          "@id": "urn:uuid:163029d3-60bf-54ae-9e35-f51283104ff4"
        }
      ],
      "uco-action:instrument": [
        {
          "@id": "urn:uuid:7962e2ab-d945-55f0-84ee-547486154f44"
        },
        {
