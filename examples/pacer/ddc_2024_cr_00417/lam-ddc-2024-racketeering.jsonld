    {
      "@id": "urn:uuid:5eaeced9-3251-538a-be34-9b8a98a4a873",
      "@type": "uco-action:Action",
      "uco-core:name": "Steal approximately $245,093,239 in virtual currency from Victim-7",
      "uco-core:description": "On or about 2024-08-19, Lam, COCONSPIRATOR-1, COCONSPIRATOR-2, CHEN, and another executed a social-engineering fraud scheme against Victim-7 while Victim-7 was at his home in Washington, D.C., convincing him to download a remote desktop connection program, accessing his computer through it, and stealing approximately $245,093,239.00 in virtual currency. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), overt acts uu-vv",
      "uco-action:performer": {
        "@id": "urn:uuid:e54ecd62-9da3-59fb-8d04-f9029e7e8898"
      },
      "uco-action:object": [
