        }
      ]
    },
    {
      "@id": "urn:uuid:a7634ce8-106c-53af-875a-a7c33621001b",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Teixeira changes username and deletes Discord server contents",
      "uco-core:description": "Changed his Discord username and deleted the entire contents of at least one Discord server where he had posted classified documents and information. Source: PACER Doc 144 (sentencing_memorandum), p. 8",
      "uco-action:performer": {
        "@id": "urn:uuid:b413b5a1-8666-5b5c-aca9-a86696327cc4"
