    {
      "@id": "urn:uuid:fcd84de1-b417-5454-b870-425ea99b24fa",
      "@type": [
        "legalproc:Sentence",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Government sentencing recommendation for Perry",
      "uco-core:description": "The United States recommended consecutive life sentences for the conspiracy-to-murder conviction and the \u00a7 924(c) convictions, consecutive statutory maximums for each attempted-murder and assault conviction, and restitution of $3,717.98 to the FBI, joint and several with O'Dell. PSR: total offense level 43 (calculated 60), criminal history category VI via the federal-crime-of-terrorism enhancement (U.S.S.G. \u00a73A1.4); Guidelines range life. Source: PACER Doc 214 (sentencing_memo), pp. 2-3, 7",
      "legalproc:sentenceStatus": "recommended",
      "legalproc:sentenceTerm": "consecutive lifetime terms of imprisonment",
      "legalproc:concernsCharge": [
        {
          "@id": "urn:uuid:fb34cdfd-c6e1-5cf4-a67f-0310e4ddbeef"
        },
        {
          "@id": "urn:uuid:d2a022eb-413e-5dae-83d1-add5d2ac8581"
        }
      ]
    },
    {
      "@id": "urn:uuid:cd834fde-a55f-50a5-848c-8075ad95d171",
      "@type": [
        "legalproc:Sentence",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Sentence imposed on Perry (2025-08-27)",
      "uco-core:description": "Life on Count 1; concurrent terms of 5-20 years on the remaining concurrent counts; and Life on each of Counts 21-34, consecutive to each other and to all other counts, for a total term of Life. Supervised release 5 years; special assessment $3,800; no fine; restitution $3,717.98. Source: PACER Doc criminal docket sheet (docket), defendant 1 dispositions",
      "legalproc:sentenceStatus": "imposed",
      "legalproc:sentenceTerm": "Life (Count 1) plus fourteen consecutive Life terms (Counts 21-34)",
      "legalproc:concernsCharge": [
