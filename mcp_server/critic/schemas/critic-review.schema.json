{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caseontology.org/schemas/critic-review.schema.json",
  "title": "CASE/UCO CriticReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_hashes",
    "validation",
    "deterministic_findings",
    "merged_findings",
    "scorecard",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "artifact_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graph_sha256"],
      "properties": {
        "graph_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "serializer_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "source_sha256": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        },
        "coverage_contract_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "provenance_manifest_sha256": {
          "type": ["string", "null"],
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    },
    "validation": { "type": "object" },
    "deterministic_findings": {
      "type": "array",
      "items": { "$ref": "critic-finding.schema.json" }
    },
    "critic_findings": {
      "type": "array",
      "items": { "$ref": "critic-finding.schema.json" }
    },
    "merged_findings": {
      "type": "array",
      "items": { "$ref": "critic-finding.schema.json" }
    },
    "scorecard": { "$ref": "critic-scorecard.schema.json" },
    "prompt_package": { "type": "object" },
    "status": { "type": "string" },
    "analysis_status": {
      "enum": ["complete", "partial", "failed"]
    },
    "rule_executions": {
      "type": "array",
      "items": { "$ref": "critic-rule-execution.schema.json" }
    },
    "finding_diff": { "type": "object" },
    "handoff_suggestions": { "type": "array" },
    "model_identifier": { "type": ["string", "null"] },
    "token_estimate": { "type": ["integer", "null"] },
    "elapsed_ms": { "type": ["integer", "null"] },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
