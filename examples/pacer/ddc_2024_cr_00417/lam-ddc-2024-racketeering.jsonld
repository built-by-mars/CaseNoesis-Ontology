    {
      "@id": "urn:uuid:26dc6518-f5b9-5093-8678-4b337d15536b",
      "@type": "uco-action:Action",
      "uco-core:name": "Watch the FBI searches through remote security-camera access",
      "uco-core:description": "On or about 2024-09-18, while in Los Angeles, Tangeman used his remote access to the security cameras at Lam's Miami rental homes to watch FBI agents search the residences and inventory evidence, taking screenshots and sharing the video. Source: PACER Doc 245 (redacted; unredacted Doc 229 returned 2025-10-29) (indictment_ss), overt act rrrr; Source: PACER Doc 318 (sentmemo), Statement of Facts",
      "uco-action:performer": {
        "@id": "urn:uuid:ee9929a5-4779-5303-9c4f-7c0d7802af40"
      },
      "uco-action:instrument": [
