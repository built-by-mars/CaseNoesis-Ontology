      "@id": "urn:uuid:c6273ac5-02d7-5dd0-9432-a46ec79390b9",
      "@type": "uco-pattern:LogicalPattern",
      "uco-core:name": "DarkWatchman DWM registry name template",
      "uco-core:description": "Anomalous keys under HKCU\\Software\\Microsoft\\Windows\\DWM\\ with 8-character uid + 1-character suffix.",
      "uco-pattern:patternExpression": {
        "@type": "https://ontology.unifiedcyberontology.org/uco/pattern/PatternExpression",
        "@value": "HKCU/Software/Microsoft/Windows/DWM/[0-9a-f]{8}[a-z]"
      },
      "uco-core:tag": [
        "detection-pattern",
        "epistemic:reported"
      ]
