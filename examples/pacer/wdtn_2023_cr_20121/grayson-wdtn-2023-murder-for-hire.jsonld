    {
      "@id": "urn:uuid:32be9783-8c2f-5e44-99cd-d57f5b5b43ce",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 1 (as to Ashley Grayson): Use of Interstate Facility in Commission of Murder-for-Hire",
      "uco-core:description": "Use of a facility of interstate commerce with intent that a murder be committed for hire (docket offense text: '18:1958 RACKETEERING - MURDER'). Ashley Grayson was found guilty by the jury on 2024-03-29 and sentenced to 120 months, the statutory maximum. Source: PACER docket, Defendant (1) terminated counts; Source: USAO press release, paras. 6-7",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 1958",
      "legalproc:countNumber": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "1"
      },
      "legalproc:countLabel": "Count 1",
      "legalproc:offenseForm": "substantive",
      "legalproc:chargeDisposition": "convicted-at-trial",
      "legalproc:assertedIn": {
        "@id": "urn:uuid:7e74eac8-f243-58a3-8bd6-3270bf2cced6"
      }
    },
    {
      "@id": "urn:uuid:b79cde58-5b54-579a-9c5b-47b407b71711",
      "@type": [
        "legalproc:CriminalCharge",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Count 1 (as to Joshua Grayson): Use of Interstate Facility in Commission of Murder-for-Hire",
      "uco-core:description": "The same \u00a7 1958 count charged against Joshua Grayson. The jury returned a not-guilty verdict on 2024-03-29; judgment of acquittal entered 2024-04-04 discharging him and exonerating his bond. Source: PACER docket, Defendant (2) pending counts; D.E. 134",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 1958",
      "legalproc:countNumber": {
        "@type": "xsd:nonNegativeInteger",
