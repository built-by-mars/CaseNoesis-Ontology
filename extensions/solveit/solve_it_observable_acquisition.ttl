@prefix solveit-observable: <https://ontology.solveit-df.org/solveit/observable/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix uco-core: <https://ontology.unifiedcyberontology.org/uco/core/> .
@prefix uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/> .
@prefix uco-types: <https://ontology.unifiedcyberontology.org/uco/types/> .
@base <https://ontology.solveit-df.org/solveit/observable/> .

#################################################################
#    SOLVE-IT Observable Acquisition Module
#    Classes for forensic data acquisition
#################################################################

<https://ontology.solveit-df.org/solveit/observable/acquisition> rdf:type owl:Ontology ;
    owl:versionIRI <https://ontology.solveit-df.org/solveit/observable/acquisition/0.1.9> ;
    owl:imports <https://ontology.unifiedcyberontology.org/uco/observable/1.4.0> ;
    dcterms:title "SOLVE-IT Observable Acquisition Module"@en ;
    dcterms:description "Classes for forensic data acquisition including forensic images, live captures, and extraction methods."@en ;
    dcterms:creator "SOLVE-IT Project" ;
    owl:versionInfo "0.1.9" ;
    rdfs:label "SOLVE-IT Observable Acquisition Module"@en .

#################################################################
#    Classes
#################################################################

###  AcquiredData Observable Object
solveit-observable:AcquiredData rdf:type owl:Class ;
    rdfs:subClassOf uco-observable:ObservableObject ;
    rdfs:label "Acquired Data"@en ;
    rdfs:comment "Data that has been forensically collected from a source device or system. This is the parent class for all types of forensic data acquisition outputs."@en .

###  ForensicImageContainer Observable Object
solveit-observable:ForensicImageContainer rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:AcquiredData ;
    rdfs:label "Forensic Image Container"@en ;
    rdfs:comment "A forensic image in a container format that encapsulates acquired data, potentially compressed or encrypted, along with embedded metadata such as case information, examiner identity, acquisition timestamps, hash values, compression settings, and encryption status. It may be stored across one or more files referenced via storedIn."@en .

###  PhysicalImageContainer Observable Object
solveit-observable:PhysicalImageContainer rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:ForensicImageContainer ;
    rdfs:label "Physical Image Container"@en ;
    rdfs:comment "A forensic image container that encapsulates a bitstream (bit-for-bit) copy of a source medium, such as a full disk image in E01 or AFF4 format."@en .

###  LogicalImageContainer Observable Object
solveit-observable:LogicalImageContainer rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:ForensicImageContainer ;
    rdfs:label "Logical Image Container"@en ;
    rdfs:comment "A forensic image container that encapsulates a logical collection of files rather than a bitstream copy, such as a logical image in L01 or ZIP format."@en .

###  RawImage Observable Object
solveit-observable:RawImage rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:AcquiredData ;
    rdfs:label "Raw Image"@en ;
    rdfs:comment "A raw forensic image containing a bitstream without container metadata. Unlike a ForensicImageContainer (e.g. E01, AFF4), a raw image has no embedded metadata. It may be stored across one or more files (e.g. split .dd segments) referenced via storedIn. Typically accompanied by a RawImageInfoFile containing hashes, case information, and acquisition details."@en .

###  RawImageInfoFile Observable Object
solveit-observable:RawImageInfoFile rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:AcquisitionRecordFile ;
    rdfs:label "Raw Image Info File"@en ;
    rdfs:comment "A sidecar file containing metadata for a raw/dd forensic image, including hash values, case information, evidence numbers, examiner details, and acquisition notes. Compensates for the lack of embedded metadata in raw image formats."@en .

###  LiveDataCapture Observable Object
solveit-observable:LiveDataCapture rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:AcquiredData ;
    rdfs:label "Live Data Capture"@en ;
    rdfs:comment "Volatile or transient data captured from a running system at a specific point in time. Includes running processes, memory state, network connections, device interrogation data (e.g., ideviceinfo output), and system properties."@en .

###  FileSystemExtraction Observable Object
solveit-observable:FileSystemExtraction rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:AcquiredData ;
    rdfs:label "File System Extraction"@en ;
    rdfs:comment "Data obtained through direct access to a file system structure. Represents the files and folders as they existed on the device or storage, applicable to any device type (mobile, desktop, embedded). Live files only."@en .

###  ServiceBasedExtractionData Observable Object
solveit-observable:ServiceBasedExtractionData rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:AcquiredData ;
    rdfs:label "Service-Based Extraction Data"@en ;
    rdfs:comment "Data obtained by interacting with services provided by a device rather than direct storage access."@en .

###  DeviceGeneratedBackup Observable Object
solveit-observable:DeviceGeneratedBackup rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:ServiceBasedExtractionData ;
    rdfs:label "Device Generated Backup"@en ;
    rdfs:comment "Data produced by a device's built-in backup mechanism. Content is determined by the device's backup logic and structured in the backup's native format."@en .

###  iOSDeviceGeneratedBackup Observable Object
solveit-observable:iOSDeviceGeneratedBackup rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:DeviceGeneratedBackup ;
    rdfs:label "iOS Device Generated Backup"@en ;
    rdfs:comment "Data produced by the iOS backup mechanism via iTunes, Finder, or libimobiledevice. Contains a manifest database (Manifest.db), file blobs identified by domain-path hashes, and metadata plists including device information and backup status."@en .

###  AndroidDeviceGeneratedBackup Observable Object
solveit-observable:AndroidDeviceGeneratedBackup rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:DeviceGeneratedBackup ;
    rdfs:label "Android Device Generated Backup"@en ;
    rdfs:comment "Data produced by Android's backup mechanism (e.g., adb backup). Potentially contains application data, shared storage, and system settings in the Android backup format (.ab file)."@en .

###  AFCExtractionData Observable Object
solveit-observable:AFCExtractionData rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:ServiceBasedExtractionData ;
    rdfs:label "AFC Extraction Data"@en ;
    rdfs:comment "Data obtained via Apple File Conduit (AFC) service from iOS devices."@en .

###  ADBPullData Observable Object
solveit-observable:ADBPullData rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:ServiceBasedExtractionData ;
    rdfs:label "ADB Pull Data"@en ;
    rdfs:comment "Data obtained via Android Debug Bridge (ADB) pull operations."@en .

###  AppleUnifiedLogArchive Observable Object
solveit-observable:AppleUnifiedLogArchive rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:ServiceBasedExtractionData ;
    rdfs:label "Apple Unified Log Archive"@en ;
    rdfs:comment "Data obtained by collecting Apple Unified Logs from a macOS or iOS device."@en .

###  ContentQueryData Observable Object
solveit-observable:ContentQueryData rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:ServiceBasedExtractionData ;
    rdfs:label "Content Query Data"@en ;
    rdfs:comment "Data obtained from an Android device by querying content providers via an ADB shell connection (e.g., adb shell content query). Content providers expose structured data such as contacts, call logs, SMS messages, and settings without requiring direct file system access."@en .

###  DeviceScreenshotCapture Observable Object
solveit-observable:DeviceScreenshotCapture rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:AcquiredData ;
    rdfs:label "Device Screenshot Capture"@en ;
    rdfs:comment "The acquisition of a screenshot from a device screen. Contains the captured image (RasterPicture)."@en .

###  ClockOffsetCapture Observable Object
solveit-observable:ClockOffsetCapture rdf:type owl:Class ;
    rdfs:subClassOf solveit-observable:AcquiredData ;
    rdfs:label "Clock Offset Capture"@en ;
    rdfs:comment "The acquisition of a clock offset measurement from a device. Contains the ClockOffsetMeasurement recording the measured difference between the device clock and a reference time source."@en .

###  AcquisitionRecordFile Observable Object
solveit-observable:AcquisitionRecordFile rdf:type owl:Class ;
    rdfs:subClassOf uco-observable:File ;
    rdfs:label "Acquisition Record File"@en ;
    rdfs:comment "A file containing records generated during a data acquisition process, such as error logs or acquisition status reports."@en .

###  AcquisitionErrorRecord Observable Object
solveit-observable:AcquisitionErrorRecord rdf:type owl:Class ;
    rdfs:subClassOf uco-observable:ObservableObject ;
    rdfs:label "Acquisition Error Record"@en ;
    rdfs:comment "A record of an error encountered during data acquisition such as a bad sector, read timeout, I/O error, CRC error, or media surface damage."@en .



#################################################################
#    Object Properties
#################################################################

solveit-observable:contains rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:AcquiredData ;
    rdfs:range uco-observable:ObservableObject ;
    rdfs:label "contains"@en ;
    rdfs:comment "The logical content encapsulated within the acquired data, such as bitstream data, files, or metadata."@en .

solveit-observable:acquiredFrom rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:AcquiredData ;
    rdfs:range uco-observable:ObservableObject ;
    rdfs:label "acquired from"@en ;
    rdfs:comment "The source from which the data was acquired, such as a device, device interface, or storage medium."@en .

solveit-observable:storedIn rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:AcquiredData ;
    rdfs:range uco-observable:File ;
    rdfs:label "stored in"@en ;
    rdfs:comment "The file or files in which the acquired data is physically stored (e.g., .E01 segment files, a .dd file, a backup archive)."@en .

solveit-observable:hasInfoFile rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:RawImage ;
    rdfs:range solveit-observable:RawImageInfoFile ;
    rdfs:label "has info file"@en ;
    rdfs:comment "Links a RawImage to its accompanying RawImageInfoFile containing metadata."@en .

solveit-observable:hasAcquisitionErrorRecord rdf:type owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
                  owl:unionOf ( solveit-observable:ForensicImageContainer
                                solveit-observable:RawImageInfoFile ) ] ;
    rdfs:range solveit-observable:AcquisitionErrorRecord ;
    rdfs:label "has acquisition error"@en ;
    rdfs:comment "Links a forensic image container or raw image info file to errors encountered during acquisition. Multiple errors can be recorded."@en .

solveit-observable:containsErrorRecord rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:AcquisitionRecordFile ;
    rdfs:range solveit-observable:AcquisitionErrorRecord ;
    rdfs:label "contains error record"@en ;
    rdfs:comment "Links an AcquisitionRecordFile to the error records it contains."@en .

solveit-observable:containsSourceHash rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:AcquisitionRecordFile ;
    rdfs:range uco-types:Hash ;
    rdfs:label "contains source hash"@en ;
    rdfs:comment "A hash value computed from the source device or media before or during acquisition."@en .

solveit-observable:containsDestinationHash rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-observable:AcquisitionRecordFile ;
    rdfs:range uco-types:Hash ;
    rdfs:label "contains destination hash"@en ;
    rdfs:comment "A hash value computed from the acquired image or data after acquisition."@en .

#################################################################
#    Data Properties
#################################################################

solveit-observable:embeddedCaseNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:ForensicImageContainer ;
    rdfs:range xsd:string ;
    rdfs:label "embedded case number"@en ;
    rdfs:comment "The case number stored within the forensic image container metadata."@en .

solveit-observable:embeddedEvidenceNumber rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:ForensicImageContainer ;
    rdfs:range xsd:string ;
    rdfs:label "embedded evidence number"@en ;
    rdfs:comment "The evidence number stored within the forensic image container metadata."@en .

solveit-observable:embeddedExaminerName rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:ForensicImageContainer ;
    rdfs:range xsd:string ;
    rdfs:label "embedded examiner name"@en ;
    rdfs:comment "The examiner name stored within the forensic image container metadata."@en .

solveit-observable:embeddedDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:ForensicImageContainer ;
    rdfs:range xsd:string ;
    rdfs:label "embedded description"@en ;
    rdfs:comment "The description stored within the forensic image container metadata."@en .

solveit-observable:embeddedNotes rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:ForensicImageContainer ;
    rdfs:range xsd:string ;
    rdfs:label "embedded notes"@en ;
    rdfs:comment "The notes stored within the forensic image container metadata."@en .

solveit-observable:backupFormatVersion rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:DeviceGeneratedBackup ;
    rdfs:range xsd:string ;
    rdfs:label "backup format version"@en ;
    rdfs:comment "The version of the backup format used to produce the backup (e.g., iOS backup version 3.3, Android backup format v5)."@en .

solveit-observable:encryptedOnGeneration rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:DeviceGeneratedBackup ;
    rdfs:range xsd:boolean ;
    rdfs:label "encrypted on generation"@en ;
    rdfs:comment "Whether the backup was encrypted at the time it was generated. A backup encrypted on generation may contain a richer dataset (e.g., iOS encrypted backups include keychain and health data) even if a decrypted copy is subsequently produced."@en .

solveit-observable:isEncrypted rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:DeviceGeneratedBackup ;
    rdfs:range xsd:boolean ;
    rdfs:label "is encrypted"@en ;
    rdfs:comment "Whether the backup is currently in an encrypted state. Used alongside encryptedOnGeneration to distinguish between a backup that is still encrypted and one that has been decrypted for analysis."@en .

solveit-observable:containsStartTime rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:AcquisitionRecordFile ;
    rdfs:range xsd:dateTime ;
    rdfs:label "contains start time"@en ;
    rdfs:comment "The acquisition start time as recorded in the acquisition record."@en .

solveit-observable:containsEndTime rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:AcquisitionRecordFile ;
    rdfs:range xsd:dateTime ;
    rdfs:label "contains end time"@en ;
    rdfs:comment "The acquisition end time as recorded in the acquisition record."@en .

solveit-observable:errorType rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:AcquisitionErrorRecord ;
    rdfs:range xsd:string ;
    rdfs:label "error type"@en ;
    rdfs:comment "The type of acquisition error (e.g., bad sector, read timeout, I/O error, CRC error)."@en .

solveit-observable:errorLocationStart rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:AcquisitionErrorRecord ;
    rdfs:range xsd:integer ;
    rdfs:label "error location start"@en ;
    rdfs:comment "The starting location of the error (e.g., sector number, byte offset)."@en .

solveit-observable:errorLocationEnd rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-observable:AcquisitionErrorRecord ;
    rdfs:range xsd:integer ;
    rdfs:label "error location end"@en ;
    rdfs:comment "The ending location of the error (e.g., sector number, byte offset). If omitted, the error is at a single location."@en .
