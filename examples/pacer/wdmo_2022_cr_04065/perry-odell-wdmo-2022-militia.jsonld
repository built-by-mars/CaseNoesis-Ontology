      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Perry fires ~11 rifle shots at FBI Special Agents (2022-10-07)",
      "uco-core:description": "During the warrant execution Perry donned his body armor and used and discharged the Voodoo Innovations rifle to fire approximately 11 shots at FBI Special Agents; several rounds hit the armored FBI Bearcat, one narrowly missing an agent's head. Source: PACER Doc 48 (indictment3), para. 40; Source: PACER Doc 214 (sentencing_memo), background, p. 10",
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2022-10-07T00:00:00-05:00"
