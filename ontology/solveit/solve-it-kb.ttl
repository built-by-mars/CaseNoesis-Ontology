        "https://ontology.unifiedcyberontology.org/uco/core/description"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/core/name"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Note"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/types/Hash"^^xsd:anyURI ;
    solveit-core:hasExample "AFF4",
        "EWF" ;
