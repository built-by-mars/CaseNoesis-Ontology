	a time:ProperInterval ;
	time:hasBeginning cg:instant-2023-02-01 ;
	time:hasEnd cg:instant-2023-02-28 .
cg:instant-2023-02-01 a time:Instant ; time:inXSDDateTimeStamp "2023-02-01T00:00:00Z"^^xsd:dateTimeStamp .
cg:instant-2023-02-28 a time:Instant ; time:inXSDDateTimeStamp "2023-02-28T23:59:00Z"^^xsd:dateTimeStamp .

