{
    "@context": {
        "kb": "http://example.org/kb/",
        "uco-core": "https://ontology.unifiedcyberontology.org/uco/core/",
        "uco-identity": "https://ontology.unifiedcyberontology.org/uco/identity/",
        "gufo": "http://purl.org/nemo/gufo#",
        "xsd": "http://www.w3.org/2001/XMLSchema#"
    },
    "@graph": [
        {
            "@id": "kb:suspect-1",
            "@type": [
                "uco-identity:Person",
                "gufo:Event"
            ],
            "uco-core:name": "Jane Doe (synthetic)",
            "gufo:hasTimestamp": {
                "@type": "xsd:dateTime",
                "@value": "2026-03-15T10:00:00Z"
            },
            "_comment": "ANTI-PATTERN: a Person must not be typed as gufo:Event. Model events as InvestigativeAction/uco-action:Action with gufo:Event on the action IRI."
        }
    ]
}
