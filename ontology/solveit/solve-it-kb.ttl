:techniqueDFT-1146 a solveit-core:Technique ;
    rdfs:label "DFT-1146: Extract browser synchronization artifacts"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/configuration/Configuration"^^xsd:anyURI ;
    solveit-core:techniqueDescription "The examination of the settings and artifacts resulting from a browser synchronization feature" ;
    solveit-core:techniqueID "DFT-1146" ;
    solveit-core:techniqueName "Extract browser synchronization artifacts" .

:techniqueDFT-1147 a solveit-core:Technique ;
    rdfs:label "DFT-1147: Extract browser cookie artifacts"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/BrowserCookie"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/CookieHistory"^^xsd:anyURI ;
    solveit-core:techniqueDescription "The examination of stored browser cookies" ;
    solveit-core:techniqueID "DFT-1147" ;
    solveit-core:techniqueName "Extract browser cookie artifacts" .

:techniqueDFT-1148 a solveit-core:Technique ;
    rdfs:label "DFT-1148: Extract browser web storage artifacts"@en ;
    solveit-core:hasReference :citationDFCite-1099 ;
    solveit-core:hasSynonym "HTML5 storage examination",
        "browser storage examination",
        "local storage examination",
        "web storage examination" ;
    solveit-core:techniqueDescription "The examination of " ;
    solveit-core:techniqueDetails "Web storage is a browser-based API bundled in HTML5 specifications that allow persistent client-side storage for web applications. (Mendoza 2015)" ;
    solveit-core:techniqueID "DFT-1148" ;
    solveit-core:techniqueName "Extract browser web storage artifacts" .

:techniqueDFT-1149 a solveit-core:Technique ;
    rdfs:label "DFT-1149: Extract artifacts from the file versioning feature"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/modifiedTime"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/version"^^xsd:anyURI ;
    solveit-core:hasExample "MacOS \"Revert to\" feature",
        "Volume Shadow Service (VSS)" ;
    solveit-core:hasReference :citationDFCite-1005,
        :citationDFCite-1059,
        :citationDFCite-1087,
        :citationDFCite-1120 ;
    solveit-core:hasSynonym "'Revert to...' feature examination",
        "macOS 'Versions' examination",
        "previous versions",
        "shadow copy examination" ;
    solveit-core:techniqueDescription "Extraction of data from the versioning system used by an operating system to store older versions of files." ;
    solveit-core:techniqueDetails "Operating systems often maintain versioning systems that preserve older versions of files, either for backup purposes or to enable users to restore previous states. These systems create snapshots or shadow copies at regular intervals or when significant changes occur. Digital forensic examination of these versioning features can reveal files that have been modified or deleted, providing valuable evidence of system activity and user behavior. The examination process involves identifying the versioning mechanism used by the operating system, locating the stored versions, and extracting relevant data for analysis." ;
    solveit-core:techniqueID "DFT-1149" ;
    solveit-core:techniqueName "Extract artifacts from the file versioning feature" .

:techniqueDFT-1150 a solveit-core:Technique ;
    rdfs:label "DFT-1150: Recover non-allocated files using residual file metadata"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/FileSystem"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/core/confidence"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Directory"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1134,
        :weaknessDFW-1135,
        :weaknessDFW-1253,
        :weaknessDFW-1254,
        :weaknessDFW-1255,
        :weaknessDFW-1256 ;
    solveit-core:hasReference :citationDFCite-1024,
        :citationDFCite-1030 ;
    solveit-core:techniqueDescription "Use metadata that remains in the file system to recover non-allocated files" ;
    solveit-core:techniqueID "DFT-1150" ;
    solveit-core:techniqueName "Recover non-allocated files using residual file metadata" .

:techniqueDFT-1151 a solveit-core:Technique ;
    rdfs:label "DFT-1151: Keyword search (over extracted artifacts)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ArtifactSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/KeywordSearchResultSet"^^xsd:anyURI ;
    solveit-core:hasExample "Using Keywords with Magnet AXIOM (McQuaid 2017)" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1257 ;
    solveit-core:hasReference :citationDFCite-1098 ;
    solveit-core:hasSynonym "search artifacts only" ;
    solveit-core:techniqueDescription "Keyword searching only applied over extracted artifacts" ;
    solveit-core:techniqueDetails "This limited scope search may be performed within tools themselves e.g. McQuaid (2017), or within an exported packaged report." ;
    solveit-core:techniqueID "DFT-1151" ;
    solveit-core:techniqueName "Keyword search (over extracted artifacts)" .

:techniqueDFT-1154 a solveit-core:Technique ;
    rdfs:label "DFT-1154: Reconstruct an identity associated with an event"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/core/confidence"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/identity/Person"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Account"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1150 ;
    solveit-core:hasReference :citationDFCite-1027,
        :citationDFCite-1119 ;
    solveit-core:hasSynonym "Identity-based event reconstruction",
        "Resolving the person-account gap,",
        "Resolving the person-device gap" ;
    solveit-core:techniqueDescription "The process of attempting to link an identity (account, person etc.) to a reconstructed event" ;
    solveit-core:techniqueID "DFT-1154" ;
    solveit-core:techniqueName "Reconstruct an identity associated with an event" .

:techniqueDFT-1155 a solveit-core:Technique ;
    rdfs:label "DFT-1155: Reconstruct that a specific event may have occurred"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/keywordSearchTerm"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/analysis/HypothesisedEvent"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/analysis/HypothesisedWebSearch"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1150 ;
    solveit-core:hasSynonym "Action-based event reconstruction",
        "Activity-based event reconstruction",
        "Operation-based event reconstruction" ;
    solveit-core:techniqueDescription "The process of reconstructing that an operation occurred on a digital system" ;
    solveit-core:techniqueDetails """While some event reconstruction needs a time component, there are some questions that are simply explaining what happened, or if something happened. The time component may need to investigated later, or may be learned as a byproduct of reconstructing the event, but isn't intrinsic to the question being asked.
e.g. Was this file opened? How many times was this file opened? What data has been exfiltrated?""" ;
    solveit-core:techniqueID "DFT-1155" ;
    solveit-core:techniqueName "Reconstruct that a specific event may have occurred" .

:techniqueDFT-1156 a solveit-core:Technique ;
    rdfs:label "DFT-1156: Reconstruct if an event could have functionally occurred on a system given its capabilities"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/configuration/Configuration"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/configuration/dependencies"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/core/confidence"^^xsd:anyURI ;
    solveit-core:hasSynonym "Functional-based event reconstruction" ;
    solveit-core:techniqueDescription "Reconstructing the configuration or capabilities of a system at the time of an event" ;
    solveit-core:techniqueDetails """Considering how a system works and what conditions were necessary for an event to be possible, i.e. supporting or refuting if a hypothesis is feasible.

This might involve questions such as:
- is a program or system capable of performing some action
- how was the program or system configured (to determine if an operation was possible)""" ;
    solveit-core:techniqueID "DFT-1156" ;
    solveit-core:techniqueName "Reconstruct if an event could have functionally occurred on a system given its capabilities" .

:techniqueDFT-1157 a solveit-core:Technique ;
    rdfs:label "DFT-1157: Extract device data using exposed service"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/MobileDevice"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/ServiceBasedExtractionData"^^xsd:anyURI ;
    solveit-core:hasExample "Android Debug Bridge (ADB) provides command line access when USB debugging is enabled on Android devices",
        "Extraction of data by querying Content Providers on Android (via ADB)",
        "Extraction of data using AFC on iOS",
        "Media Transfer Protocol (MTP)" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1037,
        :weaknessDFW-1040,
        :weaknessDFW-1041,
        :weaknessDFW-1271,
        :weaknessDFW-1272,
        :weaknessDFW-1273 ;
    solveit-core:hasSubtechnique :techniqueDFT-1019 ;
    solveit-core:techniqueDescription "Use an exposed service on a device to extract data. This represents several of the mobile data extraction methods e.g. Query content providers (android), AFC (iOS)." ;
    solveit-core:techniqueID "DFT-1157" ;
    solveit-core:techniqueName "Extract device data using exposed service" .

:techniqueDFT-1159 a solveit-core:Technique ;
    rdfs:label "DFT-1159: Extract mobile data via deployed agent"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/MobileDevice"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/ServiceBasedExtractionData"^^xsd:anyURI ;
    solveit-core:hasExample "Belkasoft",
        "Elcomsoft" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1276 ;
    solveit-core:hasReference :citationDFCite-1016,
        :citationDFCite-1041 ;
    solveit-core:techniqueDescription "Deploy software to a mobile device that can carry out some function, either collect data with available permissions or attempt further exploitation e.g. sandbox escape." ;
    solveit-core:techniqueDetails "While Android agents can be sideloaded with adb, deploying agents on iOS may require a developer account. Output may be equivalent of a file system acquisition if an exploit is successful. Otherwise data such as contacts would be extracted." ;
    solveit-core:techniqueID "DFT-1159" ;
    solveit-core:techniqueName "Extract mobile data via deployed agent" .

:techniqueDFT-1160 a solveit-core:Technique ;
    rdfs:label "DFT-1160: Collect data with 'cloud backup restore' approach"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/SmartDevice"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1046 ;
    solveit-core:techniqueDescription "Restore a device's cloud backup to a donor device, then subsequently use a local acquisition approach on that donor device, e.g. T1019/T1020" ;
    solveit-core:techniqueID "DFT-1160" ;
    solveit-core:techniqueName "Collect data with 'cloud backup restore' approach" .

:techniqueDFT-1161 a solveit-core:Technique ;
    rdfs:label "DFT-1161: Collect data from cloud service via API using credentials"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/OnlineService"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Account"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/ContentData"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/EventRecord"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Message"^^xsd:anyURI ;
    solveit-core:hasExample "Cellebrite UFED Cloud",
        "FOREST (open-source cloud forensic tool)",
        "Magnet AXIOM Cloud",
        "Oxygen Forensic Cloud Extractor",
        "kumodd" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1338,
        :weaknessDFW-1339 ;
    solveit-core:hasReference :citationDFCite-1159,
        :citationDFCite-1160,
        :citationDFCite-1161 ;
    solveit-core:hasSynonym "API-based cloud acquisition",
        "Cloud Data Collection via RESTful API" ;
    solveit-core:techniqueDescription "Copying data from a cloud service using the officially supported API of the provider." ;
    solveit-core:techniqueDetails "API-based forensic acquisition of cloud data using the officially supported API of the provider can provide additional details and structure that is not available via other access methods. Requests may target public or undocumented endpoints identified via network observation or reverse engineering. Returned responses may include artifacts such as messages, file metadata, activity logs, and identity attributes. Analysts may use traffic capture tools or instrumentation to extract and store this data for forensic or intelligence purposes, both reactively and proactively." ;
    solveit-core:techniqueID "DFT-1161" ;
    solveit-core:techniqueName "Collect data from cloud service via API using credentials" .

:techniqueDFT-1162 a solveit-core:Technique ;
    rdfs:label "DFT-1162: Read data from a device via In-System Programming (ISP)"@en ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Image"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1136 ;
    solveit-core:hasSubtechnique :techniqueDFT-1027 ;
    solveit-core:hasSynonym "ISCP",
        "In-circuit serial Programming" ;
    solveit-core:techniqueID "DFT-1162" ;
    solveit-core:techniqueName "Read data from a device via In-System Programming (ISP)" .

:techniqueDFT-1163 a solveit-core:Technique ;
    rdfs:label "DFT-1163: Capture mobile device screenshots (automatically)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/MobileDevice"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/DeviceScreenshotCapture"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1137,
        :citationDFCite-1138 ;
    solveit-core:techniqueDescription "Programmatically controlling a mobile device while capturing screenshots of the display." ;
    solveit-core:techniqueDetails "This is the automated version of DFT-1022. The device is controlled programmatically, and screenshots are captured automatically." ;
    solveit-core:techniqueID "DFT-1163" ;
    solveit-core:techniqueName "Capture mobile device screenshots (automatically)" .

:techniqueDFT-1164 a solveit-core:Technique ;
    rdfs:label "DFT-1164: Read data directly from a block device"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ReadWriteDeviceInterface"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/WriteProtectedDeviceInterface"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/BitstreamRandomAccessed"^^xsd:anyURI ;
    solveit-core:techniqueDescription "Rather than imaging a block device, this involves accessing it directly without the expectation of saving block data to a forensic image format." ;
    solveit-core:techniqueDetails "This would typically be followed by processing of the data that is read to then provide a live view of partitions and file systems, and facilitates logical file extraction or any other direct operations on the data." ;
    solveit-core:techniqueID "DFT-1164" ;
    solveit-core:techniqueName "Read data directly from a block device" .

:techniqueDFT-1165 a solveit-core:Technique ;
    rdfs:label "DFT-1165: Extract software configuration information"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ApplicationFiles"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/configuration/Configuration"^^xsd:anyURI ;
    solveit-core:techniqueDescription "Examination of one or more files to extract configuration information for a piece of software." ;
    solveit-core:techniqueDetails "A configuration file of a browser for example may contain the home page that is set or other information. This technique extracts and presents that configuration information." ;
    solveit-core:techniqueID "DFT-1165" ;
    solveit-core:techniqueName "Extract software configuration information" .

:techniqueDFT-1166 a solveit-core:Technique ;
    rdfs:label "DFT-1166: Connect directly to storage media"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Disk"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/StorageMedium"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/ReadWriteDeviceInterface"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1277 ;
    solveit-core:techniqueDescription "This technique describes the occasions where it is necessary to connect directly to a disk without a hardware write blocker. This would typically then involve a subseqeunt software write blocker, which then presents a write protected interface." ;
    solveit-core:techniqueID "DFT-1166" ;
    solveit-core:techniqueName "Connect directly to storage media" .

:techniqueDFT-1167 a solveit-core:Technique ;
    rdfs:label "DFT-1167: Extract search terms from URLs"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/URL"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/URLHistory"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/urlHistoryEntry"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/keywordSearchTerm"^^xsd:anyURI ;
    solveit-core:hasExample "DuckDuckGo search URLs",
        "Google search URLs" ;
    solveit-core:hasReference :citationDFCite-1065 ;
    solveit-core:techniqueDescription "Parsing a URL and extracting search terms from the parameters." ;
    solveit-core:techniqueDetails """These may be `q=` strings or some other encoded parameters. 

This would include web search URLs such as Google searches but could also include search terms entered into other sites such as travel or shopping sites.""" ;
    solveit-core:techniqueID "DFT-1167" ;
    solveit-core:techniqueName "Extract search terms from URLs" .

:techniqueDFT-1168 a solveit-core:Technique ;
    rdfs:label "DFT-1168: Identify volumes"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/BitstreamRandomAccessed"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/DiskPartition"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/FileSystem"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1300 ;
    solveit-core:techniqueDescription "From a partition or data from a full disk, identify volumes." ;
    solveit-core:techniqueID "DFT-1168" ;
    solveit-core:techniqueName "Identify volumes" .

:techniqueDFT-1169 a solveit-core:Technique ;
    rdfs:label "DFT-1169: Filter files related to an application"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/AiChatAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/ApplicationFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/BrowserAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/BrowserCacheData"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/CalendarAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/ChatAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/EmailAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/GamingAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/HealthAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/MapsAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/NavigationAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/PaymentAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/PhotosAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/RemindersAppFiles"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/SocialMediaAppFiles"^^xsd:anyURI ;
    solveit-core:techniqueDescription "This technique takes a set of files and determines which are related to a specified application." ;
    solveit-core:techniqueDetails "A research process informs the set of files that are likely to be relevant to a particular application." ;
    solveit-core:techniqueID "DFT-1169" ;
    solveit-core:techniqueName "Filter files related to an application" .

:techniqueDFT-1170 a solveit-core:Technique ;
    rdfs:label "DFT-1170: Read contents from logical forensic container file(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/LogicalImageContainer"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasExample "AD1",
        "AFF4-L",
        "CTR",
        "L01" ;
    solveit-core:hasReference :citationDFCite-1035,
        :citationDFCite-1069 ;
    solveit-core:hasSynonym "Logical image decoding",
        "Read logical image" ;
    solveit-core:techniqueDescription "Decodes logical image formats such as L01, AD1, CTR, or AFF4-L. The output here is not an image file but rather a set of files and their metadata." ;
    solveit-core:techniqueID "DFT-1170" ;
    solveit-core:techniqueName "Read contents from logical forensic container file(s)" .

:techniqueDFT-1171 a solveit-core:Technique ;
    rdfs:label "DFT-1171: Access a file system via live operating system"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Computer"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasSynonym "Access file system via the running operating system" ;
    solveit-core:techniqueDescription "This involves accessing a live system and relying on the operating system's parsing of the file system to access files." ;
    solveit-core:techniqueID "DFT-1171" ;
    solveit-core:techniqueName "Access a file system via live operating system" .

:techniqueDFT-1172 a solveit-core:Technique ;
    rdfs:label "DFT-1172: Read bitstream from raw image file(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/RawImage"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/BitstreamRandomAccessed"^^xsd:anyURI ;
    solveit-core:hasSynonym "read dd file" ;
    solveit-core:techniqueDescription "This technique reads data from a raw image e.g. a dd image." ;
    solveit-core:techniqueDetails "This provides the 'raw' equivalent of reading data from a forensic image container e.g. EWF. This provides random access to the bitstream so the stored sectors can be processed further." ;
    solveit-core:techniqueID "DFT-1172" ;
    solveit-core:techniqueName "Read bitstream from raw image file(s)" .

:techniqueDFT-1173 a solveit-core:Technique ;
    rdfs:label "DFT-1173: Extract data from captured screenshots"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/DeviceScreenshotCapture"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Contact"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Message"^^xsd:anyURI ;
    solveit-core:techniqueDescription "Processing a screenshot captured from a device to extract data for further processing." ;
    solveit-core:techniqueDetails "When data has been captured from devices as screenshots, data can be extracted from them using OCR techniques to incorporate into the broader case data e..g to make searchable." ;
    solveit-core:techniqueID "DFT-1173" ;
    solveit-core:techniqueName "Extract data from captured screenshots" .

:techniqueDFT-1174 a solveit-core:Technique ;
    rdfs:label "DFT-1174: Read evidential files stored directly on local file system"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/ADBPullData"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/AFCExtractionData"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:techniqueDescription "Represents reading files that have been acquired or extracted directly to the local file system." ;
    solveit-core:techniqueDetails "For example an ADB pull command against a directory can result in a set of files copied to the local file system. This represents reading those files directly to extract information." ;
    solveit-core:techniqueID "DFT-1174" ;
    solveit-core:techniqueName "Read evidential files stored directly on local file system" .

:techniqueDFT-1175 a solveit-core:Technique ;
    rdfs:label "DFT-1175: Extract data from an Android device using content queries"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/AndroidPhone"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/Call"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Contact"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Message"^^xsd:anyURI ;
    solveit-core:hasReference :citationDFCite-1047 ;
    solveit-core:techniqueDescription "Use of content queries on Android devices via adb to extract specific pieces of data exposed by content providers." ;
    solveit-core:techniqueID "DFT-1175" ;
    solveit-core:techniqueName "Extract data from an Android device using content queries" .

:techniqueDFT-1176 a solveit-core:Technique ;
    rdfs:label "DFT-1176: Classify if an image is potentially synthetically generated"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/RasterPicture"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/analysis/ArtifactClassification"^^xsd:anyURI ;
    solveit-core:hasSynonym "Deepfake Detection, Synthetic Image Detection, Image Source Attribution, Image Authentication, Image Source Classification" ;
    solveit-core:techniqueDescription "Classification of images with respect to their origin, i.e., whether they are synthetically generated or naturally captured by a camera." ;
    solveit-core:techniqueDetails "An image is analyzed using a method from the subtechniques. The output can be a classifier-predicted score of how many traces of synthetic origin can be found in an image, or extracted traces from the image that aid the analyst in their assessment of the image origin." ;
    solveit-core:techniqueID "DFT-1176" ;
    solveit-core:techniqueName "Classify if an image is potentially synthetically generated" .

:techniqueDFT-1177 a solveit-core:Technique ;
    rdfs:label "DFT-1177: Extract artifacts from multiplayer game app(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/GamingAppFiles"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/configuration/Configuration"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Account"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Contact"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Message"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1279,
        :weaknessDFW-1280,
        :weaknessDFW-1281,
        :weaknessDFW-1282,
        :weaknessDFW-1283,
        :weaknessDFW-1284,
        :weaknessDFW-1285,
        :weaknessDFW-1286,
        :weaknessDFW-1287,
        :weaknessDFW-1288,
        :weaknessDFW-1289,
        :weaknessDFW-1290,
        :weaknessDFW-1291,
        :weaknessDFW-1292,
        :weaknessDFW-1293,
        :weaknessDFW-1294 ;
    solveit-core:hasReference :citationDFCite-1143 ;
    solveit-core:hasSynonym "gaming app examination" ;
    solveit-core:techniqueDescription "Extracting artifacts from multiplayer gaming apps." ;
    solveit-core:techniqueDetails "Multiplayer game apps often offer messaging, contacts/friends, and other features that could contain data that may be relevant to many types of case." ;
    solveit-core:techniqueID "DFT-1177" ;
    solveit-core:techniqueName "Extract artifacts from multiplayer game app(s)" .

:techniqueDFT-1178 a solveit-core:Technique ;
    rdfs:label "DFT-1178: Store bitstream data in a raw image format"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/Bitstream"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/RawImage"^^xsd:anyURI ;
    solveit-core:hasSynonym "store dd image",
        "write dd image" ;
    solveit-core:techniqueDescription "Storage of bitstream data recovered from a digital device as raw files." ;
    solveit-core:techniqueDetails "Bitstream data resulting from disk imaging stored in a raw format. The imaged data may be stored as one file or split into several segments. The raw files may also be accompanied by complementary separate metadata files." ;
    solveit-core:techniqueID "DFT-1178" ;
    solveit-core:techniqueName "Store bitstream data in a raw image format" .

:techniqueDFT-1179 a solveit-core:Technique ;
    rdfs:label "DFT-1179: Extract artifacts from drone/UAV app(s)"@en ;
    solveit-core:hasSynonym "UAV app examination" ;
    solveit-core:techniqueDescription "The examination of a mobile app used to control Unmanned Areial Vehicles (UAVs) or 'drones'." ;
    solveit-core:techniqueID "DFT-1179" ;
    solveit-core:techniqueName "Extract artifacts from drone/UAV app(s)" .

:techniqueDFT-1180 a solveit-core:Technique ;
    rdfs:label "DFT-1180: Extract file(s) from a pre-deletion container"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/DateTimeStamp"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/path"^^xsd:anyURI ;
    solveit-core:hasExample "Windows Recycle Bin",
        "macOS Trash" ;
    solveit-core:hasSynonym "Recycle Bin examination",
        "Trash examination" ;
    solveit-core:techniqueDescription "An examination of the operating system structures that represent the 'pre-deletion' container (i.e. Recycle Bin/Trash) to extract those files and potentially additional metadata such as original path or date it was moved." ;
    solveit-core:techniqueDetails """Content in pre-deletion containers such as the recycle bin/trash is not always viewable in a useful form without further processing. 
This further processing should provide access to the file content but also potentially additional information such as data sent to recycle bin, or original path.""" ;
    solveit-core:techniqueID "DFT-1180" ;
    solveit-core:techniqueName "Extract file(s) from a pre-deletion container" .

:techniqueDFT-1181 a solveit-core:Technique ;
    rdfs:label "DFT-1181: Extract artifacts from smart home app(s)"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/SmartHomeAppFiles"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/location/Location"^^xsd:anyURI ;
    solveit-core:hasExample "Apple Home",
        "Philips Hue",
        "SmartThings" ;
    solveit-core:techniqueDescription "Examine the data stored by an app designed to control, monitor or program smart home capabilities." ;
    solveit-core:techniqueDetails "There are many other components to a smart home system including the devices themselves (possibly different hubs and sensors), plus the online content. This technique focuses on the app." ;
    solveit-core:techniqueID "DFT-1181" ;
    solveit-core:techniqueName "Extract artifacts from smart home app(s)" .

:techniqueDFT-1182 a solveit-core:Technique ;
    rdfs:label "DFT-1182: Filter a timeline for relevant entries"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/Timeline"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/Timeline"^^xsd:anyURI ;
    solveit-core:hasExample "Plaso",
        "TimeSketch" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1295,
        :weaknessDFW-1296,
        :weaknessDFW-1297,
        :weaknessDFW-1298,
        :weaknessDFW-1299 ;
    solveit-core:techniqueDescription "Provide some criteria that selects only a subset of timeline entries from a set. " ;
    solveit-core:techniqueDetails "Filtering might be on timestamp type, within a defined time range, related to a particular file, or matching against some other content associated with the timestamp entries. " ;
    solveit-core:techniqueID "DFT-1182" ;
    solveit-core:techniqueName "Filter a timeline for relevant entries" .

:techniqueDFT-1184 a solveit-core:Technique ;
    rdfs:label "DFT-1184: Sort a timeline so entries are ordered chronologically"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/Timeline"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/SortedTimeline"^^xsd:anyURI ;
    solveit-core:hasExample "Plaso",
        "TimeSketch" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1308,
        :weaknessDFW-1309,
        :weaknessDFW-1310,
        :weaknessDFW-1311,
        :weaknessDFW-1312,
        :weaknessDFW-1313,
        :weaknessDFW-1314 ;
    solveit-core:techniqueDescription "Order a timeline based on the values in the timestamp entry." ;
    solveit-core:techniqueDetails "This may be applied automatically to a generated timeline or may be applied as a separate process. " ;
    solveit-core:techniqueID "DFT-1184" ;
    solveit-core:techniqueName "Sort a timeline so entries are ordered chronologically" .

:techniqueDFT-1185 a solveit-core:Technique ;
    rdfs:label "DFT-1185: Extract data from operating system notifications"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/Message"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/DateTimeStamp"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/Message"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1315,
        :weaknessDFW-1316,
        :weaknessDFW-1317,
        :weaknessDFW-1318,
        :weaknessDFW-1319,
        :weaknessDFW-1320,
        :weaknessDFW-1321 ;
    solveit-core:hasReference :citationDFCite-1149,
        :citationDFCite-1150 ;
    solveit-core:hasSynonym "Notification analysis",
        "WPN analysis" ;
    solveit-core:techniqueDescription "Recovery of the notifications produced by applications that are stored by the operating system. " ;
    solveit-core:techniqueID "DFT-1185" ;
    solveit-core:techniqueName "Extract data from operating system notifications" .

:techniqueDFT-1186 a solveit-core:Technique ;
    rdfs:label "DFT-1186: Compute per-file hash values"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/hash"^^xsd:anyURI ;
    solveit-core:hasExample "Autopsy hash lookup ingest module computing per-file hashes",
        "md5sum / sha256sum applied recursively over a mounted forensic image" ;
    solveit-core:hasSynonym "File hashing",
        "Per-file hashing" ;
    solveit-core:techniqueDescription "The process of computing one or more hash digests for each file in a set, producing per-file digests that can subsequently be used for matching, deduplication, or integrity comparison." ;
    solveit-core:techniqueDetails """This technique does vary based on the kind of digest produced: cryptographic-digest computation for exact matching, and fuzzy or similarity-digest computation for approximate matching. 

The output of this technique is typically consumed by hash-matching techniques including DFT-1047, DFT-1050, and DFT-1051. 

This technique is distinct from DFT-1042, which hashes the entire bitstream of a source device for acquisition integrity rather than individual files within the file system.""" ;
    solveit-core:techniqueID "DFT-1186" ;
    solveit-core:techniqueName "Compute per-file hash values" .

:techniqueDFT-1187 a solveit-core:Technique ;
    rdfs:label "DFT-1187: Extract content from compound files"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/File"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasExample "Autopsy Embedded File Extractor module" ;
    solveit-core:hasSynonym "Compound file expansion",
        "Container file expansion",
        "Embedded file extraction" ;
    solveit-core:techniqueDescription "The process of extracting files and objects contained within compound files, including archives, Office documents, PDFs, and email containers, surfacing the contained items as first-class files for further analysis." ;
    solveit-core:techniqueDetails """'Compound file' is used here in the broad sense: any file format whose payload is one or more other files. 

This covers user-downloaded archives (.zip, .rar, .7z, .tar), images and objects embedded in Office documents (.docx / .xlsx / .pptx, and legacy .doc / .xls / .ppt that use the Microsoft Compound File Binary Format, attachments and embedded streams in PDFs, and attachments inside email containers. 

Extracting them surfaces each contained item as a first-class file so downstream techniques such as file-type identification, extension-mismatch detection, and hash matching can operate on the content. 

This is distinct from DFT-1045, which decodes archive containers produced by the forensic extraction pipeline (e.g. an iOS file-system extraction packaged as a TAR file); this technique is applied later in the workflow, against compound files encountered within user data. The technique should be applied recursively because extracted items may themselves be compound files.""" ;
    solveit-core:techniqueID "DFT-1187" ;
    solveit-core:techniqueName "Extract content from compound files" .

:techniqueDFT-1190 a solveit-core:Technique ;
    rdfs:label "DFT-1190: Extract operating system version(s) from data source"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/FileSet"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1324,
        :weaknessDFW-1325,
        :weaknessDFW-1326,
        :weaknessDFW-1327,
        :weaknessDFW-1328,
        :weaknessDFW-1329 ;
    solveit-core:hasReference :citationDFCite-1157 ;
    solveit-core:techniqueDescription "The process of extracting and processing the artifacts that describe the current operating system version and associated version details e.g. build, service pack etc." ;
    solveit-core:techniqueDetails """Each operating system will have a specific artifact that allows this to be performed e.g. details from the Registry on Windows. 

It is also sometimes possible to determine older versions of the operating system which have been used, with timestamps, which may be useful for later functional reconstruction (DFT-1156)""" ;
    solveit-core:techniqueID "DFT-1190" ;
    solveit-core:techniqueName "Extract operating system version(s) from data source" .

:techniqueDFT-1191 a solveit-core:Technique ;
    rdfs:label "DFT-1191: Parse allocated structures in Windows HIVE files"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/WindowsRegistryHive"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/WindowsRegistryKey"^^xsd:anyURI,
        "https://ontology.unifiedcyberontology.org/uco/observable/WindowsRegistryValue"^^xsd:anyURI ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1330,
        :weaknessDFW-1331,
        :weaknessDFW-1332,
        :weaknessDFW-1333,
        :weaknessDFW-1334,
        :weaknessDFW-1335,
        :weaknessDFW-1336,
        :weaknessDFW-1337 ;
    solveit-core:hasReference :citationDFCite-1158 ;
    solveit-core:hasSynonym "Registry analysis" ;
    solveit-core:techniqueDescription "Enumerate the allocated structures within HIVE files (typically Windows Registry) to extract the tree structure along with keys and their values. " ;
    solveit-core:techniqueDetails "This focuses on the data structure enumeration only, rather than taking a specific key and performing analysis on the data contained within. It covers allocated keys and values only." ;
    solveit-core:techniqueID "DFT-1191" ;
    solveit-core:techniqueName "Parse allocated structures in Windows HIVE files" .

:techniqueDFT-1192 a solveit-core:Technique ;
    rdfs:label "DFT-1192: Disable connectivity using device configuration settings"@en ;
    solveit-core:hasCASEInputClass "https://ontology.unifiedcyberontology.org/uco/observable/MobileDevice"^^xsd:anyURI ;
    solveit-core:hasCASEOutputClass "https://ontology.unifiedcyberontology.org/uco/observable/MobileDevice"^^xsd:anyURI ;
    solveit-core:hasExample "airplane mode",
        "flight mode" ;
    solveit-core:hasPotentialWeakness :weaknessDFW-1340,
        :weaknessDFW-1341,
        :weaknessDFW-1342,
        :weaknessDFW-1343 ;
    solveit-core:techniqueDescription "This involves changing settings on a device to attempt to remove any connectivity options so that data cannot be sent or received over typical RF channels. This may involve multiple settings e.g. airplane mode and separate Bluetooth and WiFi toggles." ;
    solveit-core:techniqueID "DFT-1192" ;
    solveit-core:techniqueName "Disable connectivity using device configuration settings" .

:techniqueDFT-1193 a solveit-core:Technique ;
    rdfs:label "DFT-1193: Read metadata from within a forensic image container"@en ;
    solveit-core:hasCASEInputClass "https://ontology.solveit-df.org/solveit/observable/LogicalImageContainer"^^xsd:anyURI,
        "https://ontology.solveit-df.org/solveit/observable/PhysicalImageContainer"^^xsd:anyURI ;
