      ],
      "uco-core:name": "Ding signs the MiraclePlus investment agreement (2023-11-20)",
      "uco-core:description": "Agreement granting a seven percent ownership interest in Zhisuan to a MiraclePlus-affiliated company in exchange for investment capital. Source: PACER Doc 140 (second_superseding_indictment), para. 22",
      "uco-action:performer": {
        "@id": "urn:uuid:aeeaf703-8a4a-554b-9882-0228790fb782"
