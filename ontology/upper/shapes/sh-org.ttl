	.

sh-org:changedBy-subjects-shape
	a sh:NodeShape ;
	sh:class org:Organization ;
	sh:property sh-org:changedBy-subjects-changedBy-shape ;
	sh:targetSubjectsOf org:changedBy ;
	.

