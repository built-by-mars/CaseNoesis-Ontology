      ],
      "uco-core:name": "Count One: Willful Retention and Transmission of National Defense Information (18 U.S.C. \u00a7 793(e))",
      "legalproc:statuteCitation": "18 U.S.C. \u00a7 793(e)",
      "legalproc:countNumber": {
        "@type": "xsd:nonNegativeInteger",
        "@value": "1"
      },
      "legalproc:countLabel": "Count One",
      "legalproc:offenseForm": "substantive",
      "legalproc:chargeDisposition": "convicted-by-plea",
      "legalproc:assertedIn": [
        {
          "@id": "urn:uuid:7201889a-283d-5f95-837e-7138fe023950"
        }
      ],
      "uco-core:description": "Charges that Nov. 2022 to April 2023, having unauthorized possession of, access to, and control over information relating to the national defense, Teixeira willfully communicated, delivered, and transmitted it to persons not entitled to receive it and willfully retained it. Charged NDI (TOP SECRET//SCI): Information regarding the compromise by a foreign adversary of certain accounts belonging to a U.S. company. Source: PACER Doc 48 (indictment), paras. 15-18"
    },
