@prefix : <https://ontology.solveit-df.org/solveit/core/> .
@prefix solveit-core: <https://ontology.solveit-df.org/solveit/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix uco-core: <https://ontology.unifiedcyberontology.org/uco/core/> .
@prefix uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/> .
@prefix uco-action: <https://ontology.unifiedcyberontology.org/uco/action/> .
@prefix case-investigation: <https://ontology.caseontology.org/case/investigation/> .
@base <https://ontology.solveit-df.org/solveit/core/> .

#################################################################
#    SOLVE-IT Core Ontology
#    Main ontology file with imports and metadata
#################################################################

<https://ontology.solveit-df.org/solveit/core> rdf:type owl:Ontology ;
    owl:versionIRI <https://ontology.solveit-df.org/solveit/core/0.1.9> ;
    owl:imports <https://ontology.unifiedcyberontology.org/uco/core/1.4.0> ,
                <https://ontology.unifiedcyberontology.org/uco/observable/1.4.0> ,
                <https://ontology.unifiedcyberontology.org/uco/action/1.4.0> ,                
                <https://ontology.caseontology.org/case/investigation/1.4.0> ,
                <https://ontology.solveit-df.org/solveit/observable> ,
                <https://ontology.solveit-df.org/solveit/analysis> ,
                <https://ontology.solveit-df.org/solveit/tool-profile> ,
                <https://ontology.solveit-df.org/solveit/weakness-assessment> ;
    dcterms:title "SOLVE-IT Digital Forensics Ontology"@en ;
    dcterms:description "A modular ontology extending UCO/CASE for the SOLVE-IT digital forensics project. This core ontology defines fundamental SOLVE-IT classes (Technique, Weakness, Mitigation) and imports modules for observables and analysis."@en ;
    dcterms:creator "SOLVE-IT Project" ;
    owl:versionInfo "0.1.9" ;
    rdfs:label "SOLVE-IT Ontology"@en ;
    rdfs:comment "Core ontology file with fundamental SOLVE-IT classes. Use this file to import the complete SOLVE-IT ontology."@en .

#################################################################
#    Classes
#################################################################

###  SOLVE-IT Technique
solveit-core:Technique rdf:type owl:Class ;
    rdfs:subClassOf case-investigation:InvestigativeAction ;
    rdfs:label "SOLVE-IT Technique"@en ;
    rdfs:comment "A digital forensic technique representing how one might achieve an objective by performing an action. Based on the SOLVE-IT knowledge base."@en .

###  SOLVE-IT Weakness
solveit-core:Weakness rdf:type owl:Class ;
    rdfs:subClassOf uco-core:UcoObject ;
    rdfs:label "SOLVE-IT Weakness"@en ;
    rdfs:comment "A potential problem resulting from using a technique, classified according to ASTM E3016-18 error categories."@en .

###  SOLVE-IT Mitigation
solveit-core:Mitigation rdf:type owl:Class ;
    rdfs:subClassOf case-investigation:InvestigativeAction ;
    rdfs:label "SOLVE-IT Mitigation"@en ;
    rdfs:comment "An action that can be performed to prevent a weakness from occurring or to minimize its impact."@en .

###  SOLVE-IT Objective
solveit-core:Objective rdf:type owl:Class ;
    rdfs:subClassOf uco-core:UcoObject ;
    rdfs:label "SOLVE-IT Objective"@en ;
    rdfs:comment "A goal or objective in a digital forensic investigation that can be achieved through one or more techniques."@en .

###  SOLVE-IT Investigative Action
solveit-core:SolveitInvestigativeAction rdf:type owl:Class ;
    rdfs:subClassOf case-investigation:InvestigativeAction ;
    rdfs:label "SOLVE-IT Investigative Action"@en ;
    rdfs:comment "A SOLVE-IT aware InvestigativeAction that links an investigative action to the SOLVE-IT technique(s) used (1..n via usedTechnique) and any mitigations applied (0..n via appliedMitigation) during its execution."@en .

#################################################################
#    Object Properties
#################################################################

solveit-core:hasPotentialWeakness rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range solveit-core:Weakness ;
    rdfs:label "has potential weakness"@en ;
    rdfs:comment "Links a Technique to potential weaknesses (error categories from ASTM E3016-18) that may occur when using this technique."@en .

solveit-core:hasSubtechnique rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range solveit-core:Technique ;
    rdfs:label "has subtechnique"@en ;
    rdfs:comment "Links a Technique to more specific subtechniques."@en .

solveit-core:hasPotentialMitigation rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-core:Weakness ;
    rdfs:range solveit-core:Mitigation ;
    rdfs:label "has potential mitigation"@en ;
    rdfs:comment "Links a Weakness to mitigations that can potentially prevent or minimize it."@en .

solveit-core:linksToTechnique rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-core:Mitigation ;
    rdfs:range solveit-core:Technique ;
    rdfs:label "links to technique"@en ;
    rdfs:comment "Links a Mitigation to the Technique(s) it is relevant for or applies to."@en .

solveit-core:includesTechnique rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-core:Objective ;
    rdfs:range solveit-core:Technique ;
    rdfs:label "includes technique"@en ;
    rdfs:comment "Links an Objective to Techniques that can be used to achieve it."@en .

solveit-core:usedTechnique rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-core:SolveitInvestigativeAction ;
    rdfs:range solveit-core:Technique ;
    rdfs:label "used technique"@en ;
    rdfs:comment "Links a SolveitInvestigativeAction to the SOLVE-IT Technique definition(s) that were executed. At least one technique must be specified (1..n)."@en .

solveit-core:appliedMitigation rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-core:SolveitInvestigativeAction ;
    rdfs:range solveit-core:Mitigation ;
    rdfs:label "applied mitigation"@en ;
    rdfs:comment "Links a SolveitInvestigativeAction to Mitigation(s) that were actively applied during the execution to prevent or minimize potential weaknesses (0..n)."@en .

#################################################################
#    Data Properties - Technique
#################################################################

solveit-core:techniqueID rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range xsd:string ;
    rdfs:label "technique ID"@en ;
    rdfs:comment "The unique identifier for a SOLVE-IT technique (e.g., T1002)."@en .

solveit-core:techniqueName rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range xsd:string ;
    rdfs:label "technique name"@en ;
    rdfs:comment "The name of the technique (e.g., 'Disk imaging')."@en .

solveit-core:techniqueDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range xsd:string ;
    rdfs:label "technique description"@en ;
    rdfs:comment "A detailed description of how the technique is performed."@en .

solveit-core:techniqueDetails rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range xsd:string ;
    rdfs:label "technique details"@en ;
    rdfs:comment "Additional details about the technique."@en .

solveit-core:hasCASEInputClass rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range xsd:anyURI ;
    rdfs:label "has CASE input class"@en ;
    rdfs:comment "A CASE/UCO class IRI that represents an expected input to this technique. Multiple input classes can be specified (e.g., https://ontology.solveit-df.org/solveit/observable/WriteProtectedDeviceInterface)."@en .

solveit-core:hasCASEOutputClass rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range xsd:anyURI ;
    rdfs:label "has CASE output class"@en ;
    rdfs:comment "A CASE/UCO class IRI that represents an output of this technique. Multiple output classes can be specified (e.g., https://ontology.unifiedcyberontology.org/uco/observable/Image)."@en .

#################################################################
#    Data Properties - Weakness
#################################################################

solveit-core:weaknessID rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Weakness ;
    rdfs:range xsd:string ;
    rdfs:label "weakness ID"@en ;
    rdfs:comment "The unique identifier for a SOLVE-IT weakness (e.g., W1004)."@en .

solveit-core:weaknessName rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Weakness ;
    rdfs:range xsd:string ;
    rdfs:label "weakness name"@en ;
    rdfs:comment "The name describing the weakness."@en .

solveit-core:weaknessDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Weakness ;
    rdfs:range xsd:string ;
    rdfs:label "weakness description"@en ;
    rdfs:comment "A detailed description of the weakness and its potential impacts."@en .

#################################################################
#    ASTM Error Category class and individuals
#################################################################

solveit-core:ASTMErrorCategory rdf:type owl:Class ;
    rdfs:label "ASTM Error Category"@en ;
    rdfs:comment "An error category from ASTM E3016-18 used to classify weakness impacts."@en .

solveit-core:hasWeaknessClass rdf:type owl:ObjectProperty ;
    rdfs:domain solveit-core:Weakness ;
    rdfs:range solveit-core:ASTMErrorCategory ;
    rdfs:label "has weakness class"@en ;
    rdfs:comment "Associates a weakness with an ASTM E3016-18 error category."@en .

solveit-core:ASTM_INCOMP rdf:type owl:NamedIndividual, solveit-core:ASTMErrorCategory ;
    rdfs:label "INCOMP"@en ;
    rdfs:comment "Incompleteness — failure to recover live or deleted artefacts (ASTM E3016-18)."@en .

solveit-core:ASTM_INAC_EX rdf:type owl:NamedIndividual, solveit-core:ASTMErrorCategory ;
    rdfs:label "INAC-EX"@en ;
    rdfs:comment "Inaccuracy: Existence — presenting artefacts for non-existent items (ASTM E3016-18)."@en .

solveit-core:ASTM_INAC_AS rdf:type owl:NamedIndividual, solveit-core:ASTMErrorCategory ;
    rdfs:label "INAC-AS"@en ;
    rdfs:comment "Inaccuracy: Association — e.g. presenting live data as deleted (ASTM E3016-18)."@en .

solveit-core:ASTM_INAC_ALT rdf:type owl:NamedIndividual, solveit-core:ASTMErrorCategory ;
    rdfs:label "INAC-ALT"@en ;
    rdfs:comment "Inaccuracy: Alteration — modifying the content of digital data (ASTM E3016-18)."@en .

solveit-core:ASTM_INAC_COR rdf:type owl:NamedIndividual, solveit-core:ASTMErrorCategory ;
    rdfs:label "INAC-COR"@en ;
    rdfs:comment "Inaccuracy: Corruption — process could corrupt data or fail to detect corrupt data (ASTM E3016-18)."@en .

solveit-core:ASTM_MISINT rdf:type owl:NamedIndividual, solveit-core:ASTMErrorCategory ;
    rdfs:label "MISINT"@en ;
    rdfs:comment "Misinterpretation — results presented in a way that encourages misinterpretation (ASTM E3016-18)."@en .

#################################################################
#    Data Properties - Mitigation
#################################################################

solveit-core:mitigationID rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Mitigation ;
    rdfs:range xsd:string ;
    rdfs:label "mitigation ID"@en ;
    rdfs:comment "The unique identifier for a SOLVE-IT mitigation (e.g., M1001)."@en .

solveit-core:mitigationName rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Mitigation ;
    rdfs:range xsd:string ;
    rdfs:label "mitigation name"@en ;
    rdfs:comment "The name describing the mitigation action."@en .

solveit-core:mitigationDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Mitigation ;
    rdfs:range xsd:string ;
    rdfs:label "mitigation description"@en ;
    rdfs:comment "A detailed description of how the mitigation prevents or minimizes a weakness."@en .

#################################################################
#    Data Properties - Objective
#################################################################

solveit-core:objectiveName rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Objective ;
    rdfs:range xsd:string ;
    rdfs:label "objective name"@en ;
    rdfs:comment "The name of the objective."@en .

solveit-core:objectiveDescription rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Objective ;
    rdfs:range xsd:string ;
    rdfs:label "objective description"@en ;
    rdfs:comment "A detailed description of what this objective seeks to achieve."@en .

#################################################################
#    Shared Data Properties
#################################################################

solveit-core:hasReference rdf:type owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class ;
                  owl:unionOf ( solveit-core:Technique
                               solveit-core:Weakness
                               solveit-core:Mitigation ) ] ;
    rdfs:range xsd:string ;
    rdfs:label "has reference"@en ;
    rdfs:comment "Academic or professional reference citation for Technique, Weakness, or Mitigation."@en .

solveit-core:hasSynonym rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range xsd:string ;
    rdfs:label "has synonym"@en ;
    rdfs:comment "Alternative name or synonym for a Technique."@en .

solveit-core:hasExample rdf:type owl:DatatypeProperty ;
    rdfs:domain solveit-core:Technique ;
    rdfs:range xsd:string ;
    rdfs:label "has example"@en ;
    rdfs:comment "Example tool, implementation, or instance for a Technique."@en .
