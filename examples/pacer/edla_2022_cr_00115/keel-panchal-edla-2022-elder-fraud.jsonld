    {
      "@id": "urn:uuid:22cdd8f6-2e13-5cc4-bddd-8464e6f81067",
      "@type": [
        "uco-identity:Person",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Valerie Welz Jusselin (Federal Public Defender, New Orleans)",
      "uco-core:description": "Lead appointed counsel for Keel from 2022-06-03 through plea and sentencing. Source: PACER Doc criminal docket sheet (docket), defendant 1 counsel; D.E. 14"
    },
    {
