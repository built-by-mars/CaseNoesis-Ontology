    {
      "@id": "urn:uuid:4fbaa980-8fc4-5713-b5a0-e98616438232",
      "@type": [
        "legalproc:ChargingInstrument",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Indictment (Doc 1)",
      "uco-core:description": "Grand jury charged Ding with four counts of theft of trade secrets (18 U.S.C. \u00a7 1832): TPU v4 specifications, TPU v6 specifications, GPU hardware/software/system-management specifications, and CMS software design specifications, on or about 2022-06-01 to 2023-04-17. Magistrate Judge Virginia K. DeMarchi (no-process); assigned to Judge Vince Chhabria. Source: PACER Doc 1 (indictment), caption and counts",
      "legalproc:instrumentType": "indictment",
      "uco-core:objectCreatedTime": {
        "@type": "xsd:dateTime",
        "@value": "2024-03-05T00:00:00-08:00"
      }
    },
