        "uco-core:UcoObject"
      ],
      "uco-core:name": "Ding circulates the 'replicate and upgrade' Zhisuan document (2023-11-29)",
      "uco-core:description": "Circulated to the members of a Zhisuan WeChat group, claiming experience with 'Google's ten-thousand-card computational power platform' to be replicated and upgraded for China's national conditions. Source: PACER Doc 140 (second_superseding_indictment), para. 22",
      "uco-action:performer": {
