      "@type": "case-investigation:InvestigativeAction",
      "uco-core:name": "Arrest of Keel and seizure of his phone (2022-04-04)",
      "uco-core:description": "Search incident to arrest recovered Keel's Florida driver's license, his cell phone (placed into airplane mode to prevent remote wiping), and a receipt for the La Quinta Inn in Metairie. Victim A identified Keel as the man from the prior day's handoff. Source: PACER Doc 61 (factual_basis), p. 4",
      "uco-action:performer": {
        "@id": "urn:uuid:e292a20f-83cc-50f8-91f9-260e3eb1ac55"
