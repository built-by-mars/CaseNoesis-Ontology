    {
      "@id": "urn:uuid:116a986c-6842-5267-99d1-17b37ca4b51d",
      "@type": [
        "uco-action:Action",
        "uco-core:UcoObject"
      ],
      "uco-core:name": "Zhisuan/CMS fundraising coordinated in the I&R Capital WeChat group (2023-03-20 to 2023-05-11)",
      "uco-core:description": "Ding ('dingyong198608'), co-founder Ye Yuan, and I&R Capital staff drafted the CMS project teaser, named the company 'Zhisuan', circulated Ding's resume, and met with Sinovation Ventures, Sequoia Capital, Baidu Ventures, and IDG Capital \u2014 all while Ding remained a Google employee. Source: PACER Doc 191-1 (wechat_translation), pp. 2-43",
      "uco-action:performer": {
        "@id": "urn:uuid:aeeaf703-8a4a-554b-9882-0228790fb782"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
