        "@value": "true"
      }
    },
    {
      "@id": "urn:uuid:0d021b12-f5f2-55d6-9ccc-bdb987e28d3d",
      "@type": "uco-action:Action",
      "uco-core:name": "Kidnap Victim A at gunpoint and transport him to Moorhead",
      "uco-core:description": "Beginning in the waning hours of March 5, 2024, Victim A was taken at gunpoint from Fargo by Maez-Schaack and his co-conspirators, beaten, and brought in his own Ford F-250 to Altenor's residence in Moorhead, Minnesota. Source: PACER Doc 101 (plea), para. 6 factual basis",
      "uco-action:performer": {
        "@id": "urn:uuid:6820f49e-6abe-5bc2-a10c-31b9e922374b"
      },
      "uco-action:object": [
        {
          "@id": "urn:uuid:57f315e6-8aae-5d13-b370-46aecc23eeb0"
        }
      ],
      "uco-action:instrument": [
        {
          "@id": "urn:uuid:b19e4f7a-511e-57f9-bdf6-5380072d053f"
        }
      ],
      "uco-action:location": {
        "@id": "urn:uuid:fcc948d3-5d38-5858-9c7e-6b600bf0bae1"
      },
      "uco-action:startTime": {
        "@type": "xsd:dateTime",
        "@value": "2024-03-05T00:00:00-06:00"
      },
      "uco-action:endTime": {
        "@type": "xsd:dateTime",
        "@value": "2024-03-06T00:00:00-06:00"
      }
    },
